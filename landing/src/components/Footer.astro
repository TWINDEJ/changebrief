---

<section class="relative py-24 lg:py-32">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-0 right-0 h-px" style="background: var(--border-primary);"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 text-center">
    <h2 class="animate-fade-in-up text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
      Start monitoring your most<br class="hidden sm:block" /> important pages <span style="color: var(--accent);">today</span>
    </h2>
    <p class="mx-auto mt-4 max-w-xl animate-fade-in-up delay-100 text-lg text-slate-400">Free to get started. No credit card required.</p>
    <a href="https://app.changebrief.io" class="mt-8 inline-flex animate-fade-in-up delay-200 items-center gap-2 rounded-full px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-all duration-300 hover:shadow cursor-pointer" style="background: var(--accent);">
      Create account — free
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
    </a>
  </div>
</section>

<footer class="border-t border-white/5 py-12">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 sm:flex-row sm:justify-between">
    <div class="flex items-center gap-2.5 text-lg font-bold">
      <div class="flex h-7 w-7 items-center justify-center rounded-lg" style="background: var(--accent);">
        <svg class="h-3.5 w-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="12" cy="12" r="3" />
          <path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z" />
        </svg>
      </div>
      <span class="text-white/70">changebrief</span>
    </div>
    <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-slate-600">
      <a href="/blog" class="transition-colors duration-200 hover:text-white cursor-pointer">Blog</a>
      <a href="/security" class="transition-colors duration-200 hover:text-white cursor-pointer">Security</a>
      <a href="/compliance" class="transition-colors duration-200 hover:text-white cursor-pointer">Compliance</a>
      <a href="/privacy" class="transition-colors duration-200 hover:text-white cursor-pointer">Privacy</a>
      <a href="/terms" class="transition-colors duration-200 hover:text-white cursor-pointer">Terms</a>
      <a href="/dpa" class="transition-colors duration-200 hover:text-white cursor-pointer">DPA</a>
      <a href="mailto:kristian@changebrief.io" class="transition-colors duration-200 hover:text-white cursor-pointer">Contact</a>
    </nav>
    <p class="text-sm text-slate-700">&copy; 2026 changebrief</p>
  </div>
</footer>
