---
import { lt, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const sv = lang === 'sv';
---

<div class="mx-auto max-w-4xl px-6 pt-32 pb-24">
  <!-- Hero -->
  <div class="text-center mb-20 animate-fade-in-up">
    <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500/20 to-blue-500/20 border border-emerald-500/20">
      <svg class="h-8 w-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
    </div>
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      {sv ? 'Säkerhet & ' : 'Security & '}<span class="text-gradient">{sv ? 'Förtroende' : 'Trust'}</span>
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg theme-text-secondary">
      {sv
        ? 'Vi vet att compliance-data är känslig. Så här skyddar vi den.'
        : 'We know compliance data is sensitive. Here is how we protect it.'}
    </p>
  </div>

  <!-- Grid -->
  <div class="grid gap-8 sm:grid-cols-2">
    <!-- Data Residency -->
    <div class="glass-card rounded-2xl p-8 animate-fade-in-up delay-100">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-500/10">
          <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold theme-text">{sv ? 'Datalagringsplats' : 'Data Residency'}</h3>
      </div>
      <p class="theme-text-secondary text-sm leading-relaxed">
        {sv
          ? 'All data lagras i EU (AWS eu-west-1, Irland) via Turso. Inga data lämnar EU om du inte explicit konfigurerar webhook-integration till system utanför EU.'
          : 'All data is stored in the EU (AWS eu-west-1, Ireland) via Turso. No data leaves the EU unless you explicitly configure webhook integrations to systems outside the EU.'}
      </p>
    </div>

    <!-- Encryption -->
    <div class="glass-card rounded-2xl p-8 animate-fade-in-up delay-200">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-500/10">
          <svg class="h-5 w-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold theme-text">{sv ? 'Kryptering' : 'Encryption'}</h3>
      </div>
      <p class="theme-text-secondary text-sm leading-relaxed">
        {sv
          ? 'TLS 1.3 för all kommunikation. Data krypteras i vila (AES-256). Alla API-nycklar och hemligheter lagras i miljövariabler, aldrig i kod.'
          : 'TLS 1.3 for all communication. Data encrypted at rest (AES-256). All API keys and secrets stored in environment variables, never in code.'}
      </p>
    </div>

    <!-- Authentication -->
    <div class="glass-card rounded-2xl p-8 animate-fade-in-up delay-300">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-500/10">
          <svg class="h-5 w-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold theme-text">{sv ? 'Autentisering' : 'Authentication'}</h3>
      </div>
      <p class="theme-text-secondary text-sm leading-relaxed">
        {sv
          ? 'OAuth 2.0 via Google och GitHub. Vi lagrar aldrig lösenord. SSO/SAML tillgängligt på Enterprise-planen.'
          : 'OAuth 2.0 via Google and GitHub. We never store passwords. SSO/SAML available on Enterprise plan.'}
      </p>
    </div>

    <!-- GDPR -->
    <div class="glass-card rounded-2xl p-8 animate-fade-in-up delay-400">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-purple-500/10">
          <svg class="h-5 w-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold theme-text">GDPR</h3>
      </div>
      <p class="theme-text-secondary text-sm leading-relaxed">
        {sv
          ? 'Fullständigt GDPR-kompatibelt. Vi behandlar enbart data som behövs för tjänsten. Databehandlingsavtal (DPA) tillgängligt på begäran. Rätt till radering — kontakta oss.'
          : 'Fully GDPR compliant. We only process data necessary for the service. Data Processing Agreement (DPA) available on request. Right to erasure — contact us.'}
      </p>
    </div>

    <!-- Audit Trail -->
    <div class="glass-card rounded-2xl p-8 animate-fade-in-up delay-500">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-500/10">
          <svg class="h-5 w-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold theme-text">{sv ? 'Revisionshistorik' : 'Audit Trail'}</h3>
      </div>
      <p class="theme-text-secondary text-sm leading-relaxed">
        {sv
          ? 'Varje ändring tidsstämplas. Varje granskning loggas med vem som granskade och när. Exportera som CSV eller PDF för revisioner.'
          : 'Every change is timestamped. Every review is logged with who reviewed and when. Export as CSV or PDF for audits.'}
      </p>
    </div>

    <!-- Infrastructure -->
    <div class="glass-card rounded-2xl p-8 animate-fade-in-up delay-600">
      <div class="flex items-center gap-3 mb-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-500/10">
          <svg class="h-5 w-5 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold theme-text">{sv ? 'Infrastruktur' : 'Infrastructure'}</h3>
      </div>
      <p class="theme-text-secondary text-sm leading-relaxed">
        {sv
          ? 'Hostad på Vercel (edge network) och Cloudflare. Databas via Turso (SQLite, distribuerad, EU). 99.9% uptime-mål.'
          : 'Hosted on Vercel (edge network) and Cloudflare. Database via Turso (SQLite, distributed, EU). 99.9% uptime target.'}
      </p>
    </div>
  </div>

  <!-- DPA & Contact -->
  <div class="mt-16 glass-card rounded-2xl p-8 text-center animate-fade-in-up">
    <h2 class="text-2xl font-bold theme-text mb-3">
      {sv ? 'Behöver ni ett DPA eller har säkerhetsfrågor?' : 'Need a DPA or have security questions?'}
    </h2>
    <p class="theme-text-secondary text-sm mb-6 max-w-lg mx-auto">
      {sv
        ? 'Vi erbjuder databehandlingsavtal (DPA), säkerhetsöversikter och kan svara på er IT-avdelnings frågor. Kontakta oss direkt.'
        : 'We provide Data Processing Agreements (DPA), security overviews, and can answer your IT department\'s questions. Contact us directly.'}
    </p>
    <a
      href="mailto:kristian@changebrief.io?subject=Security%20%26%20DPA%20inquiry"
      class="btn-glow inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-emerald-600 to-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg transition-all duration-200 cursor-pointer"
    >
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      kristian@changebrief.io
    </a>
  </div>

  <!-- Compliance Badges -->
  <div class="mt-12 flex flex-wrap justify-center gap-6 animate-fade-in-up">
    <div class="glass rounded-xl px-5 py-3 flex items-center gap-2.5">
      <svg class="h-5 w-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="10" /><path d="M8 12h8M12 8v8" stroke-linecap="round" />
      </svg>
      <span class="text-sm font-medium theme-text-secondary">EU {sv ? 'datalagring' : 'data residency'}</span>
    </div>
    <div class="glass rounded-xl px-5 py-3 flex items-center gap-2.5">
      <svg class="h-5 w-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="text-sm font-medium theme-text-secondary">GDPR {sv ? 'kompatibel' : 'compliant'}</span>
    </div>
    <div class="glass rounded-xl px-5 py-3 flex items-center gap-2.5">
      <svg class="h-5 w-5 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="text-sm font-medium theme-text-secondary">TLS 1.3 + AES-256</span>
    </div>
    <div class="glass rounded-xl px-5 py-3 flex items-center gap-2.5">
      <svg class="h-5 w-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span class="text-sm font-medium theme-text-secondary">{sv ? 'Revisionshistorik' : 'Audit trail'}</span>
    </div>
  </div>
</div>
