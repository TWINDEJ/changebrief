---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import { lt, type Lang } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;

const title = lang === 'sv'
  ? 'changebrief — Regulatorisk omvärldsbevakning med AI'
  : 'changebrief — AI-powered regulatory monitoring';
const description = lt('reg.sub', lang);
---

<Base title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden pt-36 pb-24 lg:pt-44 lg:pb-36">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full bg-red-600/6 blur-[120px] animate-glow-pulse"></div>
        <div class="absolute top-1/3 left-1/3 h-[300px] w-[300px] rounded-full bg-amber-500/4 blur-[80px] animate-glow-pulse delay-200"></div>
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-red-500/20 to-transparent"></div>
      </div>
      <div class="relative mx-auto max-w-6xl px-6 text-center">
        <div class="mb-8 inline-flex animate-fade-in-up items-center gap-2.5 rounded-full glass px-4 py-2 text-sm text-red-300/90">
          <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-red-400"></span></span>
          {lt('reg.badge', lang)}
        </div>
        <h1 class="mx-auto max-w-4xl animate-fade-in-up delay-100 text-5xl font-extrabold leading-[1.1] tracking-tight sm:text-6xl lg:text-7xl">
          {lt('reg.h1a', lang)}
          <span class="block bg-gradient-to-r from-red-400 via-amber-400 to-orange-400 bg-clip-text text-transparent">{lt('reg.h1b', lang)}</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl animate-fade-in-up delay-200 text-lg leading-relaxed text-slate-400 lg:text-xl">
          {lt('reg.sub', lang)}
        </p>
        <div class="mt-10 flex animate-fade-in-up delay-300 flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="https://app.changebrief.io" class="btn-glow group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-red-600 to-amber-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-red-500/20 transition-all duration-300 hover:shadow-xl hover:shadow-red-500/30">
            {lt('reg.cta1', lang)}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="#how-it-works" class="group inline-flex items-center gap-2 rounded-full glass px-8 py-3.5 text-base font-semibold text-slate-300 transition-all duration-200 hover:text-white hover:bg-white/10">
            {lt('reg.cta2', lang)}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
        </div>

        <!-- Demo card -->
        <div class="mt-16 mx-auto max-w-lg animate-fade-in-up delay-400">
          <div class="glass-card rounded-2xl p-6 text-left space-y-3">
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-red-500/15 px-2.5 py-1 text-xs font-medium text-red-400">
                <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
                {lang === 'sv' ? 'Åtgärd krävs' : 'Action required'}
              </span>
              <span class="rounded bg-white/5 px-1.5 py-0.5 text-[10px] font-mono text-slate-500">SE</span>
              <span class="rounded bg-white/5 px-1.5 py-0.5 text-[10px] font-mono text-slate-500">{lang === 'sv' ? 'Föreskrift' : 'Regulation'}</span>
            </div>
            <p class="text-sm text-slate-300">{lang === 'sv' ? '"Finansinspektionen publicerade FFFS 2026:4 som skärper kraven på AML-rapportering. Ikraftträdande: 1 juli 2026."' : '"Finansinspektionen published FFFS 2026:4 tightening AML reporting requirements. Effective date: July 1, 2026."'}</p>
            <div class="flex items-center gap-2 text-xs text-slate-600">
              <span class="rounded-full bg-red-500/20 px-1.5 py-0.5 text-red-400 font-medium">9/10</span>
              <span>fi.se</span>
              <span class="text-slate-700">•</span>
              <span>{lang === 'sv' ? '14 mar 2026, 08:15' : 'Mar 14, 2026, 08:15'}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem / Before & After -->
    <section id="how-it-works" class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0"><div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div></div>
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('reg.problem.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-400">{lt('reg.problem.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-8 md:grid-cols-2">
          <!-- Before -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-6 flex items-center gap-2 text-sm font-semibold text-red-400">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" /></svg>
              {lt('reg.problem.before', lang)}
            </div>
            <ul class="space-y-4 text-slate-400 text-[15px]">
              {[lt('reg.problem.b1', lang), lt('reg.problem.b2', lang), lt('reg.problem.b3', lang), lt('reg.problem.b4', lang)].map(item => (
                <li class="flex items-start gap-3">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-red-500/60"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <!-- After -->
          <div class="animate-fade-in-up rounded-2xl bg-gradient-to-b from-emerald-500/[0.06] to-transparent p-px">
            <div class="rounded-2xl bg-[#0a0e1a] p-8">
              <div class="mb-6 flex items-center gap-2 text-sm font-semibold text-emerald-400">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 13l4 4L19 7" /></svg>
                {lt('reg.problem.after', lang)}
              </div>
              <ul class="space-y-4 text-slate-300 text-[15px]">
                {[lt('reg.problem.a1', lang), lt('reg.problem.a2', lang), lt('reg.problem.a3', lang), lt('reg.problem.a4', lang)].map(item => (
                  <li class="flex items-start gap-3">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0"><div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div></div>
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('reg.feat.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{lt('reg.feat.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <!-- AI Classification -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-red-500/10 text-red-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('reg.feat.classify.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('reg.feat.classify.p', lang)}</p>
          </div>
          <!-- Jurisdiction -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('reg.feat.juris.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('reg.feat.juris.p', lang)}</p>
          </div>
          <!-- Doc type -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('reg.feat.doctype.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('reg.feat.doctype.p', lang)}</p>
          </div>
          <!-- Audit trail -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('reg.feat.audit.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('reg.feat.audit.p', lang)}</p>
          </div>
          <!-- Pre-configured -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-500/10 text-purple-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('reg.feat.pre.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('reg.feat.pre.p', lang)}</p>
          </div>
          <!-- Sector lists -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 10h16M4 14h16M4 18h16" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('reg.feat.sector.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('reg.feat.sector.p', lang)}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Sectors grid -->
    <section class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0"><div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div></div>
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('reg.sectors.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{lt('reg.sectors.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {([
            { key: 'finance', color: 'emerald', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
            { key: 'health', color: 'red', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
            { key: 'data', color: 'purple', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
            { key: 'transport', color: 'yellow', icon: 'M8 7h8m-8 4h8m-4-8v16m-6 0h12a2 2 0 002-2V5a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { key: 'env', color: 'green', icon: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
            { key: 'labor', color: 'orange', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
          ] as const).map(({ key, color, icon }) => (
            <div class="animate-fade-in-up glass-card rounded-xl p-6 flex items-start gap-4">
              <div class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-${color}-500/10 text-${color}-400`}>
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={icon} /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-white/90">{lt(`reg.sectors.${key}` as any, lang)}</h3>
                <p class="mt-1 text-sm text-slate-500">{lt(`reg.sectors.${key}.p` as any, lang)}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing (reuse from main page) -->
    <section id="pricing" class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-red-600/4 blur-[100px]"></div>
      </div>
      <div class="relative mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('price.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{lt('price.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 lg:grid-cols-3">
          <!-- Free -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 flex flex-col">
            <h3 class="text-lg font-semibold text-slate-300">Free</h3>
            <div class="mt-4 flex items-baseline gap-1"><span class="text-4xl font-bold text-white">$0</span><span class="text-slate-500">{lt('price.mo', lang)}</span></div>
            <p class="mt-4 text-sm text-slate-500">{lt('price.free.desc', lang)}</p>
            <ul class="mt-8 space-y-3 text-sm text-slate-400 flex-1">
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>3 {lt('price.pages', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>100 {lt('price.checks', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{lt('feat.ai', lang)}</li>
            </ul>
            <a href="https://app.changebrief.io" class="mt-8 block rounded-xl glass py-3 text-center text-sm font-semibold text-slate-300 transition-all duration-200 hover:bg-white/10 hover:text-white cursor-pointer">{lt('price.free.cta', lang)}</a>
          </div>
          <!-- Pro -->
          <div class="animate-fade-in-up relative rounded-2xl bg-gradient-to-b from-red-500/[0.08] to-amber-500/[0.04] p-px flex flex-col">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-red-600 to-amber-600 px-4 py-1 text-xs font-semibold text-white shadow-lg shadow-red-500/20">{lt('price.popular', lang)}</div>
            <div class="rounded-2xl bg-[#0a0e1a] p-8 flex flex-col flex-1">
              <h3 class="text-lg font-semibold text-white">Pro</h3>
              <div class="mt-4 flex items-baseline gap-1"><span class="text-4xl font-bold text-white">$19</span><span class="text-slate-500">{lt('price.mo', lang)}</span></div>
              <p class="mt-4 text-sm text-slate-400">{lt('price.pro.desc', lang)}</p>
              <ul class="mt-8 space-y-3 text-sm text-slate-300 flex-1">
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>25 {lt('price.pages', lang)}</li>
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>2,000 {lt('price.checks', lang)}</li>
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>90 {lt('price.days', lang)}</li>
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{lang === 'sv' ? 'Compliance audit trail + CSV-export' : 'Compliance audit trail + CSV export'}</li>
              </ul>
              <a href="https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF" class="btn-glow mt-8 block rounded-xl bg-gradient-to-r from-red-600 to-amber-600 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-red-500/20 transition-all duration-200 hover:shadow-xl hover:shadow-red-500/30 cursor-pointer">{lt('price.pro.cta', lang)}</a>
            </div>
          </div>
          <!-- Team -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 flex flex-col">
            <h3 class="text-lg font-semibold text-slate-300">Team</h3>
            <div class="mt-4 flex items-baseline gap-1"><span class="text-4xl font-bold text-white">$49</span><span class="text-slate-500">{lt('price.mo', lang)}</span></div>
            <p class="mt-4 text-sm text-slate-500">{lt('price.team.desc', lang)}</p>
            <ul class="mt-8 space-y-3 text-sm text-slate-400 flex-1">
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>100 {lt('price.pages', lang)}</li>
