---
---

<section class="relative overflow-hidden pt-36 pb-24 lg:pt-44 lg:pb-36">
  <!-- Background effects -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full bg-blue-600/8 blur-[120px] animate-glow-pulse"></div>
    <div class="absolute top-1/3 left-1/3 h-[300px] w-[300px] rounded-full bg-indigo-500/6 blur-[80px] animate-glow-pulse delay-200"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/20 to-transparent"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 text-center">
    <!-- Badge -->
    <div class="mb-8 inline-flex animate-fade-in-up items-center gap-2.5 rounded-full glass px-4 py-2 text-sm text-blue-300/90">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-60"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-blue-400"></span>
      </span>
      Know what changed in plain English
    </div>

    <!-- Headline -->
    <h1 class="mx-auto max-w-4xl animate-fade-in-up delay-100 text-5xl font-extrabold leading-[1.1] tracking-tight sm:text-6xl lg:text-7xl">
      See what changed
      <span class="block text-gradient">not just that something changed</span>
    </h1>

    <!-- Subheadline -->
    <p class="mx-auto mt-6 max-w-2xl animate-fade-in-up delay-200 text-lg leading-relaxed text-slate-400 lg:text-xl">
      change<span class="text-blue-400">brief</span> monitors web pages and uses AI to tell you exactly what happened. No blurry screenshots. No red pixels. Just a clear sentence.
    </p>

    <!-- CTA buttons -->
    <div class="mt-10 flex animate-fade-in-up delay-300 flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://app.changebrief.io"
        class="btn-glow group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-blue-500/20 transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/30"
      >
        Get started free
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href="#how-it-works"
        class="group inline-flex items-center gap-2 rounded-full glass px-8 py-3.5 text-base font-semibold text-slate-300 transition-all duration-200 hover:text-white hover:bg-white/10"
      >
        See how it works
        <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>

    <!-- Demo mockup -->
    <div class="mx-auto mt-20 max-w-3xl animate-fade-in-up delay-500">
      <div class="rounded-2xl glass-card p-1">
        <div class="rounded-xl bg-[#0a0e1a] p-5">
          <!-- Window chrome -->
          <div class="mb-4 flex items-center gap-2">
            <div class="h-3 w-3 rounded-full bg-red-500/40"></div>
            <div class="h-3 w-3 rounded-full bg-yellow-500/40"></div>
            <div class="h-3 w-3 rounded-full bg-green-500/40"></div>
            <span class="ml-3 rounded-md bg-white/5 px-3 py-0.5 text-xs text-slate-500" style="font-family: 'JetBrains Mono', monospace;">changebrief.io/dashboard</span>
          </div>
          <!-- Content -->
          <div class="rounded-lg bg-[#060810] p-5">
            <div class="flex items-start gap-4">
              <div class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-blue-500/15 text-blue-400">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <span class="text-sm font-semibold text-white" style="font-family: 'JetBrains Mono', monospace;">competitor.com/pricing</span>
                  <span class="rounded-full bg-orange-500/15 px-2.5 py-0.5 text-xs font-medium text-orange-400">8/10</span>
                  <span class="text-xs text-slate-600">3m ago</span>
                </div>
                <p class="mt-2 text-sm leading-relaxed text-slate-300">
                  Acme Corp removed the <span class="rounded bg-red-500/15 px-1.5 py-0.5 text-red-300">Free for 14 days</span> button and raised the Pro price from <span class="rounded bg-red-500/15 px-1.5 py-0.5 text-red-300">$29</span> to <span class="rounded bg-emerald-500/15 px-1.5 py-0.5 text-emerald-300">$39/month</span>.
                </p>
                <div class="mt-3 flex items-center gap-2 text-xs text-slate-600">
                  <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                  via Slack
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
