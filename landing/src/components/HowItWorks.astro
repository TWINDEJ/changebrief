---
---

<section id="how-it-works" class="relative py-24 lg:py-32">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-0 right-0 h-px" style="background: var(--border-primary);"></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center animate-fade-in-up">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">How it works</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">Three steps. No code.</p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      <div class="animate-fade-in-up delay-100 glass-card rounded-2xl p-8">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
        </div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-widest text-blue-400/70">Step 1</div>
        <h3 class="text-xl font-bold">Add a URL</h3>
        <p class="mt-2 text-slate-400 text-[15px] leading-relaxed">Paste the page you want to monitor. Pricing page, terms of service, status page — anything.</p>
      </div>

      <div class="animate-fade-in-up delay-200 glass-card rounded-2xl p-8">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-widest text-blue-400/70">Step 2</div>
        <h3 class="text-xl font-bold">We take screenshots automatically</h3>
        <p class="mt-2 text-slate-400 text-[15px] leading-relaxed">A headless browser runs in the background and captures exactly how the page looks — every hour, day, or week.</p>
      </div>

      <div class="animate-fade-in-up delay-300 glass-card rounded-2xl p-8">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-widest text-blue-400/70">Step 3</div>
        <h3 class="text-xl font-bold">AI tells you what changed</h3>
        <p class="mt-2 text-slate-400 text-[15px] leading-relaxed">AI vision compares before and after, and sends a clear summary to Slack, Teams, or email.</p>
      </div>
    </div>
  </div>
</section>
