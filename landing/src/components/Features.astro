---
---

<section class="relative py-24 lg:py-32">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-0 right-0 h-px" style="background: var(--border-primary);"></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center animate-fade-in-up">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">Features</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">What sets changebrief apart from pixel-diff tools.</p>
    </div>

    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <div class="animate-fade-in-up delay-100 glass-card rounded-2xl p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
        </div>
        <h3 class="font-bold text-white/90">AI-powered summaries</h3>
        <p class="mt-2 text-sm text-slate-400 leading-relaxed">AI vision understands what's shown — prices, buttons, text. Not just pixels.</p>
      </div>

      <div class="animate-fade-in-up delay-200 glass-card rounded-2xl p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-amber-500/10 text-amber-400">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
        </div>
        <h3 class="font-bold text-white/90">Importance score (1-10)</h3>
        <p class="mt-2 text-sm text-slate-400 leading-relaxed">Filter out noise. Only get notified about important changes — pricing, features, terms.</p>
      </div>

      <div class="animate-fade-in-up delay-300 glass-card rounded-2xl p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-purple-500/10 text-purple-400">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
        </div>
        <h3 class="font-bold text-white/90">Slack, Teams & Discord</h3>
        <p class="mt-2 text-sm text-slate-400 leading-relaxed">Notifications straight to the channel your team already uses. Plus PagerDuty, Jira, and webhooks.</p>
      </div>

      <div class="animate-fade-in-up delay-100 glass-card rounded-2xl p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="font-bold text-white/90">Scheduled monitoring</h3>
        <p class="mt-2 text-sm text-slate-400 leading-relaxed">Every hour, day, or week. You decide. We run in the background.</p>
      </div>

      <div class="animate-fade-in-up delay-200 glass-card rounded-2xl p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="font-bold text-white/90">Screenshot history</h3>
        <p class="mt-2 text-sm text-slate-400 leading-relaxed">See exactly how a page looked a day, week, or month ago. Visual timeline.</p>
      </div>

      <div class="animate-fade-in-up delay-300 glass-card rounded-2xl p-6">
        <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl bg-rose-500/10 text-rose-400">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
        </div>
        <h3 class="font-bold text-white/90">REST API & Webhooks</h3>
        <p class="mt-2 text-sm text-slate-400 leading-relaxed">Connect to Zapier, Make, n8n, or build your own integration. JSON payload on every change.</p>
      </div>
    </div>
  </div>
</section>
