---
import { lt, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const sv = lang === 'sv';

const check = `<svg class="h-4 w-4 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
const checkDim = `<svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>`;
---

<section id="pricing" class="relative py-24 lg:py-32">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-indigo-600/5 blur-[100px]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <div class="text-center animate-fade-in-up">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        {sv ? 'Enkel prissättning' : 'Simple pricing'}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        {sv ? 'Börja gratis. Uppgradera när du behöver mer.' : 'Start free. Upgrade when you need more.'}
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-4">
      <!-- Free -->
      <div class="animate-fade-in-up delay-100 glass-card rounded-2xl p-7">
        <h3 class="text-lg font-semibold text-slate-300">Free</h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="text-4xl font-bold text-white">$0</span>
          <span class="text-slate-500">/mo</span>
        </div>
        <p class="mt-4 text-sm text-slate-500">{sv ? 'Testa utan kostnad.' : 'Try it at no cost.'}</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-400">
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? '3 bevakade sidor' : '3 monitored pages'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? '100 kontroller/mån' : '100 checks/mo'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? 'AI-sammanfattningar' : 'AI summaries + scoring'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? 'E-postnotiser' : 'Email notifications'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? 'Veckorapport' : 'Weekly digest'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? '7 dagars historik' : '7 days of history'}</li>
        </ul>
        <a href="https://app.changebrief.io" class="mt-8 block rounded-xl glass py-3 text-center text-sm font-semibold text-slate-300 transition-all duration-200 hover:bg-white/10 hover:text-white cursor-pointer">
          {sv ? 'Kom igång gratis' : 'Get started free'}
        </a>
      </div>

      <!-- Pro -->
      <div class="animate-fade-in-up delay-200 relative rounded-2xl bg-gradient-to-b from-blue-500/[0.08] to-indigo-500/[0.04] p-px">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-4 py-1 text-xs font-semibold text-white shadow-lg shadow-blue-500/20">
          {sv ? 'Populärast' : 'Most popular'}
        </div>
        <div class="rounded-2xl bg-[#0a0e1a] p-7">
          <h3 class="text-lg font-semibold text-white">Pro</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">$19</span>
            <span class="text-slate-500">/mo</span>
          </div>
          <p class="mt-1 text-xs text-slate-500">{sv ? 'eller $190/år (spara 17%)' : 'or $190/year (save 17%)'}</p>
          <p class="mt-4 text-sm text-slate-400">{sv ? 'För yrkesverksamma som behöver djupare bevakning.' : 'For professionals who need deeper monitoring.'}</p>
          <ul class="mt-8 space-y-3 text-sm text-slate-300">
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? '25 bevakade sidor' : '25 monitored pages'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? '2 000 kontroller/mån' : '2,000 checks/mo'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'Slack + e-post + webhook' : 'Slack + email + webhooks'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'PDF-rapport & CSV-export' : 'PDF report & CSV export'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'GRC webhook-integration' : 'GRC webhook integration'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'SLA-uppföljning' : 'SLA deadline tracking'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? '90 dagars historik' : '90 days of history'}</li>
          </ul>
          <a href="https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF" class="btn-glow mt-8 block rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-blue-500/20 transition-all duration-200 hover:shadow-xl hover:shadow-blue-500/30 cursor-pointer">
            {sv ? 'Starta Pro' : 'Start Pro'}
          </a>
        </div>
      </div>

      <!-- Team -->
      <div class="animate-fade-in-up delay-300 glass-card rounded-2xl p-7">
        <h3 class="text-lg font-semibold text-slate-300">Team</h3>
        <div class="mt-4 flex items-baseline gap-1">
          <span class="text-4xl font-bold text-white">$49</span>
          <span class="text-slate-500">/mo</span>
        </div>
        <p class="mt-1 text-xs text-slate-500">{sv ? 'eller $490/år (spara 17%)' : 'or $490/year (save 17%)'}</p>
        <p class="mt-4 text-sm text-slate-500">{sv ? 'För team som behöver samarbete och skala.' : 'For teams that need collaboration and scale.'}</p>
        <ul class="mt-8 space-y-3 text-sm text-slate-400">
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? '100 bevakade sidor' : '100 monitored pages'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? '10 000 kontroller/mån' : '10,000 checks/mo'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? 'Allt i Pro' : 'Everything in Pro'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? 'Tilldela ändringar till team' : 'Assign changes to team members'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? 'Compliance audit trail' : 'Compliance audit trail'}</li>
          <li class="flex items-center gap-3"><Fragment set:html={checkDim} />{sv ? '1 års historik' : '1 year of history'}</li>
        </ul>
        <a href="https://buy.polar.sh/polar_cl_HmjMU2dLQz7qe5fAcTjK2SsssRYDPboqXQJXd4QgARz" class="mt-8 block rounded-xl glass py-3 text-center text-sm font-semibold text-slate-300 transition-all duration-200 hover:bg-white/10 hover:text-white cursor-pointer">
          {sv ? 'Starta Team' : 'Start Team'}
        </a>
      </div>

      <!-- Enterprise -->
      <div class="animate-fade-in-up delay-400 relative rounded-2xl bg-gradient-to-b from-emerald-500/[0.06] to-blue-500/[0.03] p-px">
        <div class="rounded-2xl bg-[#0a0e1a] p-7">
          <h3 class="text-lg font-semibold text-white">Enterprise</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-2xl font-bold text-white">{sv ? 'Anpassat' : 'Custom'}</span>
          </div>
          <p class="mt-4 text-sm text-slate-400">{sv ? 'För organisationer med regulatoriska krav.' : 'For organizations with regulatory requirements.'}</p>
          <ul class="mt-8 space-y-3 text-sm text-slate-300">
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'Obegränsat antal sidor' : 'Unlimited pages'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'SSO / SAML' : 'SSO / SAML'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'Databehandlingsavtal (DPA)' : 'Data Processing Agreement (DPA)'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'SLA med garanterad uptime' : 'SLA with guaranteed uptime'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'Fakturering' : 'Invoice billing'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'Dedikerad kontaktperson' : 'Dedicated account manager'}</li>
            <li class="flex items-center gap-3"><Fragment set:html={check} />{sv ? 'Anpassade integrationer' : 'Custom integrations'}</li>
          </ul>
          <a
            href="mailto:kristian@changebrief.io?subject=Enterprise%20inquiry"
            class="btn-glow mt-8 block rounded-xl bg-gradient-to-r from-emerald-600 to-blue-600 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all duration-200 hover:shadow-xl hover:shadow-emerald-500/30 cursor-pointer"
          >
            {sv ? 'Kontakta oss' : 'Contact us'}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
