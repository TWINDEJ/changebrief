---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import { lt, type Lang } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;

const title = lang === 'sv'
  ? 'changebrief — Se vad som ändrades, inte bara att något ändrades'
  : 'changebrief — See what changed, not just that something changed';
const description = lt('hero.sub', lang);
---

<Base title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <main>
    <!-- Hero -->
    <section class="relative overflow-hidden pt-36 pb-24 lg:pt-44 lg:pb-36">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 h-[500px] w-[700px] rounded-full bg-blue-600/8 blur-[120px] animate-glow-pulse"></div>
        <div class="absolute top-1/3 left-1/3 h-[300px] w-[300px] rounded-full bg-indigo-500/6 blur-[80px] animate-glow-pulse delay-200"></div>
        <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-blue-500/20 to-transparent"></div>
      </div>
      <div class="relative mx-auto max-w-6xl px-6 text-center">
        <div class="mb-8 inline-flex animate-fade-in-up items-center gap-2.5 rounded-full glass px-4 py-2 text-sm text-blue-300/90">
          <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-blue-400"></span></span>
          {lt('hero.badge', lang)}
        </div>
        <h1 class="mx-auto max-w-4xl animate-fade-in-up delay-100 text-5xl font-extrabold leading-[1.1] tracking-tight sm:text-6xl lg:text-7xl">
          {lt('hero.h1a', lang)}
          <span class="block text-gradient">{lt('hero.h1b', lang)}</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl animate-fade-in-up delay-200 text-lg leading-relaxed text-slate-400 lg:text-xl">
          <span class="text-white">change</span><span class="text-blue-400">brief</span> {lang === 'sv' ? 'bevakar webbsidor och berättar med AI exakt vad som hände. Inga suddiga screenshots. Inga röda pixlar. Bara en tydlig mening.' : 'monitors web pages and uses AI to tell you exactly what happened. No blurry screenshots. No red pixels. Just a clear sentence.'}
        </p>
        <div class="mt-10 flex animate-fade-in-up delay-300 flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="https://app.changebrief.io" class="btn-glow group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-blue-500/20 transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/30">
            {lt('hero.cta1', lang)}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
          <a href="#how-it-works" class="group inline-flex items-center gap-2 rounded-full glass px-8 py-3.5 text-base font-semibold text-slate-300 transition-all duration-200 hover:text-white hover:bg-white/10">
            {lt('hero.cta2', lang)}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section id="how-it-works" class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0"><div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div></div>
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('how.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{lt('how.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-3">
          {[['s1', 'link'], ['s2', 'camera'], ['s3', 'bulb']].map(([key]) => (
            <div class="animate-fade-in-up glass-card rounded-2xl p-8">
              <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
              </div>
              <div class="mb-2 text-xs font-semibold uppercase tracking-widest text-blue-400/70">{lt(`how.${key}` as any, lang)}</div>
              <h3 class="text-xl font-bold">{lt(`how.${key}.h` as any, lang)}</h3>
              <p class="mt-2 text-slate-400 text-[15px] leading-relaxed">{lt(`how.${key}.p` as any, lang)}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Use Cases -->
    <section class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0"><div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div></div>
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('use.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{lt('use.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 cursor-default">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-indigo-500/10 text-indigo-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('use.comp.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('use.comp.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 cursor-default">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-red-500/10 text-red-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('use.reg.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('use.reg.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 cursor-default">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/10 text-amber-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('use.vendor.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('use.vendor.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 cursor-default">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-500/10 text-purple-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('use.hiring.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('use.hiring.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 cursor-default">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('use.ecom.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('use.ecom.p', lang)}</p>
          </div>
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 cursor-default">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-cyan-500/10 text-cyan-400">
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            </div>
            <h3 class="text-xl font-bold">{lt('use.site.h', lang)}</h3>
            <p class="mt-3 text-slate-400 text-[15px] leading-relaxed">{lt('use.site.p', lang)}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-indigo-600/5 blur-[100px]"></div>
      </div>
      <div class="relative mx-auto max-w-6xl px-6">
        <div class="text-center animate-fade-in-up">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('price.h2', lang)}</h2>
          <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">{lt('price.sub', lang)}</p>
        </div>
        <div class="mt-16 grid gap-6 lg:grid-cols-3">
          <!-- Free -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 flex flex-col">
            <h3 class="text-lg font-semibold text-slate-300">Free</h3>
            <div class="mt-4 flex items-baseline gap-1"><span class="text-4xl font-bold text-white">$0</span><span class="text-slate-500">{lt('price.mo', lang)}</span></div>
            <p class="mt-4 text-sm text-slate-500">{lt('price.free.desc', lang)}</p>
            <ul class="mt-8 space-y-3 text-sm text-slate-400 flex-1">
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>3 {lt('price.pages', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>100 {lt('price.checks', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{lt('feat.ai', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>7 {lt('price.days', lang)}</li>
            </ul>
            <a href="https://app.changebrief.io" class="mt-8 block rounded-xl glass py-3 text-center text-sm font-semibold text-slate-300 transition-all duration-200 hover:bg-white/10 hover:text-white cursor-pointer">{lt('price.free.cta', lang)}</a>
          </div>
          <!-- Pro -->
          <div class="animate-fade-in-up relative rounded-2xl bg-gradient-to-b from-blue-500/[0.08] to-indigo-500/[0.04] p-px flex flex-col">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-4 py-1 text-xs font-semibold text-white shadow-lg shadow-blue-500/20">{lt('price.popular', lang)}</div>
            <div class="rounded-2xl bg-[#0a0e1a] p-8 flex flex-col flex-1">
              <h3 class="text-lg font-semibold text-white">Pro</h3>
              <div class="mt-4 flex items-baseline gap-1"><span class="text-4xl font-bold text-white">$19</span><span class="text-slate-500">{lt('price.mo', lang)}</span></div>
              <p class="mt-1 text-xs text-slate-500">{lt('price.or', lang)} $190{lt('price.year', lang)} ({lt('price.save', lang)})</p>
              <p class="mt-4 text-sm text-slate-400">{lt('price.pro.desc', lang)}</p>
              <ul class="mt-8 space-y-3 text-sm text-slate-300 flex-1">
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>25 {lt('price.pages', lang)}</li>
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>2,000 {lt('price.checks', lang)}</li>
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>90 {lt('price.days', lang)}</li>
                <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{lt('price.schedule15', lang)}</li>
              </ul>
              <a href="https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF" class="btn-glow mt-8 block rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-blue-500/20 transition-all duration-200 hover:shadow-xl hover:shadow-blue-500/30 cursor-pointer">{lt('price.pro.cta', lang)}</a>
            </div>
          </div>
          <!-- Team -->
          <div class="animate-fade-in-up glass-card rounded-2xl p-8 flex flex-col">
            <h3 class="text-lg font-semibold text-slate-300">Team</h3>
            <div class="mt-4 flex items-baseline gap-1"><span class="text-4xl font-bold text-white">$49</span><span class="text-slate-500">{lt('price.mo', lang)}</span></div>
            <p class="mt-1 text-xs text-slate-500">{lt('price.or', lang)} $490{lt('price.year', lang)} ({lt('price.save', lang)})</p>
            <p class="mt-4 text-sm text-slate-500">{lt('price.team.desc', lang)}</p>
            <ul class="mt-8 space-y-3 text-sm text-slate-400 flex-1">
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>100 {lt('price.pages', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>10,000 {lt('price.checks', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{lt('price.everything', lang)}</li>
              <li class="flex items-center gap-3"><svg class="h-4 w-4 shrink-0 text-blue-400/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>{lt('price.1year', lang)}</li>
            </ul>
            <a href="https://buy.polar.sh/polar_cl_HmjMU2dLQz7qe5fAcTjK2SsssRYDPboqXQJXd4QgARz" class="mt-8 block rounded-xl glass py-3 text-center text-sm font-semibold text-slate-300 transition-all duration-200 hover:bg-white/10 hover:text-white cursor-pointer">{lt('price.team.cta', lang)}</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0"><div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div></div>
      <div class="mx-auto max-w-3xl px-6">
        <h2 class="animate-fade-in-up text-center text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{lt('faq.h2', lang)}</h2>
        <div class="mt-12 space-y-4">
          {['1','2','3','4'].map(n => (
            <details class="group animate-fade-in-up glass-card rounded-2xl p-6 cursor-pointer">
              <summary class="flex items-center justify-between font-semibold text-white/90 [&::-webkit-details-marker]:hidden">
                {lt(`faq.q${n}` as any, lang)}
                <svg class="h-5 w-5 shrink-0 text-slate-500 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="mt-4 text-sm text-slate-400 leading-relaxed">{lt(`faq.a${n}` as any, lang)}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <section class="relative py-24 lg:py-32">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-700/50 to-transparent"></div>
      <div class="absolute bottom-1/4 left-1/2 -translate-x-1/2 h-[300px] w-[500px] rounded-full bg-blue-600/5 blur-[100px]"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-6 text-center">
      <h2 class="animate-fade-in-up text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        {lt('footer.h2a', lang)}<br class="hidden sm:block" /> {lt('footer.h2b', lang)} <span class="text-gradient">{lt('footer.h2c', lang)}</span>
      </h2>
      <p class="mx-auto mt-4 max-w-xl animate-fade-in-up text-lg text-slate-400">{lt('footer.sub', lang)}</p>
      <a href="https://app.changebrief.io" class="btn-glow mt-8 inline-flex animate-fade-in-up items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-blue-500/20 transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/30 cursor-pointer">
        {lt('footer.cta', lang)}
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </section>
  <footer class="border-t border-white/5 py-12">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 sm:flex-row sm:justify-between">
      <div class="flex items-center gap-2.5 text-lg font-bold">
        <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600">
          <svg class="h-3.5 w-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3" /><path d="M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z" /></svg>
        </div>
        <span class="text-white/90">change<span class="text-blue-400">brief</span></span>
      </div>
      <nav class="flex gap-6 text-sm text-slate-600">
        <a href="#" class="transition-colors duration-200 hover:text-white cursor-pointer">{lt('footer.docs', lang)}</a>
        <a href="#" class="transition-colors duration-200 hover:text-white cursor-pointer">{lt('footer.privacy', lang)}</a>
        <a href="#" class="transition-colors duration-200 hover:text-white cursor-pointer">{lt('footer.contact', lang)}</a>
      </nav>
