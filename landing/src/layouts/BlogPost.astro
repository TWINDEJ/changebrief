---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import { lt, type Lang } from '../i18n';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  tags: string[];
  heroImage?: string;
  lang: Lang;
  slug: string;
  otherLangSlug?: string;
}

const { title, description, pubDate, author, tags, heroImage, lang, slug, otherLangSlug } = Astro.props;

const blogBase = lang === 'sv' ? '/sv/blogg' : '/blog';
const canonical = `https://changebrief.io${blogBase}/${slug}`;

const hreflang = otherLangSlug
  ? [
      { lang: 'en', href: `https://changebrief.io/blog/${lang === 'en' ? slug : otherLangSlug}` },
      { lang: 'sv', href: `https://changebrief.io/sv/blogg/${lang === 'sv' ? slug : otherLangSlug}` },
    ]
  : undefined;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  author: { '@type': 'Person', name: author },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  ...(heroImage ? { image: heroImage } : {}),
};

const dateLocale = lang === 'sv' ? 'sv-SE' : 'en-US';
const formattedDate = pubDate.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={title} description={description} lang={lang} canonical={canonical} hreflang={hreflang} structuredData={structuredData}>
  <Header lang={lang} />

  <main class="mx-auto max-w-3xl px-6 pb-24 pt-32">
    <nav class="mb-8 text-sm">
      <a href={blogBase} class="theme-text-secondary hover:theme-text transition-colors">
        ← {lt('blog.backToBlog', lang)}
      </a>
    </nav>

    <article>
      <header class="mb-10">
        <div class="mb-4 flex flex-wrap items-center gap-3 text-sm theme-text-muted">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span>·</span>
          <span>{author}</span>
        </div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">{title}</h1>
        <p class="mt-4 text-lg theme-text-secondary">{description}</p>
        {tags.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="rounded-full theme-bg-muted px-3 py-1 text-xs font-medium theme-text-secondary">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="prose-content">
        <slot />
      </div>
    </article>
  </main>
</Base>

<style is:global>
  .prose-content {
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-content h2 {
    font-size: 1.625rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-content p {
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  .prose-content ul, .prose-content ol {
    margin-top: 1rem;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose-content ul { list-style: disc; }
  .prose-content ol { list-style: decimal; }
  .prose-content li { margin-top: 0.375rem; margin-bottom: 0.375rem; }
  .prose-content blockquote {
    border-left: 4px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--text-secondary);
  }
  .prose-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-content a:hover { opacity: 0.85; }
  .prose-content strong { font-weight: 600; }
  .prose-content code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
    background: var(--bg-muted);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }
</style>
