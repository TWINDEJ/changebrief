---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import { lt } from '../../../i18n';

const lang = 'sv';
const posts = (await getCollection('blog', ({ id, data }) => id.startsWith('sv/') && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base
  title="Blogg — changebrief"
  description="Texter om regelbevakning, compliance-flöden och hur AI förändrar hur team följer regeländringar."
  lang={lang}
  canonical="https://changebrief.io/sv/blogg"
  hreflang={[
    { lang: 'en', href: 'https://changebrief.io/blog' },
    { lang: 'sv', href: 'https://changebrief.io/sv/blogg' },
  ]}
>
  <Header lang={lang} />

  <main class="mx-auto max-w-3xl px-6 pb-24 pt-32">
    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{lt('blog.title', lang)}</h1>
      <p class="mt-3 text-lg theme-text-secondary">{lt('blog.subtitle', lang)}</p>
    </header>

    {posts.length === 0 ? (
      <p class="theme-text-muted">{lt('blog.empty', lang)}</p>
    ) : (
      <ul class="flex flex-col gap-10">
        {posts.map(post => {
          const slug = post.id.replace(/^sv\//, '').replace(/\.md$/, '');
          const date = post.data.pubDate.toLocaleDateString('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' });
          return (
            <li>
              <article>
                <a href={`/sv/blogg/${slug}`} class="group block">
                  <div class="flex items-center gap-3 text-sm theme-text-muted">
                    <time datetime={post.data.pubDate.toISOString()}>{date}</time>
                  </div>
                  <h2 class="mt-2 text-2xl font-semibold tracking-tight transition-colors group-hover:text-[var(--accent)]">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 theme-text-secondary">{post.data.description}</p>
                  <p class="mt-3 text-sm font-medium" style="color: var(--accent);">{lt('blog.readMore', lang)} →</p>
                </a>
              </article>
            </li>
          );
        })}
      </ul>
    )}
  </main>
</Base>
