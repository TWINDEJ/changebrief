le={{ background: 'var(--app-bg-card)', borderColor: 'var(--app-border)', border: '1px solid var(--app-border)' }}>\n227\t                  <SettingsForm\n228\t                    initialNotifyEmail={user.notify_email !== 0}\n229\t                    initialSlackWebhookUrl={(user.slack_webhook_url as string) || ''}\n230\t                    initialDigestFrequency={(user.digest_frequency as string) || 'weekly'}\n231\t                    initialNotifyActionRequired={(user as any).notify_action_required !== 0}\n232\t                    initialNotifyReviewRecommended={(user as any).notify_review_recommended !== 0}\n233\t                    initialNotifyInfoOnly={(user as any).notify_info_only === 1}\n234\t                    initialWebhookUrl={(user as any).webhook_url || ''}\n235\t                    initialSlaActionHours={(user as any).sla_action_hours ?? 48}\n236\t                    initialSlaReviewHours={(user as any).sla_review_hours ?? 168}\n237\t                    initialTeamsWebhookUrl={(user as any).teams_webhook_url || ''}\n238\t                    initialDiscordWebhookUrl={(user as any).discord_webhook_url || ''}\n239\t                    initialPagerdutyRoutingKey={(user as any).pagerduty_routing_key || ''}\n240\t                    plan={user.plan as string}\n241\t                  />\n242\t                </div>\n243\t              </details>\n244\t            </div>\n245\t            <p className=\"text-sm text-slate-500 mb-4\">{t('feed.desc', locale)}</p>\n246\t            <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda aktivitetsflödet' : 'Could not load activity feed'}>\n247\t              <ActivityFeed history={history} plan={user.plan as string} />\n248\t            </SectionErrorBoundary>\n249\t          </section>\n250\t        )}\n251\t\n252\t        {/* 3b. Compliance section (tabbed: Feed + Overview) */}\n253\t        {(complianceHistory.length > 0 || complianceOverview.length > 0) && (\n254\t          <section>\n255\t