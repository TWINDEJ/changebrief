{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SevVQuWtz8F4FNyAJ78LhS","type":"tool_result","content":"1\timport { auth } from '@/lib/auth';\n2\timport { cookies } from 'next/headers';\n3\timport { redirect } from 'next/navigation';\n4\timport { getUserByEmail, getWatchedUrls, getChangeHistory, getComplianceHistory, getComplianceTrend, getComplianceOverview, getUrlLimit, getDashboardStats, getComplianceActionSummary } from '@/lib/db';\n5\timport { t, type Locale } from '@/lib/i18n';\n6\timport { Onboarding } from './onboarding';\n7\timport { AddUrlForm } from './add-url-form';\n8\timport { MonitoredGrid } from './monitored-grid';\n9\timport { ActivityFeed } from './activity-feed';\n10\timport { PopularWatchlists } from './popular-watchlists';\n11\timport { ComplianceFeed } from './compliance-feed';\n12\timport { ComplianceTrend } from './compliance-trend';\n13\timport { ComplianceOverview } from './compliance-overview';\n14\timport { ComplianceTabs } from './compliance-tabs';\n15\timport { SettingsForm } from './settings-form';\n16\timport { SignOutButton } from './sign-out-button';\n17\timport { CheckoutToast } from './checkout-toast';\n18\timport { SectionErrorBoundary } from './error-boundary';\n19\timport { KeyboardShortcutsHelp } from './keyboard-shortcuts';\n20\timport { LanguageSwitcher } from '../locale-provider';\n21\timport { ThemeToggle } from './theme-toggle';\n22\timport { AnimatedNumber } from './animated-number';\n23\timport { DashboardShell } from './dashboard-shell';\n24\timport { FaviconBadge } from './favicon-badge';\n25\timport { ShortcutHint } from './shortcut-hint';\n26\timport ComplianceOnboarding from './compliance-onboarding';\n27\t\n28\tfunction formatLastCheck(dateStr: string | null, locale: Locale): string {\n29\t  if (!dateStr) return t('stats.never', locale);\n30\t  const diff = Math.floor((Date.now() - new Date(dateStr + 'Z').getTime()) / 1000);\n31\t  if (diff < 60) return locale === 'sv' ? 'nyss' : 'just now';\n32\t  if (diff < 3600) return `${Math.floor(diff / 60)}${locale === 'sv' ? ' min sedan' : 'm ago'}`;\n33\t  if (diff < 86400) return `${Math.floor(diff / 3600)}${locale === 'sv' ? 'h sedan' : 'h ago'}`;\n34\t  return `${Math.floor(diff / 86400)}${locale === 'sv' ? 'd sedan' : 'd ago'}`;\n35\t}\n36\t\n37\texport default async function DashboardPage({\n38\t  searchParams,\n39\t}: {\n40\t  searchParams: Promise<{ [key: string]: string | string[] | undefined }>;\n41\t}) {\n42\t  const params = await searchParams;\n43\t  const session = await auth();\n44\t  if (!session?.user?.email) {\n45\t    const ref = typeof params.ref === 'string' ? params.ref : '';\n46\t    redirect(ref ? `/login?ref=${ref}` : '/login');\n47\t  }\n48\t\n49\t  const user = await getUserByEmail(session.user.email);\n50\t  if (!user) redirect('/login');\n51\t\n52\t  const cookieStore = await cookies();\n53\t  const locale = (cookieStore.get('locale')?.value as Locale) || 'en';\n54\t\n55\t  const checkoutSuccess = params.checkout === 'success';\n56\t  const isComplianceRef = params.ref === 'compliance';\n57\t\n58\t  const [urls, history, complianceHistory, trendData, complianceOverview, stats, complianceSummary] = await Promise.all([\n59\t    getWatchedUrls(user.id as string) as Promise<any[]>,\n60\t    getChangeHistory(user.id as string, 50) as Promise<any[]>,\n61\t    getComplianceHistory(user.id as string) as Promise<any[]>,\n62\t    getComplianceTrend(user.id as string) as Promise<any[]>,\n63\t    getComplianceOverview(user.id as string) as Promise<any[]>,\n64\t    getDashboardStats(user.id as string),\n65\t    getComplianceActionSummary(user.id as string),\n66\t  ]);\n67\t  const urlLimit = getUrlLimit(user.plan as string);\n68\t  const planLabel = t(`header.plan.${user.plan as 'free' | 'pro' | 'team'}` as any, locale);\n69\t  const isNewUser = urls.length === 0 && history.length === 0;\n70\t\n71\t  return (\n72\t    <div className=\"min-h-screen\" style={{ background: 'var(--app-bg)', color: 'var(--app-text)' }}>\n73\t\n74\t      {/* Checkout success toast */}\n75\t      <CheckoutToast show={checkoutSuccess} />\n76\t      <FaviconBadge count={complianceSummary.actionRequired + complianceSummary.reviewRecommended} />\n77\t\n78\t      <DashboardShell header={\n79\t        <div className=\"mx-auto flex max-w-5xl items-center justify-between\">\n80\t          <div className=\"flex items-center gap-2.5\">\n81\t            <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600\">\n82\t              <svg className=\"h-4 w-4 text-white\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\">\n83\t                <circle cx=\"12\" cy=\"12\" r=\"3\" />\n84\t                <path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\" />\n85\t              </svg>\n86\t            </div>\n87\t            <h1 className=\"text-lg font-bold tracking-tight hidden sm:block\">\n88\t              change<span className=\"text-blue-600\">brief</span>\n89\t            </h1>\n90\t          </div>\n91\t          <div className=\"flex items-center gap-2 sm:gap-3\">\n92\t            <ThemeToggle />\n93\t            <LanguageSwitcher />\n94\t            <span className=\"rounded-full bg-blue-50 border border-blue-100 px-2.5 sm:px-3 py-1 text-xs font-medium text-blue-700\">\n95\t              {planLabel}\n96\t            </span>\n97\t            {user.plan !== 'team' && (\n98\t              <a\n99\t                href={user.plan === 'pro'\n100\t                  ? 'https://buy.polar.sh/polar_cl_HmjMU2dLQz7qe5fAcTjK2SsssRYDPboqXQJXd4QgARz'\n101\t                  : 'https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF'}\n102\t                target=\"_blank\"\n103\t                rel=\"noopener noreferrer\"\n104\t                className=\"rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 px-2.5 sm:px-3 py-1 text-xs font-medium text-white hover:from-blue-400 hover:to-indigo-400 transition-all\"\n105\t              >\n106\t                {t('header.upgrade', locale)}\n107\t              </a>\n108\t            )}\n109\t            <a\n110\t              href={`mailto:kristian@changebrief.io?subject=${encodeURIComponent(locale === 'sv' ? 'Feedback på changebrief' : 'Feedback on changebrief')}&body=${encodeURIComponent(locale === 'sv'\n111\t                ? '1. Vilka sidor/myndigheter bevakar du?\\n\\n2. Fick du någon ändring klassificerad? Stämde den?\\n\\n3. Vad saknar du?\\n\\n4. Skulle du betala för detta? Hur mycket?\\n\\n5. Vem mer borde testa detta?\\n'\n112\t                : '1. Which pages/agencies are you monitoring?\\n\\n2. Did you get any change classified? Was it accurate?\\n\\n3. What is missing?\\n\\n4. Would you pay for this? How much?\\n\\n5. Who else should try this?\\n')}`}\n113\t              className=\"group flex items-center gap-1.5 rounded-full bg-amber-50 border border-amber-200 px-3 py-1 text-xs font-medium text-amber-700 hover:bg-amber-100 hover:text-amber-800 transition-all animate-pulse hover:animate-none\"\n114\t            >\n115\t              <svg className=\"h-3.5 w-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\" /></svg>\n116\t              {locale === 'sv' ? 'Ge feedback' : 'Give feedback'}\n117\t            </a>\n118\t            <span className=\"text-sm text-slate-400 hidden md:inline\">{session.user.email}</span>\n119\t            <SignOutButton />\n120\t          </div>\n121\t        </div>\n122\t      }>\n123\t\n124\t      <main className=\"relative mx-auto max-w-5xl px-4 sm:px-6 py-6 sm:py-8 space-y-6 sm:space-y-8\">\n125\t        {/* 1. Onboarding for new users */}\n126\t        {isNewUser && isComplianceRef ? (\n127\t          <section>\n128\t            <ComplianceOnboarding canAdd={urls.length < urlLimit} />\n129\t          </section>\n130\t        ) : isNewUser ? (\n131\t          <section>\n132\t            <Onboarding />\n133\t          </section>\n134\t        ) : null}\n135\t\n136\t        {/* 2. Stats bar — compliance summary or generic */}\n137\t        {urls.length > 0 && (\n138\t          <section className=\"space-y-3\">\n139\t            {/* Compliance action summary (shown when compliance data exists) */}\n140\t            {complianceHistory.length > 0 && (complianceSummary.actionRequired > 0 || complianceSummary.reviewRecommended > 0 || complianceSummary.reviewedThisWeek > 0) && (\n141\t              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3 stagger-children\">\n142\t                <div className=\"rounded-xl bg-red-50 border border-red-100 px-4 py-3\">\n143\t                  <p className=\"text-xs text-red-600/70 font-medium\">{locale === 'sv' ? 'Åtgärd krävs' : 'Action required'}</p>\n144\t                  <p className=\"mt-1 text-2xl font-bold text-red-700\"><AnimatedNumber value={complianceSummary.actionRequired} /></p>\n145\t                </div>\n146\t                <div className=\"rounded-xl bg-amber-50 border border-amber-100 px-4 py-3\">\n147\t                  <p className=\"text-xs text-amber-600/70 font-medium\">{locale === 'sv' ? 'Granska' : 'Review'}</p>\n148\t                  <p className=\"mt-1 text-2xl font-bold text-amber-700\"><AnimatedNumber value={complianceSummary.reviewRecommended} /></p>\n149\t                </div>\n150\t                <div className=\"rounded-xl bg-emerald-50 border border-emerald-100 px-4 py-3\">\n151\t                  <p className=\"text-xs text-emerald-600/70 font-medium\">{locale === 'sv' ? 'Granskade (7d)' : 'Reviewed (7d)'}</p>\n152\t                  <p className=\"mt-1 text-2xl font-bold text-emerald-700\"><AnimatedNumber value={complianceSummary.reviewedThisWeek} /></p>\n153\t                </div>\n154\t                <div className=\"rounded-xl glass-card px-4 py-3\">\n155\t                  <p className=\"text-xs text-slate-500 font-medium\">{t('stats.lastcheck', locale)}</p>\n156\t                  <p className=\"mt-1 text-lg font-semibold text-slate-900\">{formatLastCheck(stats.lastCheck, locale)}</p>\n157\t                </div>\n158\t              </div>\n159\t            )}\n160\t            {/* Generic stats */}\n161\t            <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3 stagger-children\">\n162\t              <div className=\"rounded-xl glass-card px-4 py-3 animate-fade-in\">\n163\t                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.pages', locale)}</p>\n164\t                <p className=\"mt-1 text-2xl font-bold text-slate-900\"><AnimatedNumber value={urls.length} /><span className=\"text-sm font-normal text-slate-500\">/{urlLimit}</span></p>\n165\t              </div>\n166\t              <div className=\"rounded-xl glass-card px-4 py-3\">\n167\t                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.changes', locale)}</p>\n168\t                <p className=\"mt-1 text-2xl font-bold text-slate-900\">\n169\t                  {stats.significantChanges7d > 0 ? (\n170\t                    <span className=\"text-orange-600\">{stats.significantChanges7d}</span>\n171\t                  ) : (\n172\t                    <span className=\"text-emerald-600\">0</span>\n173\t                  )}\n174\t                </p>\n175\t              </div>\n176\t              <div className=\"rounded-xl glass-card px-4 py-3\">\n177\t                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.checks', locale)}</p>\n178\t                <p className=\"mt-1 text-2xl font-bold text-slate-900\"><AnimatedNumber value={stats.totalChecks7d} /></p>\n179\t              </div>\n180\t              {!(complianceHistory.length > 0 && (complianceSummary.actionRequired > 0 || complianceSummary.reviewRecommended > 0 || c