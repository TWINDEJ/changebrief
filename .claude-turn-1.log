wn regulatory sources.\n93\t      </div>\n94\t\n95\t      {/* Header */}\n96\t      <header className=\"border-b border-slate-200 bg-white/80 backdrop-blur-xl sticky top-0 z-30\">\n97\t        <div className=\"mx-auto flex max-w-5xl items-center justify-between px-4 sm:px-6 py-3\">\n98\t          <div className=\"flex items-center gap-2.5\">\n99\t            <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600\">\n100\t              <svg className=\"h-4 w-4 text-white\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\">\n101\t                <circle cx=\"12\" cy=\"12\" r=\"3\" />\n102\t                <path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\" />\n103\t              </svg>\n104\t            </div>\n105\t            <h1 className=\"text-lg font-bold tracking-tight\">\n106\t              change<span className=\"text-blue-600\">brief</span>\n107\t            </h1>\n108\t            <span className=\"rounded-full bg-amber-50 border border-amber-200 px-2.5 py-0.5 text-xs font-medium text-amber-700 ml-2\">\n109\t              Demo\n110\t            </span>\n111\t          </div>\n112\t          <Link\n113\t            href=\"/login\"\n114\t            className=\"rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 px-4 py-1.5 text-sm font-medium text-white hover:from-blue-400 hover:to-indigo-400 transition-all\"\n115\t          >\n116\t            Get started free\n117\t          </Link>\n118\t        </div>\n119\t      </header>\n120\t\n121\t      <main className=\"mx-auto max-w-5xl px-4 sm:px-6 py-6 sm:py-8 space-y-6\">\n122\t        {/* Stats */}\n123\t        <section className=\"space-y-3\">\n124\t          <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n125\t            <div className=\"rounded-xl bg-red-50 border border-red-100 px-4 py-3\">\n126\t              <p className=\"text-xs text-red-600/70 font-medium\">Action required</p>\n127\t              <p className=\"mt-1 text-2xl font-bold text-red-700\">{actionRequired}</p>\n128\t            </div>\n129\t            <div className=\"rounded-xl bg-amber-50 border border-amber-100 px-4 py-3\">\n130\t              <p className=\"text-xs text-amber-600/70 font-medium\">Review</p>\n131\t              <p className=\"mt-1 text-2xl font-bold text-amber-700\">{reviewRecommended}</p>\n132\t            </div>\n133\t            <div className=\"rounded-xl bg-emerald-50 border border-emerald-100 px-4 py-3\">\n134\t              <p className=\"text-xs text-emerald-600/70 font-medium\">Reviewed (7d)</p>\n135\t              <p className=\"mt-1 text-2xl font-bold text-emerald-700\">{reviewed}</p>\n136\t            </div>\n137\t            <div className=\"rounded-xl bg-white border border-slate-200 px-4 py-3\">\n138\t              <p className=\"text-xs text-slate-500 font-medium\">Last check</p>\n139\t              <p className=\"mt-1 text-lg font-semibold text-slate-900\">2h ago</p>\n140\t            </div>\n141\t          </div>\n142\t          <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n143\t            <div className=\"rounded-xl bg-white border border-slate-200 px-4 py-3\">\n144\t              <p className=\"text-xs text-slate-500 font-medium\">Pages monitored</p>\n145\t              <p className=\"mt-1 text-2xl font-bold text-slate-900\">{mockSources.length}<span className=\"text-sm font-normal text-slate-500\">/25</span></p>\n146\t            </div>\n147\t            <div className=\"rounded-xl bg-white border border-slate-200 px-4 py-3\">\n148\t              <p className=\"text-xs text-slate-500 font-medium\">Changes (7d)</p>\n149\t              <p className=\"mt-1 text-2xl font-bold text-orange-600\">{mockChanges.length}</p>\n150\t            </div>\n151\t            <div className=\"rounded-xl bg-white border border-slate-200 px-4 py-3\">\n152\t              <p className=\"text-xs text-slate-500 font-medium\">Total checks (7d)</p>\n153\t              <p className=\"mt-1 text-2xl font-bold text-slate-900\">48</p>\n154\t            </div>\n155\t          </div>\n156\t        </section>\n157\t\n158\t        {/* Activity feed */}\n159\t        <section>\n160\t          <h2 className=\"text-lg font-semibold text-slate-900/90 mb-1\">Recent changes</h2>\n161\t          <p className=\"text-sm text-slate-500 mb-4\">AI-powered summaries of regulatory changes, ranked by importance.</p>\n162\t          <div className=\"space-y-3\">\n163\t            {mockChanges\n164\t              .sort((a, b) => b.importance - a.importance)\n165\t              .map((change) => (\n166\t              <div key={change.id} className=\"rounded-xl bg-white border border-slate-200 p-4 hover:shadow-md transition-shadow\">\n167\t                <div className=\"flex items-start justify-between gap-3\">\n168\t                  <div className=\"flex-1 min-w-0\">\n169\t                    <div className=\"flex items-center gap-2 mb-1 flex-wrap\">\n170\t                      <span className={`inline-flex items-center justify-center h-6 w-6 rounded-full text-xs font-bold text-white ${\n171\t                        change.importance >= 7 ? 'bg-red-500' : change.importance >= 4 ? 'bg-amber-500' : 'bg-slate-400'\n172\t                      }`}>\n173\t                        {change.importance}\n174\t                      </span>\n175\t                      <span className=\"text-sm font-semibold text-slate-900 truncate\">{change.name}</span>\n176\t                      <ActionBadge action={change.compliance_action} />\n177\t                      {change.jurisdiction && (\n178\t                        <span className=\"text-xs text-slate-400 font-mono\">[{change.jurisdiction}]</span>\n179\t                      )}\n180\t                    </div>\n181\t                    <p className=\"text-sm text-slate-700 leading-relaxed\">{change.summary}</p>\n182\t                    <div className=\"flex items-center gap-3 mt-2 text-xs text-slate-400\">\n183\t