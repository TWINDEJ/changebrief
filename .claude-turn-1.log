{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0171RkVryrqeonRttPcBWdtP","type":"tool_result","content":"1\timport { auth } from '@/lib/auth';\n2\timport { redirect } from 'next/navigation';\n3\t\n4\texport default async function Home() {\n5\t  const session = await auth();\n6\t  if (session?.user) {\n7\t    redirect('/dashboard');\n8\t  }\n9\t  redirect('/login');\n10\t}\n11\t"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"63ded2e7-c92d-41b4-b294-0169290eb12b","timestamp":"2026-04-18T21:23:13.858Z"}
