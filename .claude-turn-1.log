tion PopularWatchlists({ existingUrls, canAdd }: { existingUrls: string[]; canAdd: boolean }) {\n59\t  const { locale, t } = useLocale();\n60\t  const [adding, setAdding] = useState<string | null>(null);\n61\t  const [added, setAdded] = useState<Set<string>>(new Set());\n62\t  const [justAdded, setJustAdded] = useState<string | null>(null);\n63\t  const [activeCategory, setActiveCategory] = useState<string | null>(null);\n64\t  const [activeJurisdiction, setActiveJurisdiction] = useState<string | null>(null);\n65\t  const [expanded, setExpanded] = useState(false);\n66\t  const router = useRouter();\n67\t  const { toast, show, clear } = useToast();\n68\t\n69\t  const handleAdd = useCallback(async (s: Suggestion) => {\n70\t    if (!canAdd) { show(t('watchlists.upgradeError'), 'error'); return; }\n71\t    setAdding(s.url);\n72\t    try {\n73\t      const res = await fetch('/api/urls', {\n74\t        method: 'POST',\n75\t        headers: { 'Content-Type': 'application/json' },\n76\t        body: JSON.stringify({ url: s.url, name: locale === 'sv' ? s.name_sv : s.name, category: s.category }),\n77\t      });\n78\t      if (res.ok) {\n79\t        setJustAdded(s.url);\n80\t        setTimeout(() => { setAdded(prev => new Set(prev).add(s.url)); setJustAdded(null); }, 600);"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"210f5129-ed09-423e-890f-711a7b8bb47a","timestamp":"2026-04-18T21:23:32.494Z"}
