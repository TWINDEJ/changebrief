{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SkEqH9HK8Q5oyExV6Mt2Td","type":"tool_result","content":"1\t'use client';\n2\t\n3\timport { useState, useCallback } from 'react';\n4\timport { useRouter } from 'next/navigation';\n5\timport { Toast, useToast } from './toast';\n6\timport { useLocale } from '../locale-provider';\n7\timport suggestionsData from '@/data/suggestions.json';\n8\t\n9\tinterface Suggestion {\n10\t  url: string; name: string; name_sv: string;\n11\t  category: string; description: string; description_sv: string;\n12\t  jurisdiction?: string;\n13\t}\n14\t\n15\tconst suggestions = suggestionsData as Suggestion[];\n16\tconst categories = [\n17\t  'Finance & Banking', 'Transport & Infrastructure', 'Health & Pharma',\n18\t  'Data & Privacy', 'Environment & Energy', 'Labor & Workplace',\n19\t  'Laws & Government', 'Legal', 'Pricing', 'Newsrooms', 'Standards', 'Status',\n20\t];\n21\t\n22\tconst categoryColors: Record<string, string> = {\n23\t  'Finance & Banking': 'text-emerald-600 bg-emerald-50',\n24\t  'Transport & Infrastructure': 'text-yellow-600 bg-yellow-50',\n25\t  'Health & Pharma': 'text-red-600 bg-red-50',\n26\t  'Data & Privacy': 'text-purple-600 bg-purple-50',\n27\t  'Environment & Energy': 'text-green-600 bg-green-50',\n28\t  'Labor & Workplace': 'text-orange-600 bg-orange-50',\n29\t  'Laws & Government': 'text-blue-600 bg-blue-50',\n30\t  Legal: 'text-amber-600 bg-amber-50',\n31\t  Pricing: 'text-teal-600 bg-teal-50',\n32\t  Newsrooms: 'text-pink-600 bg-pink-50',\n33\t  Standards: 'text-cyan-600 bg-cyan-50',\n34\t  Status: 'text-slate-600 bg-slate-100',\n35\t};\n36\t\n37\t// Vågskålar = reglering, mynt = finans, hjärta = hälsa, sköld = data, blad = miljö, bygge = arbete, riksdag = lagar\n38\tconst categoryIcons: Record<string, React.ReactNode> = {\n39\t  'Finance & Banking': <svg className=\"h-4 w-4\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\"