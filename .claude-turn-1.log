{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018dNj7bHPqRxdrpksmXUeog","type":"tool_result","content":"1\t---\n2\timport Base from '../layouts/Base.astro';\n3\timport Header from './Header.astro';\n4\timport { lt, type Lang } from '../i18n';\n5\t\n6\tinterface Props { lang: Lang }\n7\tconst { lang } = Astro.props;\n8\t\n9\tconst title = lang === 'sv'\n10\t  ? 'changebrief — Se vad som ändrades, inte bara att något ändrades'\n11\t  : 'changebrief — See what changed, not just that something changed';\n12\tconst description = lt('hero.sub', lang);\n13\t\n14\tconst canonical = lang === 'sv'\n15\t  ? 'https://changebrief.io/sv'\n16\t  : 'https://changebrief.io';\n17\t\n18\tconst hreflang = [\n19\t  { lang: 'en', href: 'https://changebrief.io' },\n20\t  { lang: 'sv', href: 'https://changebrief.io/sv' },\n21\t  { lang: 'x-default', href: 'https://changebrief.io' },\n22\t];\n23\t\n24\tconst structuredData = {\n25\t  '@context': 'https://schema.org',\n26\t  '@type': 'WebApplication',\n27\t  name: 'changebrief',\n28\t  url: 'https://changebrief.io',\n29\t  applicationCategory: 'BusinessApplication',\n30\t  operatingSystem: 'Web',\n31\t  description: lang === 'sv'\n32\t    ? 'changebrief bevakar webbsidor och berättar med AI vad som ändrades — inte bara att något ändrades.'\n33\t    : 'changebrief monitors web pages and uses AI to tell you exactly what changed — not just that something changed.',\n34\t  offers: {\n35\t    '@type': 'Offer',\n36\t    price: '0',\n37\t    priceCurrency: 'USD',\n38\t  },\n39\t};\n40\t---\n41\t\n42\t<Base title={title} description={description} lang={lang} canonical={canonical} hreflang={hreflang} structuredData={structuredData}>\n43\t  <Header lang={lang} />\n44\t  <main>\n45\t    <!-- Hero -->\n46\t    <section class=\"relative overflow-hidden pt-36 pb-24 lg:pt-44 lg:pb-36 theme-bg\">\n47\t      <div class=\"relative mx-auto max-w-6xl px-6 text-center\">\n48\t        <div class=\"mb-8 inline-flex animate-fade-in-up items-center gap-2.5 rounded-full bg-blue-50 border border-blue-100 px-4 py-2 text-sm text-blue-700\">\n49\t          <span class=\"relative flex h-2 w-2\"><span class=\"absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-500 opacity-60\"></span><span class=\"relative inline-flex h-2 w-2 rounded-full bg-blue-500\"></span></span>\n50\t          {lt('hero.badge', lang)}\n51\t        </div>\n52\t        <h1 class=\"mx-auto max-w-4xl animate-fade-in-up delay-100 text-5xl font-extrabold leading-[1.1] tracking-tight theme-text sm:text-6xl lg:text-7xl\">\n53\t          {lt('hero.h1a', lang)}\n54\t          <span class=\"block text-gradient\">{lt('hero.h1b', lang)}</span>\n55\t        </h1>\n56\t        <p class=\"mx-auto mt-6 max-w-2xl animate-fade-in-up delay-200 text-lg leading-relaxed theme-text-secondary lg:text-xl\">\n57\t          <span class=\"theme-text font-semibold\">change</span><span class=\"text-blue-600 font-semibold\">brief</span> {lang === 'sv' ? 'bevakar webbsidor och berättar med AI exakt vad som hände. Inga suddiga screenshots. Inga röda pixlar. Bara en tydlig mening.' : 'monitors web pages and uses AI to tell you exactly what happened. No blurry screenshots. No red pixels. Just a clear sentence.'}\n58\t        </p>\n59\t        <div class=\"mt-10 flex animate-fade-in-up delay-300 flex-col items-center justify-center gap-4 sm:flex-row\">\n60\t          <a href=\"https://app.changebrief.io\" class=\"btn-glow group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-8 py-3.5 text-base font-semibold text-white transition-all duration-300\">\n61\t            {lt('hero.cta1', lang)}\n62\t            <svg class=\"h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\" /></svg>\n63\t          </a>\n64\t          <a href=\"#how-it-works\" class=\"group inline-flex items-center gap-2 rounded-full border theme-border theme-bg px-8 py-3.5 text-base font-semibold theme-text-secondary transition-all duration-200 hover:border-slate-300 hover:text-[var(--text-primary)] hover:shadow-sm\">\n65\t            {lt('hero.cta2', lang)}\n66\t            <svg class=\"h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" /></svg>\n67\t          </a>\n68\t        </div>\n69\t      </div>\n70\t    </section>\n71\t\n72\t    <!-- How it works -->\n73\t    <section id=\"how-it-works\" class=\"relative py-24 lg:py-32 border-t theme-border\">\n74\t      <div class=\"mx-auto max-w-6xl px-6\">\n75\t        <div class=\"text-center animate-fade-in-up\">\n76\t          <h2 class=\"text-3xl font-bold tracking-tight theme-text sm:text-4xl lg:text-5xl\">{lt('how.h2', lang)}</h2>\n77\t          <p class=\"mx-auto mt-4 max-w-2xl text-lg theme-text-secondary\">{lt('how.sub', lang)}</p>\n78\t        </div>\n79\t        <div class=\"mt-16 grid gap-6 md:grid-cols-3\">\n80\t          {[['s1', 'link'], ['s2', 'camera'], ['s3', 'bulb']].map(([key]) => (\n81\t            <div class=\"animate-fade-in-up glass-card rounded-2xl p-8\">\n82\t              <div class=\"mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-blue-50 text-blue-600\">\n83\t                <svg class=\"h-6 w-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z\" /></svg>\n84\t              </div>\n85\t              <div class=\"mb-2 text-xs font-semibold uppercase tracking-widest text