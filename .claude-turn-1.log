\"theme-toggle\"\n          class=\"cursor-pointer rounded-lg p-1.5 theme-text-muted hover:theme-text transition-all duration-200\"\n          title=\"Toggle dark/light mode\"\n          aria-label=\"Toggle dark/light mode\"\n        >\n          <!-- Sun icon (shown in dark mode) -->\n          <svg class=\"h-4 w-4 hidden\" id=\"theme-sun\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z\" />\n          </svg>\n          <!-- Moon icon (shown in light mode) -->\n          <svg class=\"h-4 w-4\" id=\"theme-moon\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z\" />\n          </svg>\n        </button>\n        <a\n          href={otherUrl}\n          class=\"cursor-pointer rounded-lg theme-bg-muted px-2 py-1 text-xs font-medium theme-text-muted hover:theme-text transition-all duration-200\"\n          aria-label={lang === 'en' ? 'Byt till svenska' : 'Switch to English'}\n        >\n          {otherLang.toUpperCase()}\n        </a>","originalFile":"---\nimport { lt, type Lang } from '../i18n';\ninterface Props { lang?: Lang }\nconst { lang = 'en' } = Astro.props;\nconst otherLang = lang === 'en' ? 'sv' : 'en';\nconst otherUrl = lang === 'en' ? '/sv' : '/';\n---\n\n<header class=\"fixed top-4 left-4 right-4 z-50\">\n  <div class=\"mx-auto max-w-6xl rounded-2xl glass-strong px-6 py-3\">\n    <div class=\"flex items-center justify-between\">\n      <a href=\"/\" class=\"flex items-center gap-2.5 text-lg font-bold tracking-tight\">\n        <div class=\"flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600\">\n          <svg class=\"h-4 w-4 text-white\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\">\n            <circle cx=\"12\" cy=\"12\" r=\"3\" />\n            <path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\" />\n          </svg>\n        </div>\n        <span class=\"theme-text\">change<span class=\"text-blue-600\">brief</span></span>\n      </a>\n      <div class=\"flex items-center gap-3\">\n        <a href={lang === 'sv' ? '/sv/compliance' : '/compliance'} class=\"hidden sm:inline-flex cursor-pointer text-sm font-medium theme-text-secondary hover:theme-text transition-all duration-200\">\n          Compliance\n        </a>\n        <a href={lang === 'sv' ? '/sv/security' : '/security'} class=\"hidden sm:inline-flex cursor-pointer text-sm font-medium theme-text-secondary hover:theme-text transition-all duration-200\">\n          {lang === 'sv' ? 'Säkerhet' : 'Security'}\n        </a>\n        <!-- Theme toggle -->\n        <button\n          id=\"theme-toggle\"\n          class=\"cursor-pointer rounded-lg p-1.5 theme-text-muted hover:theme-text transition-all duration-200\"\n          title=\"Toggle dark/light mode\"\n        >\n          <!-- Sun icon (shown in dark mode) -->\n          <svg class=\"h-4 w-4 hidden\" id=\"theme-sun\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z\" />\n          </svg>\n          <!-- Moon icon (shown in light mode) -->\n          <svg class=\"h-4 w-4\" id=\"theme-moon\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z\" />\n          </svg>\n        </button>\n        <a href={otherUrl} class=\"cursor-pointer rounded-lg theme-bg-muted px-2 py-1 text-xs font-medium theme-text-muted hover:theme-text transition-all duration-200\">\n          {otherLang.toUpperCase()}\n        </a>\n        <a\n          href=\"#pricing\"\n          class=\"btn-glow rounded-full bg-gradient-to-r from-blue-600 to-indigo-600 px-5 py-2 text-sm font-semibold text-white transition-all duration-200\"\n        >\n          {lt('header.cta', lang)}\n        </a>\n      </div>\n    </div>\n  </div>\n</header>\n\n<script is:inline>\n  (function() {\n    var toggle = document.getElementById('theme-toggle');\n    var sun = document.getElementById('theme-sun');\n    var moon = document.getElementById('theme-moon');\n\n    function updateIcons() {\n      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';\n      if (sun && moon) {\n        sun.style.display = isDark ? 'block' : 'none';\n        moon.style.display = isDark ? 'none' : 'block';\n      }\n    }\n\n    updateIcons();\n\n    if (toggle) {\n      toggle.addEventListener('click', function() {\n        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';\n        if (isDark) {\n          document.documentElement.removeAttribute('data-theme');\n          localStorage.setItem('cb-theme', 'light');\n        } else {\n          document.documentElement.setAttribute('data-theme', 'dark');\n          localStorage.setItem('cb-theme', 'dark');\n        }\n        updateIcons();\n      });\n    }\n  })();\n</script>\n","structuredPatch":[{"oldStart":30,"oldLines":17,"newStart":30,"newLines":22,"lines":["           id=\"theme-toggle\"","           class=\"cursor-pointer rounded-lg p-1.5 theme-text-muted hover:theme-text transition-all duration-200\"","           title=\"Toggle dark/light mode\"","+          aria-label=\"Toggle dark/light mode\"","         >","           <!-- Sun icon (s