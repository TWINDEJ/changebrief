{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017zmKiHz6mQ1oQPYBwxQWG9","type":"tool_result","content":"1\t'use client';\n2\t\n3\timport { useState, useMemo } from 'react';\n4\timport { useLocale } from '../locale-provider';\n5\t\n6\tinterface ComplianceEntry {\n7\t  id: number;\n8\t  url: string;\n9\t  name: string;\n10\t  summary: string | null;\n11\t  importance: number | null;\n12\t  changed_elements: string | null;\n13\t  checked_at: string;\n14\t  jurisdiction: string | null;\n15\t  document_type: string | null;\n16\t  compliance_action: string | null;\n17\t  reviewed_at: string | null;\n18\t  assigned_to: string | null;\n19\t  assigned_at: string | null;\n20\t}\n21\t\n22\ttype ActionFilter = 'all' | 'action_required' | 'review_recommended' | 'info_only';\n23\t\n24\tconst actionColors: Record<string, { badge: string; dot: string }> = {\n25\t  action_required: { badge: 'text-red-700 bg-red-50', dot: 'bg-red-500' },\n26\t  review_recommended: { badge: 'text-amber-700 bg-amber-50', dot: 'bg-amber-500' },\n27\t  info_only: { badge: 'text-slate-600 bg-slate-100', dot: 'bg-slate-500' },\n28\t};\n29\t\n30\tconst actionLabels: Record<string, { en: string; sv: string }> = {\n31\t  action_required: { en: 'Action required', sv: 'Åtgärd krävs' },\n32\t  review_recommended: { en: 'Review recommended', sv: 'Granskning rekommenderas' },\n33\t  info_only: { en: 'Info only', sv: 'Endast information' },\n34\t};\n35\t\n36\tconst actionTooltips: Record<string, { en: string; sv: string }> = {\n37\t  action_required: { en: 'This change likely requires you to take action — update a process, notify stakeholders, or adjust compliance.', sv: 'Denna ändring kräver sannolikt åtgärd — uppdatera en process, informera intressenter eller justera efterlevnad.' },\n38\t  review_recommended: { en: 'This change should be reviewed to determine if it affects your operations. May not require immediate action.', sv: 'Denna ändring bör granskas för att avgöra om den påverkar er verksamhet. Kräver kanske inte omedelbar åtgärd.' },\n39\t  info_only: { en: 'Informational change — format update, minor correction, or cosmetic change. Typically no action needed.', sv: 'Informationsändring — formatuppdatering, mindre korrigering eller kosmetisk ändring. Normalt ingen åtgärd krävs.' },\n40\t};\n41\t\n42\tconst docTypeLabels: Record<string, { en: string; sv: string }> = {\n43\t  regulation: { en: 'Regulation', sv: 'Föreskrift' },\n44\t  guidance: { en: 'Guidance', sv: 'Vägledning' },\n45\t  consultation: { en: 'Consultation', sv: 'Remiss' },\n46\t  decision: { en: 'Decision', sv: 'Beslut' },\n47\t  standard: { en: 'Standard', sv: 'Standard' },\n48\t  law: { en: 'Law', sv: 'Lag' },\n49\t};\n50\t\n51\tfunction ActionBadge({ action, locale }: { action: string; locale: string }) {\n52\t  const colors = actionColors[action] || actionColors.info_only;\n53\t  const label = actionLabels[action]?.[locale as 'en' | 'sv'] || action;\n54\t  const tooltip = actionTooltips[action]?.[locale as 'en' | 'sv'] || '';\n55\t  return (\n56\t    <span\n57\t      className={`inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-medium cursor-help ${colors.badge}`}\n58\t      title={tooltip}\n59\t    >\n60\t      <span className={`h-1.5 w-1.5 rounded-full ${colors.dot}`} />\n61\t      {label}\n62\t    </span>\n63\t  );\n64\t}\n65\t\n66\texport function ComplianceFeed({ history: initialHistory, plan = 'free', slaActionHours = 48, slaReviewHours = 168 }: { history: ComplianceEntry[]; plan?: string; slaActionHours?: number; slaReviewHours?: number }) {\n67\t  const { locale } = useLocale();\n68\t  const [history, setHistory] = useState(initialHistory);\n69\t  const [actionFilter, setActionFilter] = useState<ActionFilter>('all');\n70\t  const [jurisdictionFilter, setJurisdictionFilter] = useState<string>('');\n71\t  const [expanded, setExpanded] = useState<Set<number>>(new Set());\n72\t  const [reviewing, setReviewing] = useState<number | null>(null);\n73\t  const [assigning, setAssigning] = useState<number | null>(null);\n74\t  const [assignInput, setAssignInput] = useState('');\n75\t\n76\t  const jurisdictions = useMemo(() => {\n77\t    const set = new Set<string>();\n78\t    for (const h of history) if (h.jurisdiction) set.add(h.jurisdiction);\n79\t    return Array.from(set).sort();\n80\t  }, [history]);\n81\t\n82\t  const filtered = useMemo(() => {\n83\t    let items = history;\n84\t    if (actionFilter !== 'all') items = items.filter(e => e.compliance_action === actionFilter);\n85\t    if (jurisdictionFilter) items = items.filter(e => e.jurisdiction === jurisdictionFilter);\n86\t    return items;\n87\t  }, [history, actionFilter, jurisdictionFilter]);\n88\t\n89\t  const actionCounts = useMemo(() => {\n90\t    const counts = { action_required: 0, review_recommended: 0, info_only: 0 };\n91\t    for (const h of history) {\n92\t      const a = h.compliance_action as keyof typeof counts;\n93\t      if (a && a in counts) counts[a]++;\n94\t    }\n95\t    return counts;\n96\t  }, [history]);\n97\t\n98\t  const toggleExpand = (id: number) => {\n99\t    setExpanded(prev => {\n100\t      const next = new Set(prev);\n101\t      next.has(id) ? next.delete(id) : next.add(id);\n102\t      return next;\n103\t    });\n104\t  };\n105\t\n106\t  const markReviewed = async (changeId: number) => {\n107\t    setReviewing(changeId);\n108\t    const res = await fetch('/api/review', {\n109\t      method: 'POST',\n110\t      headers: { 'Content-Type': 'application/json' },\n111\t      body: JSON.stringify({ changeId }),\n112\t    });\n113\t    if (res.ok) {\n114\t      setHistory((prev) =>\n115\t        prev.map((e) => e.id === changeId ? { ...e, reviewed_at: new Date().toISOString() } : e)\n116\t      );\n117\t    }\n118\t    setReviewing(null);\n119\t  };\n120\t\n121\t  const handleAssign = async (changeId: number, assignedTo: string) => {\n122\t    setAssigning(changeId);\n123\t    const res = await fetch('/api/assign', {\n124\t      method: 'POST',\n125\t      headers: { 'Content-Type': 'application/json' },\n126\t      body: JSON.stringify({ changeId, assignedTo: assignedTo || null }),\n127\t    });\n128\t    if (res.ok) {\n129\t      setHistory((prev) =>\n130\t        prev.map((e) => e.id === changeId\n131\t          ? { ...e, assigned_to: assignedTo || null, assigned_at: assignedTo ? new Date().toISOString() : null }\n132\t          : e)\n133\t      );\n134\t      setAssignInput('');\n135\t    }\n136\t    setAssigning(null);\n137\t  };\n138\t\n139\t  const formatDate = (dateStr: string) =>\n140\t    new Date(dateStr + 'Z').toLocaleString(locale === 'sv' ? 'sv-SE' : 'en-US', {\n141\t      month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit',\n142\t    });\n143\t\n144\t  if (history.length === 0) {\n145\t    return (\n146\t      <div className=\"space-y-4\">\n147\t        {/* Ghost preview — visar hur en compliance-ändring ser ut */}\n148\t        <div className=\"rounded-xl border border-dashed border-slate-200 p-4 opacity-50 pointer-events-none\">\n149\t          <div className=\"flex items-center gap-2 mb-2\">\n150\t            <span className=\"inline-flex items-center gap-1.5 rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700\">\n151\t              <span className=\"h-1.5 w-1.5 rounded-full bg-red-500\" />\n152\t              {locale === 'sv' ? 'Åtgärd krävs' : 'Action required'}\n153\t            </span>\n154\t            <span className=\"rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-500\">SE</span>\n155\t            <span className=\"rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-500\">{locale === 'sv' ? 'Föreskrift' : 'Regulation'}</span>\n156\t          </div>\n157\t          <p className=\"text-sm font-medium text-slate-700\">Finansinspektionen</p>\n158\t          <p className=\"text-sm text-slate-600 mt-1\">\n159\t            {locale === 'sv'\n160\t              ? '\"Nya krav på AML-rapportering publicerade. Ikraftträdande: 1 juli 2026.\"'\n161\t              : '\"New AML reporting requirements published. Effective date: July 1, 2026.\"'}\n162\t          </p>\n163\t          <div className=\"flex items-center gap-2 mt-2 text-xs text-slate-400\">\n164\t            <span className=\"rounded-full bg-red-50 px-1.5 py-0.5 text-red-500 font-medium\">9/10</span>\n165\t            <span>fi.se</span>\n166\t          </div>\n167\t        </div>\n168\t        <div className=\"text-center py-4\">\n169\t          <p className=\"text-sm font-medium text-slate-600\">\n170\t            {locale === 'sv' ? 'Så kommer dina regulatoriska ändringar att se ut' : 'This is what your regulatory changes will look like'}\n171\t          </p>\n172\t          <p className=\"mt-1 text-xs text-slate-500\">\n173\t            {locale === 'sv'\n174\t              ? 'Lägg till myndigheter under Upptäck för att börja bevaka.'\n175\t              : 'Add agencies from Discover below to start monitoring.'}\n176\t          </p>\n177\t        </div>\n178\t      </div>\n179\t    );\n180\t  }\n181\t\n182\t  const filterBtnCls = (active: boolean) =>\n183\t    `cursor-pointer rounded-lg px-3 py-1.5 text-xs font-medium transition-all duration-200 ${active ? 'bg-slate-100 text-slate-900' : 'text-slate-500 hover:text-slate-700'}`;\n184\t\n185\t  return (\n186\t    <div className=\"space-y-3\">\n187\t      {/* Stats strip */}\n188\t      <div className=\"flex gap-3\">\n189\t        {actionCounts.action_required > 0 && (\n190\t          <div className=\"flex items-center gap-1.5 rounded-lg bg-red-50 px-3 py-1.5\">\n191\t            <span className=\"h-2 w-2 rounded-full bg-red-500\" />\n192\t            <span className=\"text-xs font-medium text-red-600\">{actionCounts.action_required}</span>\n193\t            <span className=\"text-xs text-red-600/70\">{locale === 'sv' ? 'kräver åtgärd' : 'need action'}</span>\n194\t          </div>\n195\t        )}\n196\t        {actionCounts.review_recommended > 0 && (\n197\t          <div className=\"flex items-center gap-1.5 rounded-lg bg-amber-50 px-3 py-1.5\">\n198\t            <span className=\"h-2 w-2 rounded-full bg-amber-500\" />\n199\t            <span className=\"text-xs font-medium text-amber-600\">{actionCounts.review_recommended}</span>\n200\t            <span className=\"text-xs text-amber-600/70\">{locale === 'sv' ? 'att granska' : 'to review'}</span>\n201\t          </div>\n202\t        )}\n203\t      </div>\n204\t\n205\t      {/* Filters */}\n206\t      <div className=\"flex flex-wrap items-center gap-2\">\n207\t        <button onClick={() => setActionFilter('all')} className={filterBtnCls(actionFilter === 'all')}>\n208\t          {locale === 'sv' ? 'Alla' : 'All'} ({history.length})\n209\t        </button>\n210\t        <button onClick={() => setActionFilter('action_required')} className={filterBtnCls(actionFilter === 'action_required')}>\n211\t          {locale === 'sv' ? 'Åtgärd krävs' : 'Action required'} ({actionCounts.action_required})\n212\t        </button>\n213\t        <button onClick={() => setActionFilter('review_recommended')} className={filterBtnCls(actionFilter === 'review_recommended')}>\n214\t          {locale === 'sv' ? 'Granska' : 'Review'} ({actionCounts.review_recommended})\n215\t        </button>\n216\t        <button onClick={() => setActionFilter('info_only')} className={filterBtnCls(actionFilter === 'info_only')}>\n217\t          {locale === 'sv' ? 'Info' : 'Info'} ({actionCounts.info_only})\n218\t        </button>\n219\t\n220\t        {jurisdictions.length > 1 && (\n221\t          <select\n222\t            value={jurisdictionFilter}\n223\t            onChange={(e) => setJurisdictionFilter(e.target.value)}\n224\t            className=\"cursor-pointer rounded-lg bg-slate-50 border border-slate-200 px-3 py-1.5 text-xs text-slate-600 focus:outline-none ml-auto\"\n225\t          >\n226\t            <option value=\"\">{locale === 'sv' ? 'Alla jurisdiktioner' : 'All jurisdictions'}</option>\n227\t            {jurisdictions.map(j => (\n228\t              <option key={j} value={j}>{j}</option>\n229\t            ))}\n230\t          </select>\n231\t        )}\n232\t\n233\t        {(plan === 'pro' || plan === 'team') ? (\n234\t          <a\n235\t            href={`/api/export/compliance${jurisdictionFilter ? `?jurisdiction=${jurisdictionFilter}` : ''}${actionFilter !== 'all' ? `${jurisdictionFilter ? '&' : '?'}complianceAction=${actionFilter}` : ''}`}\n236\t            className=\"cursor-pointer rounded-lg bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-slate-900 transition\"\n237\t          >\n238\t            {locale === 'sv' ? 'Exportera audit trail' : 'Export audit trail'}\n239\t          </a>\n240\t        ) : (\n241\t          <a\n242\t            href=\"https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF\"\n243\t            target=\"_blank\"\n244\t            rel=\"noopener noreferrer\"\n245\t            className=\"cursor-pointer rounded-lg bg-blue-50 border border-blue-100 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100 transition\"\n246\t          >\n247\t            {locale === 'sv' ? 'Uppgradera för CSV-export' : 'Upgrade for CSV export'}\n248\t          </a>\n249\t        )}\n250\t      </div>\n251\t\n252\t      {/* Entries */}\n253\t      <div className=\"rounded-xl glass-card overflow-hidden divide-y divide-slate-100\">\n254\t        {filtered.map((entry) => {\n255\t          const isOpen = expanded.has(entry.id);\n256\t          let elements: string[] = [];\n257\t          if (entry.changed_elements) {\n258\t            try { elements = JSON.parse(entry.changed_elements); } catch { /* */ }\n259\t          }\n260\t          const docLabel = entry.document_type\n261\t            ? docTypeLabels[entry.document_type]?.[locale as 'en' | 'sv'] || entry.document_type\n262\t            : null;\n263\t\n264\t          // SLA overdue check\n265\t          const isOverdue = !entry.reviewed_at && entry.compliance_action && entry.checked_at && (() => {\n266\t            const ageMs = Date.now() - new Date(entry.checked_at + 'Z').getTime();\n267\t            const ageHours = ageMs / 3600000;\n268\t            if (entry.compliance_action === 'action_required') return ageHours > slaActionHours;\n269\t            if (entry.compliance_action === 'review_recommended') return ageHours > slaReviewHours;\n270\t            return false;\n271\t          })();\n272\t\n273\t          return (\n274\t            <div key={entry.id}>\n275\t              <button\n276\t                onClick={() => toggleExpand(entry.id)}\n277\t                className={`w-full cursor-pointer px-4 py-3 flex items-center gap-3 hover:bg-slate-50 transition text-left ${isOverdue ? 'bg-red-50/50' : ''}`}\n278\t              >\n279\t                <span className=\"text-xs text-slate-500 w-24 shrink-0\">{formatDate(entry.checked_at)}</span>\n280\t                {entry.compliance_action && (\n281\t                  <ActionBadge action={entry.compliance_action} locale={locale} />\n282\t                )}\n283\t                {isOverdue && (\n284\t                  <span className=\"rounded-full bg-red-50 px-1.5 py-0.5 text-[10px] font-bold text-red-600 shrink-0\" title={locale === 'sv' ? 'SLA överskriden' : 'SLA overdue'}>\n285\t                    ⚠ {locale === 'sv' ? 'Försenad' : 'Overdue'}\n286\t                  </span>\n287\t                )}\n288\t                {entry.jurisdiction && (\n289\t                  <span className=\"rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-500 shrink-0\">\n290\t                    {entry.jurisdiction}\n291\t                  </span>\n292\t                )}\n293\t                <span className=\"text-sm font-medium text-slate-900 shrink-0 max-w-[160px] truncate\">{entry.name}</span>\n294\t                <span className=\"text-sm text-slate-600 truncate flex-1 min-w-0\">\n295\t                  {entry.summary || (locale === 'sv' ? 'Ingen sammanfattning' : 'No summary')}\n296\t                </span>\n297\t                {entry.reviewed_at && (\n298\t                  <span className=\"shrink-0 rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-medium text-emerald-600\">\n299\t                    ✓\n300\t                  </span>\n301\t                )}\n302\t                <svg\n303\t                  className={`h-3.5 w-3.5 shrink-0 text-slate-400 transition-transform duration-200 ${isOpen ? 'rotate-180' : ''}`}\n304\t                  fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\n305\t                >\n306\t                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\n307\t                </svg>\n308\t              </button>\n309\t\n310\t              {isOpen && (\n311\t                <div className=\"px-4 pb-3 pt-0 ml-28 space-y-2 animate-expand\">\n312\t                  {entry.summary && (\n313\t                    <p className=\"text-sm text-slate-700 leading-relaxed\">{entry.summary}</p>\n314\t                  )}\n315\t                  <div className=\"flex flex-wrap items-center gap-2 text-xs text-slate-500\">\n316\t                    {entry.importance != null && entry.importance > 0 && (\n317\t                      <span className={`rounded-full px-1.5 py-0.5 font-medium ${\n318\t                        entry.importance >= 7 ? 'text-red-600 bg-red-50'\n319\t                          : entry.importance >= 4 ? 'text-orange-600 bg-orange-50'\n320\t                          : 'text-green-600 bg-green-50'\n321\t                      }`}>\n322\t                        {entry.importance}/10\n323\t                      </span>\n324\t                    )}\n325\t                    {docLabel && (\n326\t                      <span className=\"rounded bg-slate-100 px-2 py-0.5 text-slate-600\">{docLabel}</span>\n327\t                    )}\n328\t                    <a\n329\t                      href={entry.url} target=\"_blank\" rel=\"noopener noreferrer\"\n330\t                      className=\"text-blue-600/70 hover:text-blue-500 transition\"\n331\t                      onClick={(e) => e.stopPropagation()}\n332\t                    >\n333\t                      {entry.url}\n334\t                    </a>\n335\t                  </div>\n336\t                  {elements.length > 0 && (\n337\t                    <div className=\"flex flex-wrap gap-1.5\">\n338\t                      {elements.map((el, i) => (\n339\t                        <span key={i} className=\"rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600\">{el}</span>\n340\t                      ))}\n341\t                    </div>\n342\t                  )}\n343\t                  <div className=\"flex items-center gap-3 pt-1 flex-wrap\">\n344\t                    {!entry.reviewed_at ? (\n345\t                      <button\n346\t                        onClick={(e) => {\n347\t                          e.stopPropagation();\n348\t                          markReviewed(entry.id);\n349\t                        }}\n350\t                        disabled={reviewing === entry.id}\n351\t                        className=\"text-xs text-emerald-600/70 hover:text-emerald-600 transition cursor-pointer disabled:opacity-50\"\n352\t                      >\n353\t                        {reviewing === entry.id\n354\t                          ? (locale === 'sv' ? 'Markerar...' : 'Marking...')\n355\t                          : (locale === 'sv' ? 'Markera som granskad' : 'Mark as reviewed')}\n356\t                      </button>\n357\t                    ) : (\n358\t                      <span className=\"text-xs text-emerald-600/50\">\n359\t                        {locale === 'sv' ? 'Granskad' : 'Reviewed'} {new Date(entry.reviewed_at + 'Z').toLocaleDateString(locale === 'sv' ? 'sv-SE' : 'en-US')}\n360\t                      </span>\n361\t                    )}\n362\t                    {plan === 'team' && (\n363\t                      entry.assigned_to ? (\n364\t                        <span className=\"flex items-center gap-1.5 text-xs\">\n365\t                          <span className=\"rounded-full bg-blue-50 border border-blue-100 px-2 py-0.5 text-blue-700\">\n366\t                            → {entry.assigned_to}\n367\t                          </span>\n368\t                          <button\n369\t                            onClick={(e) => { e.stopPropagation(); handleAssign(entry.id, ''); }}\n370\t                            className=\"text-slate-400 hover:text-red-500 transition cursor-pointer\"\n371\t                          >×</button>\n372\t                        </span>\n373\t                      ) : (\n374\t                        <span className=\"flex items-center gap-1\" onClick={(e) => e.stopPropagation()}>\n375\t                          <input\n376\t                            type=\"email\"\n377\t                            placeholder={locale === 'sv' ? 'tilldela@email.se' : 'assign@email.com'}\n378\t                            value={assigning === entry.id ? assignInput : ''}\n379\t                            onFocus={() => { setAssigning(entry.id); setAssignInput(''); }}\n380\t                            onChange={(e) => setAssignInput(e.target.value)}\n381\t                            onKeyDown={(e) => { if (e.key === 'Enter' && assignInput) handleAssign(entry.id, assignInput); }}\n382\t                            className=\"w-36 rounded-md bg-slate-50 border border-slate-200 px-2 py-0.5 text-xs text-slate-600 placeholder:text-slate-400 focus:outline-none focus:ring-1 focus:ring-blue-300\"\n383\t                          />\n384\t                          {assigning === entry.id && assignInput && (\n385\t                            <button\n386\t                              onClick={() => handleAssign(entry.id, assignInput)}\n387\t                              className=\"text-xs text-blue-600 hover:text-blue-700 transition cursor-pointer\"\n388\t                            >\n389\t                              {locale === 'sv' ? 'Tilldela' : 'Assign'}\n390\t                            </button>\n391\t                          )}\n392\t                        </span>\n393\t                      )\n394\t                    )}\n395\t                  </div>\n396\t                </div>\n397\t              )}\n398\t            </div>\n399\t          );\n400\t        })}\n401\t        {filtered.length === 0 && (\n402\t          <div className=\"px-4 py-8 text-center text-sm text-slate-500\">\n403\t            {locale === 'sv' ? 'Inga ändringar matchar filtret' : 'No changes match the filter'}\n404\t          </div>\n405\t        )}\n406\t      </div>\n407\t    </div>\n408\t  );\n409\t}\n410\t"}]},"parent_tool_use_id":null,"session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"92f7f1e2-9c4c-4873-818b-cbcdf9bd0ea0","timestamp":"2026-04-18T21:25:07.878Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wigclaw/overnight-work/changebrief-night-improve/app/src/app/dashboard/compliance-feed.tsx","content":"'use client';\n\nimport { useState, useMemo } from 'react';\nimport { useLocale } from '../locale-provider';\n\ninterface ComplianceEntry {\n  id: number;\n  url: string;\n  name: string;\n  summary: string | null;\n  importance: number | null;\n  changed_elements: string | null;\n  checked_at: string;\n  jurisdiction: string | null;\n  document_type: string | null;\n  compliance_action: string | null;\n  reviewed_at: string | null;\n  assigned_to: string | null;\n  assigned_at: string | null;\n}\n\ntype ActionFilter = 'all' | 'action_required' | 'review_recommended' | 'info_only';\n\nconst actionColors: Record<string, { badge: string; dot: string }> = {\n  action_required: { badge: 'text-red-700 bg-red-50', dot: 'bg-red-500' },\n  review_recommended: { badge: 'text-amber-700 bg-amber-50', dot: 'bg-amber-500' },\n  info_only: { badge: 'text-slate-600 bg-slate-100', dot: 'bg-slate-500' },\n};\n\nconst actionLabels: Record<string, { en: string; sv: string }> = {\n  action_required: { en: 'Action required', sv: 'Åtgärd krävs' },\n  review_recommended: { en: 'Review recommended', sv: 'Granskning rekommenderas' },\n  info_only: { en: 'Info only', sv: 'Endast information' },\n};\n\nconst actionTooltips: Record<string, { en: string; sv: string }> = {\n  action_required: { en: 'This change likely requires you to take action — update a process, notify stakeholders, or adjust compliance.', sv: 'Denna ändring kräver sannolikt åtgärd — uppdatera en process, informera intressenter eller justera efterlevnad.' },\n  review_recommended: { en: 'This change should be reviewed to determine if it affects your operations. May not require immediate action.', sv: 'Denna ändring bör granskas för att avgöra om den påverkar er verksamhet. Kräver kanske inte omedelbar åtgärd.' },\n  info_only: { en: 'Informational change — format update, minor correction, or cosmetic change. Typically no action needed.', sv: 'Informationsändring — formatuppdatering, mindre korrigering eller kosmetisk ändring. Normalt ingen åtgärd krävs.' },\n};\n\nconst docTypeLabels: Record<string, { en: string; sv: string }> = {\n  regulation: { en: 'Regulation', sv: 'Föreskrift' },\n  guidance: { en: 'Guidance', sv: 'Vägledning' },\n  consultation: { en: 'Consultation', sv: 'Remiss' },\n  decision: { en: 'Decision', sv: 'Beslut' },\n  standard: { en: 'Standard', sv: 'Standard' },\n  law: { en: 'Law', sv: 'Lag' },\n};\n\nfunction ActionBadge({ action, locale }: { action: string; locale: string }) {\n  const colors = actionColors[action] || actionColors.info_only;\n  const label = actionLabels[action]?.[locale as 'en' | 'sv'] || action;\n  const tooltip = actionTooltips[action]?.[locale as 'en' | 'sv'] || '';\n  return (\n    <span\n      className={`inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-medium cursor-help ${colors.badge}`}\n      title={tooltip}\n    >\n      <span className={`h-1.5 w-1.5 rounded-full ${colors.dot}`} />\n      {label}\n    </span>\n  );\n}\n\nexport function ComplianceFeed({ history: initialHistory, plan = 'free', slaActionHours = 48, slaReviewHours = 168 }: { history: ComplianceEntry[]; plan?: string; slaActionHours?: number; slaReviewHours?: number }) {\n  const { locale } = useLocale();\n  const [history, setHistory] = useState(initialHistory);\n  const [actionFilter, setActionFilter] = useState<ActionFilter>('all');\n  const [jurisdictionFilter, setJurisdictionFilter] = useState<string>('');\n  const [expanded, setExpanded] = useState<Set<number>>(new Set());\n  const [reviewing, setReviewing] = useState<number | null>(null);\n  const [assigning, setAssigning] = useState<number | null>(null);\n  const [assignInput, setAssignInput] = useState('');\n\n  const jurisdictions = useMemo(() => {\n    const set = new Set<string>();\n    for (const h of history) if (h.jurisdiction) set.add(h.jurisdiction);\n    return Array.from(set).sort();\n  }, [history]);\n\n  const filtered = useMemo(() => {\n    let items = history;\n    if (actionFilter !== 'all') items = items.filter(e => e.compliance_action === actionFilter);\n    if (jurisdictionFilter) items = items.filter(e => e.jurisdiction === jurisdictionFilter);\n    return items;\n  }, [history, actionFilter, jurisdictionFilter]);\n\n  const actionCounts = useMemo(() => {\n    const counts = { action_required: 0, review_recommended: 0, info_only: 0 };\n    for (const h of history) {\n      const a = h.compliance_action as keyof typeof counts;\n      if (a && a in counts) counts[a]++;\n    }\n    return counts;\n  }, [history]);\n\n  const toggleExpand = (id: number) => {\n    setExpanded(prev => {\n      const next = new Set(prev);\n      next.has(id) ? next.delete(id) : next.add(id);\n      return next;\n    });\n  };\n\n  const markReviewed = async (changeId: number) => {\n    setReviewing(changeId);\n    const res = await fetch('/api/review', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ changeId }),\n    });\n    if (res.ok) {\n      setHistory((prev) =>\n        prev.map((e) => e.id === changeId ? { ...e, reviewed_at: new Date().toISOString() } : e)\n      );\n    }\n    setReviewing(null);\n  };\n\n  const handleAssign = async (changeId: number, assignedTo: string) => {\n    setAssigning(changeId);\n    const res = await fetch('/api/assign', {\n      method: 'POST',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ changeId, assignedTo: assignedTo || null }),\n    });\n    if (res.ok) {\n      setHistory((prev) =>\n        prev.map((e) => e.id === changeId\n          ? { ...e, assigned_to: assignedTo || null, assigned_at: assignedTo ? new Date().toISOString() : null }\n          : e)\n      );\n      setAssignInput('');\n    }\n    setAssigning(null);\n  };\n\n  const formatDate = (dateStr: string) =>\n    new Date(dateStr + 'Z').toLocaleString(locale === 'sv' ? 'sv-SE' : 'en-US', {\n      month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit',\n    });\n\n  if (history.length === 0) {\n    return (\n      <div className=\"space-y-4\">\n        {/* Ghost preview — visar hur en compliance-ändring ser ut */}\n        <div className=\"rounded-xl border border-dashed border-slate-200 p-4 opacity-50 pointer-events-none\">\n          <div className=\"flex items-center gap-2 mb-2\">\n            <span className=\"inline-flex items-center gap-1.5 rounded-full bg-red-50 px-2 py-0.5 text-xs font-medium text-red-700\">\n              <span className=\"h-1.5 w-1.5 rounded-full bg-red-500\" />\n              {locale === 'sv' ? 'Åtgärd krävs' : 'Action required'}\n            </span>\n            <span className=\"rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-500\">SE</span>\n            <span className=\"rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-500\">{locale === 'sv' ? 'Föreskrift' : 'Regulation'}</span>\n          </div>\n          <p className=\"text-sm font-medium text-slate-700\">Finansinspektionen</p>\n          <p className=\"text-sm text-slate-600 mt-1\">\n            {locale === 'sv'\n              ? '\"Nya krav på AML-rapportering publicerade. Ikraftträdande: 1 juli 2026.\"'\n              : '\"New AML reporting requirements published. Effective date: July 1, 2026.\"'}\n          </p>\n          <div className=\"flex items-center gap-2 mt-2 text-xs text-slate-400\">\n            <span className=\"rounded-full bg-red-50 px-1.5 py-0.5 text-red-500 font-medium\">9/10</span>\n            <span>fi.se</span>\n          </div>\n        </div>\n        <div className=\"text-center py-4\">\n          <p className=\"text-sm font-medium text-slate-600\">\n            {locale === 'sv' ? 'Så kommer dina regulatoriska ändringar att se ut' : 'This is what your regulatory changes will look like'}\n          </p>\n          <p className=\"mt-1 text-xs text-slate-500\">\n            {locale === 'sv'\n              ? 'Lägg till myndigheter under Upptäck för att börja bevaka.'\n              : 'Add agencies from Discover below to start monitoring.'}\n          </p>\n        </div>\n      </div>\n    );\n  }\n\n  const filterBtnCls = (active: boolean) =>\n    `cursor-pointer rounded-lg px-3 py-1.5 text-xs font-medium transition-all duration-200 ${active ? 'bg-slate-100 text-slate-900' : 'text-slate-500 hover:text-slate-700'}`;\n\n  return (\n    <div className=\"space-y-3\">\n      {/* Stats strip */}\n      <div className=\"flex gap-3\">\n        {actionCounts.action_required > 0 && (\n          <div className=\"flex items-center gap-1.5 rounded-lg bg-red-50 px-3 py-1.5\">\n            <span className=\"h-2 w-2 rounded-full bg-red-500\" />\n            <span className=\"text-xs font-medium text-red-600\">{actionCounts.action_required}</span>\n            <span className=\"text-xs text-red-600/70\">{locale === 'sv' ? 'kräver åtgärd' : 'need action'}</span>\n          </div>\n        )}\n        {actionCounts.review_recommended > 0 && (\n          <div className=\"flex items-center gap-1.5 rounded-lg bg-amber-50 px-3 py-1.5\">\n            <span className=\"h-2 w-2 rounded-full bg-amber-500\" />\n            <span className=\"text-xs font-medium text-amber-600\">{actionCounts.review_recommended}</span>\n            <span className=\"text-xs text-amber-600/70\">{locale === 'sv' ? 'att granska' : 'to review'}</span>\n          </div>\n        )}\n      </div>\n\n      {/* Filters */}\n      <div className=\"flex flex-wrap items-center gap-2\">\n        <button onClick={() => setActionFilter('all')} className={filterBtnCls(actionFilter === 'all')}>\n          {locale === 'sv' ? 'Alla' : 'All'} ({history.length})\n        </button>\n        <button onClick={() => setActionFilter('action_required')} className={filterBtnCls(actionFilter === 'action_required')}>\n          {locale === 'sv' ? 'Åtgärd krävs' : 'Action required'} ({actionCounts.action_required})\n        </button>\n        <button onClick={() => setActionFilter('review_recommended')} className={filterBtnCls(actionFilter === 'review_recommended')}>\n          {locale === 'sv' ? 'Granska' : 'Review'} ({actionCounts.review_recommended})\n        </button>\n        <button onClick={() => setActionFilter('info_only')} className={filterBtnCls(actionFilter === 'info_only')}>\n          {locale === 'sv' ? 'Info' : 'Info'} ({actionCounts.info_only})\n        </button>\n\n        {jurisdictions.length > 1 && (\n          <select\n            value={jurisdictionFilter}\n            onChange={(e) => setJurisdictionFilter(e.target.value)}\n            className=\"cursor-pointer rounded-lg bg-slate-50 border border-slate-200 px-3 py-1.5 text-xs text-slate-600 focus:outline-none ml-auto\"\n          >\n            <option value=\"\">{locale === 'sv' ? 'Alla jurisdiktioner' : 'All jurisdictions'}</option>\n            {jurisdictions.map(j => (\n              <option key={j} value={j}>{j}</option>\n            ))}\n          </select>\n        )}\n\n        {(plan === 'pro' || plan === 'team') ? (\n          <a\n            href={`/api/export/compliance${jurisdictionFilter ? `?jurisdiction=${jurisdictionFilter}` : ''}${actionFilter !== 'all' ? `${jurisdictionFilter ? '&' : '?'}complianceAction=${actionFilter}` : ''}`}\n            className=\"cursor-pointer rounded-lg bg-slate-50 px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-slate-900 transition\"\n          >\n            {locale === 'sv' ? 'Exportera audit trail' : 'Export audit trail'}\n          </a>\n        ) : (\n          <a\n            href=\"https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            className=\"cursor-pointer rounded-lg bg-blue-50 border border-blue-100 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100 transition\"\n          >\n            {locale === 'sv' ? 'Uppgradera för CSV-export' : 'Upgrade for CSV export'}\n          </a>\n        )}\n      </div>\n\n      {/* Entries */}\n      <div className=\"rounded-xl glass-card overflow-hidden divide-y divide-slate-100\">\n        {filtered.map((entry) => {\n          const isOpen = expanded.has(entry.id);\n          let elements: string[] = [];\n          if (entry.changed_elements) {\n            try { elements = JSON.parse(entry.changed_elements); } catch { /* */ }\n          }\n          const docLabel = entry.document_type\n            ? docTypeLabels[entry.document_type]?.[locale as 'en' | 'sv'] || entry.document_type\n            : null;\n\n          // SLA overdue check\n          const isOverdue = !entry.reviewed_at && entry.compliance_action && entry.checked_at && (() => {\n            const ageMs = Date.now() - new Date(entry.checked_at + 'Z').getTime();\n            const ageHours = ageMs / 3600000;\n            if (entry.compliance_action === 'action_required') return ageHours > slaActionHours;\n            if (entry.compliance_action === 'review_recommended') return ageHours > slaReviewHours;\n            return false;\n          })();\n\n          return (\n            <div key={entry.id}>\n              <button\n                onClick={() => toggleExpand(entry.id)}\n                className={`w-full cursor-pointer px-4 py-3 flex items-center gap-3 hover:bg-slate-50 transition text-left ${isOverdue ? 'bg-red-50/50' : ''}`}\n              >\n                <span className=\"text-xs text-slate-500 w-24 shrink-0\">{formatDate(entry.checked_at)}</span>\n                {entry.compliance_action && (\n                  <ActionBadge action={entry.compliance_action} locale={locale} />\n                )}\n                {isOverdue && (\n                  <span className=\"rounded-full bg-red-50 px-1.5 py-0.5 text-[10px] font-bold text-red-600 shrink-0\" title={locale === 'sv' ? 'SLA överskriden' : 'SLA overdue'}>\n                    ⚠ {locale === 'sv' ? 'Försenad' : 'Overdue'}\n                  </span>\n                )}\n                {entry.jurisdiction && (\n                  <span className=\"rounded bg-slate-100 px-1.5 py-0.5 text-[10px] font-mono text-slate-500 shrink-0\">\n                    {entry.jurisdiction}\n                  </span>\n                )}\n                <span className=\"text-sm font-medium text-slate-900 shrink-0 max-w-[160px] truncate\">{entry.name}</span>\n                <span className=\"text-sm text-slate-600 truncate flex-1 min-w-0\">\n                  {entry.summary || (locale === 'sv' ? 'Ingen sammanfattning' : 'No summary')}\n                </span>\n                {entry.reviewed_at && (\n                  <span className=\"shrink-0 rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-medium text-emerald-600\">\n                    ✓\n                  </span>\n                )}\n                <svg\n                  className={`h-3.5 w-3.5 shrink-0 text-slate-400 transition-transform duration-200 ${isOpen ? 'rotate-180' : ''}`}\n                  fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\n                >\n                  <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M19 9l-7 7-7-7\" />\n                </svg>\n              </button>\n\n              {isOpen && (\n                <div className=\"px-4 pb-3 pt-0 ml-28 space-y-2 animate-expand\">\n                  {entry.summary && (\n                    <p className=\"text-sm text-slate-700 leading-relaxed\">{entry.summary}</p>\n                  )}\n                  <div className=\"flex flex-wrap items-center gap-2 text-xs text-slate-500\">\n                    {entry.importance != null && entry.importance > 0 && (\n                      <span className={`rounded-full px-1.5 py-0.5 font-medium ${\n                        entry.importance >= 7 ? 'text-red-600 bg-red-50'\n                          : entry.importance >= 4 ? 'text-orange-600 bg-orange-50'\n                          : 'text-green-600 bg-green-50'\n                      }`}>\n                        {entry.importance}/10\n                      </span>\n                    )}\n                    {docLabel && (\n                      <span className=\"rounded bg-slate-100 px-2 py-0.5 text-slate-600\">{docLabel}</span>\n                    )}\n                    <a\n                      href={entry.url} target=\"_blank\" rel=\"noopener noreferrer\"\n                      className=\"text-blue-600/70 hover:text-blue-500 transition\"\n                      onClick={(e) => e.stopPropagation()}\n                    >\n                      {entry.url}\n                    </a>\n                  </div>\n                  {elements.length > 0 && (\n                    <div className=\"flex flex-wrap gap-1.5\">\n                      {elements.map((el, i) => (\n                        <span key={i} className=\"rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600\">{el}</span>\n                      ))}\n                    </div>\n                  )}\n                  <div className=\"flex items-center gap-3 pt-1 flex-wrap\">\n                    {!entry.reviewed_at ? (\n                      <button\n                        onClick={(e) => {\n                          e.stopPropagation();\n                          markReviewed(entry.id);\n                        }}\n                        disabled={reviewing === entry.id}\n                        className=\"text-xs text-emerald-600/70 hover:text-emerald-600 transition cursor-pointer disabled:opacity-50\"\n                      >\n                        {reviewing === entry.id\n                          ? (locale === 'sv' ? 'Markerar...' : 'Marking...')\n                          : (locale === 'sv' ? 'Markera som granskad' : 'Mark as reviewed')}\n                      </button>\n                    ) : (\n                      <span className=\"text-xs text-emerald-600/50\">\n                        {locale === 'sv' ? 'Granskad' : 'Reviewed'} {new Date(entry.reviewed_at + 'Z').toLocaleDateString(locale === 'sv' ? 'sv-SE' : 'en-US')}\n                      </span>\n                    )}\n                    {plan === 'team' && (\n                      entry.assigned_to ? (\n                        <span className=\"flex items-center gap-1.5 text-xs\">\n                          <span className=\"rounded-full bg-blue-50 border border-blue-100 px-2 py-0.5 text-blue-700\">\n                            → {entry.assigned_to}\n                          </span>\n                          <button\n                            onClick={(e) => { e.stopPropagation(); handleAssign(entry.id, ''); }}\n                            className=\"text-slate-400 hover:text-red-500 transition cursor-pointer\"\n                          >×</button>\n                        </span>\n                      ) : (\n                        <span className=\"flex items-center gap-1\" onClick={(e) => e.stopPropagation()}>\n                          <input\n                            type=\"email\"\n                            placeholder={locale === 'sv' ? 'tilldela@email.se' : 'assign@email.com'}\n                            value={assigning === entry.id ? assignInput : ''}\n                            onFocus={() => { setAssigning(entry.id); setAssignInput(''); }}\n                            onChange={(e) => setAssignInput(e.target.value)}\n                            onKeyDown={(e) => { if (e.key === 'Enter' && assignInput) handleAssign(entry.id, assignInput); }}\n                            className=\"w-36 rounded-md bg-slate-50 border border-slate-200 px-2 py-0.5 text-xs text-slate-600 placeholder:text-slate-400 focus:outline-none focus:ring-1 focus:ring-blue-300\"\n                          />\n                          {assigning === entry.id && assignInput && (\n                            <button\n                              onClick={() => handleAssign(entry.id, assignInput)}\n                              className=\"text-xs text-blue-600 hover:text-blue-700 transition cursor-pointer\"\n                            >\n                              {locale === 'sv' ? 'Tilldela' : 'Assign'}\n                            </button>\n                          )}\n                        </span>\n                      )\n                    )}\n                  </div>\n                </div>\n              )}\n            </div>\n          );\n        })}\n        {filtered.length === 0 && (\n          <div className=\"px-4 py-8 text-center text-sm text-slate-500\">\n            {locale === 'sv' ? 'Inga ändringar matchar filtret' : 'No changes match the filter'}\n          </div>\n        )}\n      </div>\n    </div>\n  );\n}\n","numLines":410,"startLine":1,"totalLines":410}}}
