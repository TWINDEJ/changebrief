{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XrLfWMxJabJryNxCkFgjKC","type":"tool_result","content":"1\texport type Lang = 'en' | 'sv';\n2\t\n3\texport const landing = {\n4\t  'header.cta': { en: 'Get started free', sv: 'Kom igång gratis' },\n5\t  'hero.badge': { en: 'Know what changed in plain English', sv: 'Vet vad som ändrades — på ren svenska' },\n6\t  'hero.h1a': { en: 'See what changed', sv: 'Se vad som ändrades' },\n7\t  'hero.h1b': { en: 'not just that something changed', sv: 'inte bara att något ändrades' },\n8\t  'hero.sub': { en: 'changebrief monitors web pages and uses AI to tell you exactly what happened. No blurry screenshots. No red pixels. Just a clear sentence.', sv: 'changebrief bevakar webbsidor och berättar med AI exakt vad som hände. Inga suddiga screenshots. Inga röda pixlar. Bara en tydlig mening.' },\n9\t  'hero.cta1': { en: 'Get started free', sv: 'Kom igång gratis' },\n10\t  'hero.cta2': { en: 'See how it works', sv: 'Se hur det funkar' },\n11\t  'hero.demo.text': { en: 'Acme Corp removed the', sv: 'Acme Corp tog bort' },\n12\t  'hero.demo.btn': { en: 'Free for 14 days', sv: 'Gratis i 14 dagar' },\n13\t  'hero.demo.raised': { en: 'button and raised the Pro price from', sv: '-knappen och höjde Pro-priset från' },\n14\t  'hero.demo.to': { en: 'to', sv: 'till' },\n15\t  'problem.h2': { en: 'Existing tools show you', sv: 'Befintliga verktyg visar dig' },\n16\t  'problem.h2b': { en: 'this...', sv: 'det här...' },\n17\t  'problem.sub': { en: \"You shouldn't have to interpret screenshots. AI does it for you.\", sv: 'Du ska inte behöva tolka screenshots. AI gör det åt dig.' },\n18\t  'problem.other': { en: 'Other tools', sv: 'Andra verktyg' },\n19\t  'problem.q': { en: 'Something changed... but what?', sv: 'Något har ändrats... men vad?' },\n20\t  'problem.clear': { en: 'Crystal clear. Straight to Slack.', sv: 'Kristallklart. Direkt i Slack.' },\n21\t  'how.h2': { en: 'How it works', sv: 'Så funkar det' },\n22\t  'how.sub': { en: 'Three steps. No code.', sv: 'Tre steg. Ingen kod.' },\n23\t  'how.s1': { en: 'Step 1', sv: 'Steg 1' },\n24\t  'how.s1.h': { en: 'Add a URL', sv: 'Lägg till en URL' },\n25\t  'how.s1.p': { en: 'Paste the page you want to monitor. Pricing page, terms of service, status page — anything.', sv: 'Klistra in sidan du vill bevaka. Prissida, villkor, statusesida — vad som helst.' },\n26\t  'how.s2': { en: 'Step 2', sv: 'Steg 2' },\n27\t  'how.s2.h': { en: 'We take screenshots automatically', sv: 'Vi tar screenshots automatiskt' },\n28\t  'how.s2.p': { en: 'A headless browser runs in the background and captures exactly how the page looks — every hour, day, or week.', sv: 'Headless browser kör i bakgrunden och fångar exakt hur sidan ser ut — varje timme, dag eller vecka.' },\n29\t  'how.s3': { en: 'Step 3', sv: 'Steg 3' },\n30\t  'how.s3.h': { en: 'AI tells you what changed', sv: 'AI berättar vad som ändrades' },\n31\t  'how.s3.p': { en: 'AI vision compares before and after, and sends a clear summary to Slack, Teams, or email.', sv: 'AI vision jämför före och efter, och skickar en tydlig sammanfattning till Slack, Teams eller e-post.' },\n32\t  'use.h2': { en: 'Use cases', sv: 'Användningsområden' },\n33\t  'use.sub': { en: 'One tool. Dozens of high-value applications.', sv: 'Ett verktyg. Massor av värdefulla användningsområden.' },\n34\t  'use.comp.h': { en: 'Competitor pricing', sv: 'Konkurrentpriser' },\n35\t  'use.comp.p': { en: 'Know within hours when a competitor changes pricing, removes a free tier, or adds a new plan. React the same day instead of next quarter.', sv: 'Vet inom timmar när en konkurrent ändrar priser, tar bort en gratisplan eller lägger till en ny nivå. Reagera samma dag istället för nästa kvartal.' },\n36\t  'use.reg.h': { en: 'Regulatory changes', sv: 'Regeländringar' },\n37\t  'use.reg.p': { en: 'Monitor government agencies and regulators for policy updates, new rules, or changed requirements that affect your industry.', sv: 'Bevaka myndigheter och tillsynsorgan för policyuppdateringar, nya regler eller ändrade krav som påverkar din bransch.' },\n38\t  'use.vendor.h': { en: 'SaaS terms & contracts', sv: 'SaaS-villkor & avtal' },\n39\t  'use.vendor.p': { en: \"Catch silent changes to terms of service, privacy policies, or SLAs from vendors you depend on — before your renewal date.\", sv: 'Fånga tysta ändringar i användarvillkor, integritetspolicyer eller SLA:er hos leverantörer ni är beroende av — innan förnyelsedatumet.' },\n40\t  'use.hiring.h': { en: 'Hiring & strategy intel', sv: 'Rekrytering & strategi-intel' },\n41\t  'use.hiring.p': { en: \"Watch competitor career pages. When they start hiring ML engineers or enterprise sales reps, you know where they're heading next.\", sv: 'Bevaka konkurrenters karriärsidor. När de börjar anställa ML-ingenjörer eller enterprise-säljare vet du vart de är på väg.' },\n42\t  'use.ecom.h': { en: 'Supplier & MAP pricing', sv: 'Leverantörs- & MAP-priser' },\n43\t  'use.ecom.p': { en: 'Track supplier prices, wholesale catalogs, or MAP compliance across resellers. Catch price drops before your competitors do.', sv: 'Följ leverantörspriser, grossistkataloger eller MAP-efterlevnad hos återförsäljare. Fånga prissänkningar innan konkurrenterna.' },\n44\t  'use.site.h': { en: 'Your own site integrity', sv: 'Er egen sajts integritet' },\n45\t  'use.site.p': { en: 'Detect accidental deploys, defacement, SEO spam injection, or broken layouts on your own pages — before customers see them.', sv: 'Upptäck oavsiktliga deployar, defacement, SEO-spam eller trasiga layouts på era egna sidor — innan kunderna ser dem.' },\n46\t  'feat.h2': { en: 'Features', sv: 'Funktioner' },\n47\t  'feat.sub': { en: 'What sets changebrief apart from pixel-diff tools.', sv: 'Det som skiljer changebrief från pixeldiff-verktyg.' },\n48\t  'feat.ai': { en: 'AI-powered summaries', sv: 'AI-drivna sammanfattningar' },\n49\t  'feat.ai.p': { en: \"AI vision understands what's shown — prices, buttons, text. Not just pixels.\", sv: 'AI vision förstår vad som visas — priser, knappar, text. Inte bara pixlar.' },\n50\t  'feat.score': { en: 'Importance score (1-10)', sv: 'Viktighetspoäng (1-10)' },\n51\t  'feat.score.p': { en: 'Filter out noise. Only get notified about important changes — pricing, features, terms.', sv: 'Filtrera brus. Få bara notiser vid viktiga ändringar — pris, features, villkor.' },\n52\t  'feat.slack': { en: 'Slack, Teams & Discord', sv: 'Slack, Teams & Discord' },\n53\t  'feat.slack.p': { en: 'Notifications straight to the channel your team already uses. Plus PagerDuty, Jira, and webhooks.', sv: 'Notiser direkt i kanalen ditt team redan använder. Plus PagerDuty, Jira och webhooks.' },\n54\t  'feat.sched': { en: 'Scheduled monitoring', sv: 'Schemalagd bevakning' },\n55\t  'feat.sched.p': { en: 'Every hour, day, or week. You decide. We run in the background.', sv: 'Varje timme, dag eller vecka. Du bestämmer. Vi kör i bakgrunden.' },\n56\t  'feat.hist': { en: 'Screenshot history', sv: 'Screenshot-historik' },\n57\t  'feat.hist.p': { en: 'See exactly how a page looked a day, week, or month ago. Visual timeline.', sv: 'Se exakt hur sidan såg ut för en dag, vecka eller månad sedan. Visuell tidslinje.' },\n58\t  'feat.api': { en: 'REST API & Webhooks', sv: 'REST API & Webhooks' },\n59\t  'feat.api.p': { en: 'Connect to Zapier, Make, n8n, or build your own integration. JSON payload on every change.', sv: 'Koppla till Zapier, Make, n8n eller bygg din egen integration. JSON-payload vid varje ändring.' },\n60\t  'price.h2': { en: 'Simple pricing', sv: 'Enkel prissättning' },\n61\t  'price.sub': { en: 'Start free. Upgrade when you need more.', sv: 'Börja gratis. Uppgradera när du behöver mer.' },\n62\t  'price.free.desc': { en: 'Try it at no cost.', sv: 'Testa utan kostnad.' },\n63\t  'price.free.cta': { en: 'Get started free', sv: 'Kom igång gratis' },\n64\t  'price.popular': { en: 'Most popular', sv: 'Populärast' },\n65\t  'price.pro.desc': { en: '25 pages, Slack notifications, 90 days of history.', sv: '25 sidor, Slack-notiser, 90 dagars historik.' },\n66\t  'price.pro.cta': { en: 'Start Pro', sv: 'Starta Pro' },\n67\t  'price.team.desc': { en: '100 pages, all integrations, API access.', sv: '100 sidor, alla integrationer, API-åtkomst.' },\n68\t  'price.team.cta': { en: 'Start Team', sv: 'Starta Team' },\n69\t  'price.or': { en: 'or', sv: 'eller' },\n70\t  'price.save': { en: 'save 17%', sv: 'spara 17%' },\n71\t  'price.mo': { en: '/mo', sv: '/mån' },\n72\t  'price.year': { en: '/year', sv: '/år' },\n73\t  'price.pages': { en: 'monitored pages', sv: 'bevakade sidor' },\n74\t  'price.checks': { en: 'checks/mo', sv: 'kontroller/mån' },\n75\t  'price.days': { en: 'days of history', sv: 'dagars historik' },\n76\t  'price.schedule15': { en: 'Schedule every 15 minutes', sv: 'Schemalägg var 15:e minut' },\n77\t  'price.everything': { en: 'Everything in Pro', sv: 'Allt i Pro' },\n78\t  'price.1year': { en: '1 year history, 5 users', sv: '1 år historik, 5 användare' },\n79\t  'faq.h2': { en: 'Frequently asked questions', sv: 'Vanliga frågor' },\n80\t  'faq.q1': { en: 'How is changebrief different from Visualping?', sv: 'Hur skiljer sig changebrief från Visualping?' },\n81\t  'faq.a1': { en: 'Visualping shows you an image with red pixels where something changed. You have to figure out what it means yourself. changebrief sends the screenshot pair to AI vision and returns a sentence describing exactly what changed — \"Price increased from $29 to $39/mo\" instead of a red blob.', sv: 'Visualping visar en bild med röda pixlar där något ändrats. Du måste själv tolka vad det betyder. changebrief skickar bildparet till AI vision och returnerar en mening som beskriver exakt vad som ändrades — \"Priset höjdes från $29 till $39/mån\" istället för en röd fläck.' },\n82\t  'faq.q2': { en: 'How accurate are the summaries?', sv: 'Hur träffsäkra är sammanfattningarna?' },\n83\t  'faq.a2': { en: \"We use state-of-the-art vision AI that understands what's displayed on a web page — prices, buttons, text, layouts. It compares two versions of the same page and describes exactly what changed in plain language. The importance score (1-10) helps you filter noise from signal.\", sv: 'Vi använder toppmodern vision-AI som förstår vad som visas på en webbsida — priser, knappar, text, layouter. Den jämför två versioner av samma sida och beskriver exakt vad som ändrades i klartext. Viktighetspoängen (1-10) hjälper dig filtrera brus från signal.' },\n84\t  'faq.q3': { en: 'Can I monitor pages behind a login?', sv: 'Kan jag bevaka sidor bakom login?' },\n85\t  'faq.a3': { en: 'Yes! You can configure cookies and HTTP headers per URL. This makes it possible to monitor pages that require authentication, such as internal dashboards or customer portals.', sv: 'Ja! Du kan konfigurera cookies och HTTP-headers per URL. Det gör det möjligt att bevaka sidor som kräver autentisering, t.ex. interna dashboards eller kund-portaler.' },\n86\t  'faq.q4': { en: 'Where is data hosted?', sv: 'Var hostar ni data?' },\n87\t  'faq.a4': { en: \"All data is stored within the EU. Screenshots are encrypted at rest. We never share data with third parties beyond what's required for the AI analysis.\", sv: 'All data lagras inom EU. Screenshots krypteras at rest. Vi delar aldrig data med tredje part utöver vad som krävs för AI-analysen.' },\n88\t  'footer.h2a': { en: 'Start monitoring your most', sv: 'Börja bevaka dina viktigaste' },\n89\t  'footer.h2b': { en: 'important pages', sv: 'sidor' },\n90\t  'footer.h2c': { en: 'today', sv: 'idag' },\n91\t  'footer.sub': { en: 'Free to get started. No credit card required.', sv: 'Gratis att komma igång. Inget kreditkort krävs.' },\n92\t  'footer.cta': { en: 'Create account — free', sv: 'Skapa konto — gratis' },\n93\t  'footer.docs': { en: 'Documentation', sv: 'Dokumentation' },\n94\t  'footer.privacy': { en: 'Privacy policy', sv: 'Integritetspolicy' },\n95\t  'footer.contact': { en: 'Contact', sv: 'Kontakt' },\n96\t\n97\t  // ─── Compliance landing page ───\n98\t  'reg.badge': { en: 'Built for compliance teams', sv: 'Byggd för compliance-team' },\n99\t  'reg.h1a': { en: 'Never miss a', sv: 'Missa aldrig en' },\n100\t  'reg.h1b': { en: 'regulatory change again', sv: 'regeländring igen' },\n101\t  'reg.sub': { en: 'changebrief monitors government agencies and regulators with AI — and tells you exactly what changed, whether it requires action, and which jurisdiction it affects.', sv: 'changebrief bevakar myndigheter och tillsynsorgan med AI — och berättar exakt vad som ändrades, om det kräver åtgärd och vilken jurisdiktion som berörs.' },\n102\t  'reg.cta1': { en: 'Start monitoring — free', sv: 'Börja bevaka — gratis' },\n103\t  'reg.cta2': { en: 'See how it works', sv: 'Se hur det funkar' },\n104\t\n105\t  'reg.problem.h2': { en: 'Your team is still checking agency websites manually', sv: 'Ert team kollar fortfarande myndighetssidor manuellt' },\n106\t  'reg.problem.sub': { en: 'Every day, someone opens 20+ tabs — Finansinspektionen, IMY, EBA, Transportstyrelsen — scrolls through pages that probably haven\\'t changed, and hopes nothing slipped through. Meanwhile, a guidance update was published yesterday that nobody noticed.', sv: 'Varje dag öppnar någon 20+ flikar — Finansinspektionen, IMY, EBA, Transportstyrelsen — scrollar genom sidor som förmodligen inte ändrats, och hoppas att inget missades. Under tiden publicerades en vägledningsuppdatering igår som ingen märkte.' },\n107\t  'reg.problem.before': { en: 'Without changebrief', sv: 'Utan changebrief' },\n108\t  'reg.problem.b1': { en: '5–10 hours/week spent on manual website checks', sv: '5–10 timmar/vecka spenderade på manuella webbkontroller' },\n109\t  'reg.problem.b2': { en: 'Changes missed between checks — discovered at the audit', sv: 'Ändringar missade mellan kontroller — upptäcks vid revisionen' },\n110\t  'reg.problem.b3': { en: 'No proof of when a change was published or who reviewed it', sv: 'Inga bevis för när en ändring publicerades eller vem som granskade den' },\n111\t  'reg.problem.b4': { en: 'One person leaves — and their monitoring knowledge goes with them', sv: 'En person slutar — och deras bevakningskunskap försvinner med dem' },\n112\t  'reg.problem.after': { en: 'With changebrief', sv: 'Med changebrief' },\n113\t  'reg.problem.a1': { en: 'Every agency checked every 6 hours, automatically', sv: 'Varje myndighet kontrollerad var 6:e timme, automatiskt' },\n114\t  'reg.problem.a2': { en: 'AI tells you: \"action required\" or \"just FYI\" — no guessing', sv: 'AI berättar: \"åtgärd krävs\" eller \"bara info\" — ingen gissning' },\n115\t  'reg.problem.a3': { en: 'Full audit trail: who reviewed what, when, with notes', sv: 'Komplett audit trail: vem granskade vad, när, med anteckningar' },\n116\t  'reg.problem.a4': { en: 'Team-proof: monitoring doesn\\'t depend on one person', sv: 'Teamsäker: bevakningen beror inte på en enskild person' },\n117\t\n118\t  'reg.feat.h2': { en: 'Built for regulatory intelligence', sv: 'Byggd för regulatorisk omvärldsbevakning' },\n119\t  'reg.feat.sub': { en: 'Replace spreadsheets and manual checks with AI-powered regulatory intelligence.', sv: 'Ersätt kalkylblad och manuella kontroller med AI-driven regulatorisk omvärldsbevakning.' },\n120\t  'reg.feat.classify.h': { en: 'AI compliance classification', sv: 'AI-driven compliance-klassificering' },\n121\t  'reg.feat.classify.p': { en: 'Every change is automatically classified: action required, review recommended, or info only. No more guessing.', sv: 'Varje ändring klassificeras automatiskt: åtgärd krävs, granskning rekommenderas, eller bara info. Slut på gissningar.' },\n122\t  'reg.feat.juris.h': { en: 'Jurisdiction tagging', sv: 'Jurisdiktions-taggning' },\n123\t  'reg.feat.juris.p': { en: 'Changes tagged by country and authority: Sweden, EU, US. Filter your feed by the jurisdictions that matter to you.', sv: 'Ändringar taggade per land och myndighet: Sverige, EU, USA. Filtrera ditt flöde på de jurisdiktioner som berör er.' },\n124\t  'reg.feat.doctype.h': { en: 'Document type detection', sv: 'Dokumenttyp-identifiering' },\n125\t  'reg.feat.doctype.p': { en: 'AI identifies whether the change is a regulation, guidance, consultation, decision, or standard — so you know how to prioritize.', sv: 'AI identifierar om ändringen gäller en föreskrift, vägledning, remiss, beslut eller standard — så ni vet hur den ska prioriteras.' },\n126\t  'reg.feat.audit.h': { en: 'Compliance audit trail', sv: 'Compliance audit trail' },\n127\t  'reg.feat.audit.p': { en: 'Every detected change timestamped and archived. Export filtered CSV for auditors — by jurisdiction, document type, or action level.', sv: 'Varje detekterad ändring tidsstämplas och arkiveras. Exportera filtrerad CSV till revisorer — per jurisdiktion, dokumenttyp eller åtgärdsnivå.' },\n128\t  'reg.feat.pre.h': { en: '60+ agencies across 5 countries', sv: '60+ myndigheter i 5 länder' },\n129\t  'reg.feat.pre.p': { en: 'One-click add Nordic, EU, and US agencies: Finansinspektionen, IMY, Socialstyrelsen, EBA, ESMA, EDPB, EMA, SEC, NIST, and more.', sv: 'Lägg till nordiska, EU- och amerikanska myndigheter med ett klick: Finansinspektionen, IMY, Socialstyrelsen, EBA, ESMA, EDPB, EMA, SEC, NIST med flera.' },\n130\t  'reg.feat.sector.h': { en: 'Sector-based watchlists', sv: 'Branschbaserade bevakningslistor' },\n131\t  'reg.feat.sector.p': { en: 'Pre-built lists for finance, health, transport, data privacy, environment, and labor. Add an entire sector in seconds.', sv: 'Färdiga listor för finans, hälsa, transport, dataskydd, miljö och arbetsmarknad. Lägg till en hel sektor på sekunder.' },\n132\t\n133\t  'reg.sectors.h2': { en: 'Pre-built watchlists for every sector', sv: 'Färdiga bevakningslistor för varje sektor' },\n134\t  'reg.sectors.sub': { en: 'Add an entire regulatory sector with one click.', sv: 'Lägg till en hel regulatorisk sektor med ett klick.' },\n135\t  'reg.sectors.finance': { en: 'Finance & Banking', sv: 'Finans & Bank' },\n136\t  'reg.sectors.finance.p': { en: 'Finansinspektionen, Riksbanken, EBA, ESMA, EIOPA, SEC', sv: 'Finansinspektionen, Riksbanken, EBA, ESMA, EIOPA, SEC' },\n137\t  'reg.sectors.health': { en: 'Health & Pharma', sv: 'Hälsa & Läkemedel' },\n138\t  'reg.sectors.health.p': { en: 'Socialstyrelsen, Läkemedelsverket, EMA, Folkhälsomyndigheten', sv: 'Socialstyrelsen, Läkemedelsverket, EMA, Folkhälsomyndigheten' },\n139\t  'reg.sectors.data': { en: 'Data & Privacy', sv: 'Data & Integritet' },\n140\t  'reg.sectors.data.p': { en: 'IMY, EDPB, PTS, DIGG, EU AI Act', sv: 'IMY, EDPB, PTS, DIGG, EU:s AI-förordning' },\n141\t  'reg.sectors.transport': { en: 'Transport & Infrastructure', sv: 'Transport & Infrastruktur' },\n142\t  'reg.sectors.transport.p': { en: 'Transportstyrelsen, Trafikverket, Jordbruksverket, HaV', sv: 'Transportstyrelsen, Trafikverket, Jordbruksverket, HaV' },\n143\t  'reg.sectors.env': { en: 'Environment & Energy', sv: 'Miljö & Energi' },\n144\t  'reg.sectors.env.p': { en: 'Naturvårdsverket, Energimyndigheten, KemI, ECHA', sv: 'Naturvårdsverket, Energimyndigheten, KemI, ECHA' },\n145\t  'reg.sectors.labor': { en: 'Labor & Workplace', sv: 'Arbetsmarknad & Arbetsmiljö' },\n146\t  'reg.sectors.labor.p': { en: 'Arbetsmiljöverket, MSB, Boverket', sv: 'Arbetsmiljöverket, MSB, Boverket' },\n147\t\n148\t  'reg.footer.h2a': { en: 'Stop checking websites manually.', sv: 'Sluta kolla webbsidor manuellt.' },\n149\t  'reg.footer.h2b': { en: 'Let AI watch', sv: 'Låt AI bevaka' },\n150\t  'reg.footer.h2c': { en: 'the regulators.', sv: 'myndigheterna.' },\n151\t  'reg.footer.sub': { en: 'Free to start. Monitor 3 agencies at no cost. Upgrade when you need more.', sv: 'Gratis att börja. Bevaka 3 myndigheter utan kostnad. Uppgradera när du behöver mer.' },\n152\t\n153\t  // ─── Why changebrief ───\n154\t  'reg.why.h2': { en: 'Why compliance teams are leaving traditional law monitoring', sv: 'Varför compliance-team lämnar traditionell lagbevakning' },\n155\t  'reg.why.web.h': { en: 'Changes appear on websites first — not in legal databases', sv: 'Ändringar syns på webbsidor först — inte i juridiska databaser' },\n156\t  'reg.why.web.p': { en: 'Updated guidance, new forms, revised requirements — they all appear on agency websites days before formal SFS or FFFS publication. Traditional tools miss this entirely. changebrief sees it the same day.', sv: 'Uppdaterade vägledningar, nya formulär, reviderade krav — allt syns på myndigheters webbsidor dagar före formell SFS- eller FFFS-publicering. Traditionella verktyg missar detta helt. changebrief ser det samma dag.' },\n157\t  'reg.why.ai.h': { en: 'AI classification in seconds — not jurist review in days', sv: 'AI-klassificering på sekunder — inte juristgranskning på dagar' },\n158\t  'reg.why.ai.p': { en: 'Every change is classified automatically: does it require action, review, or is it just informational? No waiting for a human to read and summarize. Consistent quality whether you monitor 5 or 500 sources.', sv: 'Varje ändring klassificeras automatiskt: kräver den åtgärd, granskning, eller är den bara information? Ingen väntan på att en människa ska läsa och sammanfatta. Konsekvent kvalitet oavsett om ni bevakar 5 eller 500 källor.' },\n159\t  'reg.why.open.h': { en: 'Plugs into your existing workflow — not another silo', sv: 'Kopplar in i ert befintliga arbetsflöde — inte ännu en silo' },\n160\t  'reg.why.open.p': { en: 'Get alerts in Slack, Teams, or email. Create Jira tickets automatically. Page on-call via PagerDuty. Subscribe via RSS. Export to CSV. No login required to stay informed.', sv: 'Få notiser i Slack, Teams eller e-post. Skapa Jira-ärenden automatiskt. Larma jour via PagerDuty. Prenumerera via RSS. Exportera till CSV. Ingen inloggning krävs för att hålla sig uppdaterad.' },\n161\t  'reg.why.api.h': { en: 'API-first — build on top, don\\'t depend on a portal', sv: 'API-first — bygg ovanpå, bli inte beroende av en portal' },\n162\t  'reg.why.api.p': { en: 'REST API, filtered RSS feeds, webhook payloads, CSV audit exports. Connect to Zapier, Make, n8n, or build custom integrations. Your compliance data, your way.', sv: 'REST API, filtrerade RSS-flöden, webhook-payloads, CSV audit-exporter. Koppla till Zapier, Make, n8n, eller bygg egna integrationer. Er compliance-data, på ert sätt.' },\n163\t\n164\t  // ─── ISO section ───\n165\t  'reg.iso.h2': { en: 'Built for ISO-certified organizations', sv: 'Byggd för ISO-certifierade organisationer' },\n166\t  'reg.iso.sub': { en: 'Whether you maintain ISO 14001, ISO 45001, or ISO 9001 — changebrief gives you the audit trail and acknowledgment workflow your certification requires.', sv: 'Oavsett om ni arbetar med ISO 14001, ISO 45001 eller ISO 9001 — changebrief ger er den audit trail och kvittenshantering som er certifiering kräver.' },\n167\t  'reg.iso.audit.h': { en: 'Audit-ready compliance trail', sv: 'Revisionsklar compliance trail' },\n168\t  'reg.iso.audit.p': { en: 'Every detected change timestamped and archived. Export filtered CSV reports for auditors — by jurisdiction, document type, or action level.', sv: 'Varje detekterad ändring tidsstämplad och arkiverad. Exportera filtrerade CSV-rapporter till revisorer — per jurisdiktion, dokumenttyp eller åtgärdsnivå.' },\n169\t  'reg.iso.kvittens.h': { en: 'Proof that every change was reviewed', sv: 'Bevis att varje ändring granskades' },\n170\t  'reg.iso.kvittens.p': { en: 'Mark changes as reviewed with your name and notes. When the auditor asks \"who reviewed this regulatory change and when?\" — you have the answer. Exportable.', sv: 'Markera ändringar som granskade med ditt namn och anteckningar. När revisorn frågar \"vem granskade denna regeländring och när?\" — har ni svaret. Exporterbart.' },\n171\t  'reg.iso.overview.h': { en: 'Real-time regulatory overview', sv: 'Regulatorisk översikt i realtid' },\n172\t  'reg.iso.overview.p': { en: 'See all monitored authorities in one table: last change, action level, review status. Sortable, filterable, printable for board meetings.', sv: 'Se alla bevakade myndigheter i en tabell: senaste ändring, åtgärdsnivå, granskningsstatus. Sorterbar, filtrerbar, utskriftsvänlig för styrelsemöten.' },\n173\t\n174\t  // ─── Beyond legislation ───\n175\t  'reg.beyond.h2': { en: 'What your current tool can\\'t see', sv: 'Vad ert nuvarande verktyg inte kan se' },\n176\t  'reg.beyond.visual.h': { en: 'Visual changes on government websites', sv: 'Visuella förändringar på myndighetssidor' },\n177\t  'reg.beyond.visual.p': { en: 'New guidance documents, updated forms, changed requirements — all caught by AI-powered visual monitoring before they become formal publications.', sv: 'Nya vägledningsdokument, uppdaterade formulär, ändrade krav — allt fångat av AI-driven visuell bevakning innan de blir formella publiceringar.' },\n178\t  'reg.beyond.guidance.h': { en: 'Guidance and interpretive notices', sv: 'Vägledningar och tolkningsbesked' },\n179\t  'reg.beyond.guidance.p': { en: 'Not just SFS and FFFS — we monitor the practical guidance that shapes how regulations are applied in your industry.', sv: 'Inte bara SFS och FFFS — vi bevakar den praktiska vägledning som styr hur regler tillämpas i er bransch.' },\n180\t  'reg.beyond.intl.h': { en: 'International coverage beyond the Nordics', sv: 'Internationell täckning bortom Norden' },\n181\t  'reg.beyond.intl.p': { en: 'Monitor EU agencies (EBA, ESMA, EDPB, EMA), US regulators (SEC, NIST), and more. One dashboard for all your jurisdictions.', sv: 'Bevaka EU-myndigheter (EBA, ESMA, EDPB, EMA), amerikanska tillsynsmyndigheter (SEC, NIST) och fler. En dashboard för alla era jurisdiktioner.' },\n182\t\n183\t  // ─── Numbers strip ───\n184\t  'reg.proof.authorities': { en: '60+ authorities', sv: '60+ myndigheter' },\n185\t  'reg.proof.sectors': { en: '8 sectors', sv: '8 sektorer' },\n186\t  'reg.proof.countries': { en: '5 countries', sv: '5 länder' },\n187\t  'reg.proof.integrations': { en: '9 integrations', sv: '9 integrationer' },\n188\t\n189\t  // ─── Compliance FAQ ───\n190\t  // ─── How it works (compliance) ───\n191\t  'reg.how.h2': { en: 'How it works', sv: 'Så fungerar det' },\n192\t  'reg.how.sub': { en: 'From setup to compliance insights in under 60 seconds.', sv: 'Från setup till compliance-insikter på under 60 sekunder.' },\n193\t  'reg.how.s1': { en: 'Step 1', sv: 'Steg 1' },\n194\t  'reg.how.s1.h': { en: 'Pick your authorities', sv: 'Välj era myndigheter' },\n195\t  'reg.how.s1.p': { en: 'Select jurisdiction and sector — we recommend 60+ pre-configured agencies across Sweden, Denmark, Norway, Finland, the EU, and the US.', sv: 'Välj jurisdiktion och sektor — vi rekommenderar 60+ förkonfigurerade myndigheter i Sverige, Danmark, Norge, Finland, EU och USA.' },\n196\t  'reg.how.s2': { en: 'Step 2', sv: 'Steg 2' },\n197\t  'reg.how.s2.h': { en: 'AI monitors 24/7', sv: 'AI bevakar dygnet runt' },\n198\t  'reg.how.s2.p': { en: 'Every 6 hours, our AI takes screenshots, detects changes, and classifies them: action required, review recommended, or info only.', sv: 'Var 6:e timme tar vår AI screenshots, upptäcker ändringar och klassificerar dem: åtgärd krävs, granskning rekommenderas, eller bara info.' },\n199\t  'reg.how.s3': { en: 'Step 3', sv: 'Steg 3' },\n200\t  'reg.how.s3.h': { en: 'Review and comply', sv: 'Granska och agera' },\n201\t  'reg.how.s3.p': { en: 'Get notified via Slack, email, or Teams. Mark changes as reviewed with your name. Export audit trails for your ISO auditor.', sv: 'Bli notifierad via Slack, e-post eller Teams. Markera ändringar som granskade med ditt namn. Exportera audit trails till er ISO-revisor.' },\n202\t\n203\t  'reg.faq.h2': { en: 'Questions from compliance teams', sv: 'Frågor från compliance-team' },\n204\t  'reg.faq.q1': { en: 'How is this different from traditional law monitoring tools?', sv: 'Hur skiljer sig detta från traditionella lagbevakningsverktyg?' },\n205\t  'reg.faq.a1': { en: 'Three key differences: (1) We monitor the actual agency websites where changes appear first — not just legal databases that update days later. (2) AI classifies every change in seconds — no waiting for a jurist to write a summary. (3) We\\'re API-first: Slack, Teams, Jira, PagerDuty, RSS, webhooks, CSV — not a closed portal you have to log into.', sv: 'Tre nyckelskillnader: (1) Vi bevakar de faktiska myndighetssidorna där ändringar syns först — inte bara juridiska databaser som uppdateras dagar senare. (2) AI klassificerar varje ändring på sekunder — ingen väntan på att en jurist ska skriva en sammanfattning. (3) Vi är API-first: Slack, Teams, Jira, PagerDuty, RSS, webhooks, CSV — inte en stängd portal man måste logga in i.' },\n206\t  'reg.faq.q2': { en: 'Can I use changebrief for ISO 14001/45001 compliance?', sv: 'Kan jag använda changebrief för ISO 14001/45001-efterlevnad?' },\n207\t  'reg.faq.a2': { en: 'Yes. changebrief provides timestamped audit trails, reviewer attribution (who reviewed what and when), and CSV export — all evidence your ISO auditor needs. The acknowledgment workflow tracks that every regulatory change has been reviewed by the responsible person.', sv: 'Ja. changebrief ger tidsstämplade audit trails, granskningsattribution (vem som granskade vad och när) och CSV-export — alla bevis er ISO-revisor behöver. Kvittensflödet spårar att varje regeländring har granskats av ansvarig person.' },\n208\t  'reg.faq.q3': { en: 'Which countries and authorities do you cover?', sv: 'Vilka länder och myndigheter täcker ni?' },\n209\t  'reg.faq.a3': { en: 'We have 60+ pre-configured authorities across Sweden, Denmark, Norway, Finland, the EU, and the US. This includes Finansinspektionen, IMY, Transportstyrelsen, EBA, ESMA, EDPB, SEC, and many more. You can also add any custom URL — if it has a webpage, we can monitor it.', sv: 'Vi har 60+ förkonfigurerade myndigheter i Sverige, Danmark, Norge, Finland, EU och USA. Det inkluderar Finansinspektionen, IMY, Transportstyrelsen, EBA, ESMA, EDPB, SEC och många fler. Du kan också lägga till valfri URL — om den har en webbsida kan vi bevaka den.' },\n210\t  'reg.faq.q4': { en: 'How often are pages checked?', sv: 'Hur ofta kontrolleras sidorna?' },\n211\t  'reg.faq.a4': { en: 'Every 6 hours, 24/7. When a change is detected, you\\'re notified immediately via your chosen channels (email, Slack, Teams, etc.). Weekly/daily digest summaries are also available.', sv: 'Var 6:e timme, dygnet runt. När en ändring upptäcks notifieras du direkt via dina valda kanaler (e-post, Slack, Teams etc.). Vecko-/dagliga sammanfattningar finns också tillgängliga.' },\n212\t} as const;\n213\t\n214\texport type LandingKey = keyof typeof landing;\n215\t\n216\texport function lt(key: LandingKey, lang: Lang): string {\n217\t  return landing[key]?.[lang] ?? landing[key]?.en ?? key;\n218\t}\n219\t"}]},"parent_tool_use_id":null,"session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"321e0288-ad12-499d-a95d-3f78c9538edf","timestamp":"2026-04-18T21:24:56.986Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wigclaw/overnight-work/changebrief-night-improve/landing/src/i18n.ts","content":"export type Lang = 'en' | 'sv';\n\nexport const landing = {\n  'header.cta': { en: 'Get started free', sv: 'Kom igång gratis' },\n  'hero.badge': { en: 'Know what changed in plain English', sv: 'Vet vad som ändrades — på ren svenska' },\n  'hero.h1a': { en: 'See what changed', sv: 'Se vad som ändrades' },\n  'hero.h1b': { en: 'not just that something changed', sv: 'inte bara att något ändrades' },\n  'hero.sub': { en: 'changebrief monitors web pages and uses AI to tell you exactly what happened. No blurry screenshots. No red pixels. Just a clear sentence.', sv: 'changebrief bevakar webbsidor och berättar med AI exakt vad som hände. Inga suddiga screenshots. Inga röda pixlar. Bara en tydlig mening.' },\n  'hero.cta1': { en: 'Get started free', sv: 'Kom igång gratis' },\n  'hero.cta2': { en: 'See how it works', sv: 'Se hur det funkar' },\n  'hero.demo.text': { en: 'Acme Corp removed the', sv: 'Acme Corp tog bort' },\n  'hero.demo.btn': { en: 'Free for 14 days', sv: 'Gratis i 14 dagar' },\n  'hero.demo.raised': { en: 'button and raised the Pro price from', sv: '-knappen och höjde Pro-priset från' },\n  'hero.demo.to': { en: 'to', sv: 'till' },\n  'problem.h2': { en: 'Existing tools show you', sv: 'Befintliga verktyg visar dig' },\n  'problem.h2b': { en: 'this...', sv: 'det här...' },\n  'problem.sub': { en: \"You shouldn't have to interpret screenshots. AI does it for you.\", sv: 'Du ska inte behöva tolka screenshots. AI gör det åt dig.' },\n  'problem.other': { en: 'Other tools', sv: 'Andra verktyg' },\n  'problem.q': { en: 'Something changed... but what?', sv: 'Något har ändrats... men vad?' },\n  'problem.clear': { en: 'Crystal clear. Straight to Slack.', sv: 'Kristallklart. Direkt i Slack.' },\n  'how.h2': { en: 'How it works', sv: 'Så funkar det' },\n  'how.sub': { en: 'Three steps. No code.', sv: 'Tre steg. Ingen kod.' },\n  'how.s1': { en: 'Step 1', sv: 'Steg 1' },\n  'how.s1.h': { en: 'Add a URL', sv: 'Lägg till en URL' },\n  'how.s1.p': { en: 'Paste the page you want to monitor. Pricing page, terms of service, status page — anything.', sv: 'Klistra in sidan du vill bevaka. Prissida, villkor, statusesida — vad som helst.' },\n  'how.s2': { en: 'Step 2', sv: 'Steg 2' },\n  'how.s2.h': { en: 'We take screenshots automatically', sv: 'Vi tar screenshots automatiskt' },\n  'how.s2.p': { en: 'A headless browser runs in the background and captures exactly how the page looks — every hour, day, or week.', sv: 'Headless browser kör i bakgrunden och fångar exakt hur sidan ser ut — varje timme, dag eller vecka.' },\n  'how.s3': { en: 'Step 3', sv: 'Steg 3' },\n  'how.s3.h': { en: 'AI tells you what changed', sv: 'AI berättar vad som ändrades' },\n  'how.s3.p': { en: 'AI vision compares before and after, and sends a clear summary to Slack, Teams, or email.', sv: 'AI vision jämför före och efter, och skickar en tydlig sammanfattning till Slack, Teams eller e-post.' },\n  'use.h2': { en: 'Use cases', sv: 'Användningsområden' },\n  'use.sub': { en: 'One tool. Dozens of high-value applications.', sv: 'Ett verktyg. Massor av värdefulla användningsområden.' },\n  'use.comp.h': { en: 'Competitor pricing', sv: 'Konkurrentpriser' },\n  'use.comp.p': { en: 'Know within hours when a competitor changes pricing, removes a free tier, or adds a new plan. React the same day instead of next quarter.', sv: 'Vet inom timmar när en konkurrent ändrar priser, tar bort en gratisplan eller lägger till en ny nivå. Reagera samma dag istället för nästa kvartal.' },\n  'use.reg.h': { en: 'Regulatory changes', sv: 'Regeländringar' },\n  'use.reg.p': { en: 'Monitor government agencies and regulators for policy updates, new rules, or changed requirements that affect your industry.', sv: 'Bevaka myndigheter och tillsynsorgan för policyuppdateringar, nya regler eller ändrade krav som påverkar din bransch.' },\n  'use.vendor.h': { en: 'SaaS terms & contracts', sv: 'SaaS-villkor & avtal' },\n  'use.vendor.p': { en: \"Catch silent changes to terms of service, privacy policies, or SLAs from vendors you depend on — before your renewal date.\", sv: 'Fånga tysta ändringar i användarvillkor, integritetspolicyer eller SLA:er hos leverantörer ni är beroende av — innan förnyelsedatumet.' },\n  'use.hiring.h': { en: 'Hiring & strategy intel', sv: 'Rekrytering & strategi-intel' },\n  'use.hiring.p': { en: \"Watch competitor career pages. When they start hiring ML engineers or enterprise sales reps, you know where they're heading next.\", sv: 'Bevaka konkurrenters karriärsidor. När de börjar anställa ML-ingenjörer eller enterprise-säljare vet du vart de är på väg.' },\n  'use.ecom.h': { en: 'Supplier & MAP pricing', sv: 'Leverantörs- & MAP-priser' },\n  'use.ecom.p': { en: 'Track supplier prices, wholesale catalogs, or MAP compliance across resellers. Catch price drops before your competitors do.', sv: 'Följ leverantörspriser, grossistkataloger eller MAP-efterlevnad hos återförsäljare. Fånga prissänkningar innan konkurrenterna.' },\n  'use.site.h': { en: 'Your own site integrity', sv: 'Er egen sajts integritet' },\n  'use.site.p': { en: 'Detect accidental deploys, defacement, SEO spam injection, or broken layouts on your own pages — before customers see them.', sv: 'Upptäck oavsiktliga deployar, defacement, SEO-spam eller trasiga layouts på era egna sidor — innan kunderna ser dem.' },\n  'feat.h2': { en: 'Features', sv: 'Funktioner' },\n  'feat.sub': { en: 'What sets changebrief apart from pixel-diff tools.', sv: 'Det som skiljer changebrief från pixeldiff-verktyg.' },\n  'feat.ai': { en: 'AI-powered summaries', sv: 'AI-drivna sammanfattningar' },\n  'feat.ai.p': { en: \"AI vision understands what's shown — prices, buttons, text. Not just pixels.\", sv: 'AI vision förstår vad som visas — priser, knappar, text. Inte bara pixlar.' },\n  'feat.score': { en: 'Importance score (1-10)', sv: 'Viktighetspoäng (1-10)' },\n  'feat.score.p': { en: 'Filter out noise. Only get notified about important changes — pricing, features, terms.', sv: 'Filtrera brus. Få bara notiser vid viktiga ändringar — pris, features, villkor.' },\n  'feat.slack': { en: 'Slack, Teams & Discord', sv: 'Slack, Teams & Discord' },\n  'feat.slack.p': { en: 'Notifications straight to the channel your team already uses. Plus PagerDuty, Jira, and webhooks.', sv: 'Notiser direkt i kanalen ditt team redan använder. Plus PagerDuty, Jira och webhooks.' },\n  'feat.sched': { en: 'Scheduled monitoring', sv: 'Schemalagd bevakning' },\n  'feat.sched.p': { en: 'Every hour, day, or week. You decide. We run in the background.', sv: 'Varje timme, dag eller vecka. Du bestämmer. Vi kör i bakgrunden.' },\n  'feat.hist': { en: 'Screenshot history', sv: 'Screenshot-historik' },\n  'feat.hist.p': { en: 'See exactly how a page looked a day, week, or month ago. Visual timeline.', sv: 'Se exakt hur sidan såg ut för en dag, vecka eller månad sedan. Visuell tidslinje.' },\n  'feat.api': { en: 'REST API & Webhooks', sv: 'REST API & Webhooks' },\n  'feat.api.p': { en: 'Connect to Zapier, Make, n8n, or build your own integration. JSON payload on every change.', sv: 'Koppla till Zapier, Make, n8n eller bygg din egen integration. JSON-payload vid varje ändring.' },\n  'price.h2': { en: 'Simple pricing', sv: 'Enkel prissättning' },\n  'price.sub': { en: 'Start free. Upgrade when you need more.', sv: 'Börja gratis. Uppgradera när du behöver mer.' },\n  'price.free.desc': { en: 'Try it at no cost.', sv: 'Testa utan kostnad.' },\n  'price.free.cta': { en: 'Get started free', sv: 'Kom igång gratis' },\n  'price.popular': { en: 'Most popular', sv: 'Populärast' },\n  'price.pro.desc': { en: '25 pages, Slack notifications, 90 days of history.', sv: '25 sidor, Slack-notiser, 90 dagars historik.' },\n  'price.pro.cta': { en: 'Start Pro', sv: 'Starta Pro' },\n  'price.team.desc': { en: '100 pages, all integrations, API access.', sv: '100 sidor, alla integrationer, API-åtkomst.' },\n  'price.team.cta': { en: 'Start Team', sv: 'Starta Team' },\n  'price.or': { en: 'or', sv: 'eller' },\n  'price.save': { en: 'save 17%', sv: 'spara 17%' },\n  'price.mo': { en: '/mo', sv: '/mån' },\n  'price.year': { en: '/year', sv: '/år' },\n  'price.pages': { en: 'monitored pages', sv: 'bevakade sidor' },\n  'price.checks': { en: 'checks/mo', sv: 'kontroller/mån' },\n  'price.days': { en: 'days of history', sv: 'dagars historik' },\n  'price.schedule15': { en: 'Schedule every 15 minutes', sv: 'Schemalägg var 15:e minut' },\n  'price.everything': { en: 'Everything in Pro', sv: 'Allt i Pro' },\n  'price.1year': { en: '1 year history, 5 users', sv: '1 år historik, 5 användare' },\n  'faq.h2': { en: 'Frequently asked questions', sv: 'Vanliga frågor' },\n  'faq.q1': { en: 'How is changebrief different from Visualping?', sv: 'Hur skiljer sig changebrief från Visualping?' },\n  'faq.a1': { en: 'Visualping shows you an image with red pixels where something changed. You have to figure out what it means yourself. changebrief sends the screenshot pair to AI vision and returns a sentence describing exactly what changed — \"Price increased from $29 to $39/mo\" instead of a red blob.', sv: 'Visualping visar en bild med röda pixlar där något ändrats. Du måste själv tolka vad det betyder. changebrief skickar bildparet till AI vision och returnerar en mening som beskriver exakt vad som ändrades — \"Priset höjdes från $29 till $39/mån\" istället för en röd fläck.' },\n  'faq.q2': { en: 'How accurate are the summaries?', sv: 'Hur träffsäkra är sammanfattningarna?' },\n  'faq.a2': { en: \"We use state-of-the-art vision AI that understands what's displayed on a web page — prices, buttons, text, layouts. It compares two versions of the same page and describes exactly what changed in plain language. The importance score (1-10) helps you filter noise from signal.\", sv: 'Vi använder toppmodern vision-AI som förstår vad som visas på en webbsida — priser, knappar, text, layouter. Den jämför två versioner av samma sida och beskriver exakt vad som ändrades i klartext. Viktighetspoängen (1-10) hjälper dig filtrera brus från signal.' },\n  'faq.q3': { en: 'Can I monitor pages behind a login?', sv: 'Kan jag bevaka sidor bakom login?' },\n  'faq.a3': { en: 'Yes! You can configure cookies and HTTP headers per URL. This makes it possible to monitor pages that require authentication, such as internal dashboards or customer portals.', sv: 'Ja! Du kan konfigurera cookies och HTTP-headers per URL. Det gör det möjligt att bevaka sidor som kräver autentisering, t.ex. interna dashboards eller kund-portaler.' },\n  'faq.q4': { en: 'Where is data hosted?', sv: 'Var hostar ni data?' },\n  'faq.a4': { en: \"All data is stored within the EU. Screenshots are encrypted at rest. We never share data with third parties beyond what's required for the AI analysis.\", sv: 'All data lagras inom EU. Screenshots krypteras at rest. Vi delar aldrig data med tredje part utöver vad som krävs för AI-analysen.' },\n  'footer.h2a': { en: 'Start monitoring your most', sv: 'Börja bevaka dina viktigaste' },\n  'footer.h2b': { en: 'important pages', sv: 'sidor' },\n  'footer.h2c': { en: 'today', sv: 'idag' },\n  'footer.sub': { en: 'Free to get started. No credit card required.', sv: 'Gratis att komma igång. Inget kreditkort krävs.' },\n  'footer.cta': { en: 'Create account — free', sv: 'Skapa konto — gratis' },\n  'footer.docs': { en: 'Documentation', sv: 'Dokumentation' },\n  'footer.privacy': { en: 'Privacy policy', sv: 'Integritetspolicy' },\n  'footer.contact': { en: 'Contact', sv: 'Kontakt' },\n\n  // ─── Compliance landing page ───\n  'reg.badge': { en: 'Built for compliance teams', sv: 'Byggd för compliance-team' },\n  'reg.h1a': { en: 'Never miss a', sv: 'Missa aldrig en' },\n  'reg.h1b': { en: 'regulatory change again', sv: 'regeländring igen' },\n  'reg.sub': { en: 'changebrief monitors government agencies and regulators with AI — and tells you exactly what changed, whether it requires action, and which jurisdiction it affects.', sv: 'changebrief bevakar myndigheter och tillsynsorgan med AI — och berättar exakt vad som ändrades, om det kräver åtgärd och vilken jurisdiktion som berörs.' },\n  'reg.cta1': { en: 'Start monitoring — free', sv: 'Börja bevaka — gratis' },\n  'reg.cta2': { en: 'See how it works', sv: 'Se hur det funkar' },\n\n  'reg.problem.h2': { en: 'Your team is still checking agency websites manually', sv: 'Ert team kollar fortfarande myndighetssidor manuellt' },\n  'reg.problem.sub': { en: 'Every day, someone opens 20+ tabs — Finansinspektionen, IMY, EBA, Transportstyrelsen — scrolls through pages that probably haven\\'t changed, and hopes nothing slipped through. Meanwhile, a guidance update was published yesterday that nobody noticed.', sv: 'Varje dag öppnar någon 20+ flikar — Finansinspektionen, IMY, EBA, Transportstyrelsen — scrollar genom sidor som förmodligen inte ändrats, och hoppas att inget missades. Under tiden publicerades en vägledningsuppdatering igår som ingen märkte.' },\n  'reg.problem.before': { en: 'Without changebrief', sv: 'Utan changebrief' },\n  'reg.problem.b1': { en: '5–10 hours/week spent on manual website checks', sv: '5–10 timmar/vecka spenderade på manuella webbkontroller' },\n  'reg.problem.b2': { en: 'Changes missed between checks — discovered at the audit', sv: 'Ändringar missade mellan kontroller — upptäcks vid revisionen' },\n  'reg.problem.b3': { en: 'No proof of when a change was published or who reviewed it', sv: 'Inga bevis för när en ändring publicerades eller vem som granskade den' },\n  'reg.problem.b4': { en: 'One person leaves — and their monitoring knowledge goes with them', sv: 'En person slutar — och deras bevakningskunskap försvinner med dem' },\n  'reg.problem.after': { en: 'With changebrief', sv: 'Med changebrief' },\n  'reg.problem.a1': { en: 'Every agency checked every 6 hours, automatically', sv: 'Varje myndighet kontrollerad var 6:e timme, automatiskt' },\n  'reg.problem.a2': { en: 'AI tells you: \"action required\" or \"just FYI\" — no guessing', sv: 'AI berättar: \"åtgärd krävs\" eller \"bara info\" — ingen gissning' },\n  'reg.problem.a3': { en: 'Full audit trail: who reviewed what, when, with notes', sv: 'Komplett audit trail: vem granskade vad, när, med anteckningar' },\n  'reg.problem.a4': { en: 'Team-proof: monitoring doesn\\'t depend on one person', sv: 'Teamsäker: bevakningen beror inte på en enskild person' },\n\n  'reg.feat.h2': { en: 'Built for regulatory intelligence', sv: 'Byggd för regulatorisk omvärldsbevakning' },\n  'reg.feat.sub': { en: 'Replace spreadsheets and manual checks with AI-powered regulatory intelligence.', sv: 'Ersätt kalkylblad och manuella kontroller med AI-driven regulatorisk omvärldsbevakning.' },\n  'reg.feat.classify.h': { en: 'AI compliance classification', sv: 'AI-driven compliance-klassificering' },\n  'reg.feat.classify.p': { en: 'Every change is automatically classified: action required, review recommended, or info only. No more guessing.', sv: 'Varje ändring klassificeras automatiskt: åtgärd krävs, granskning rekommenderas, eller bara info. Slut på gissningar.' },\n  'reg.feat.juris.h': { en: 'Jurisdiction tagging', sv: 'Jurisdiktions-taggning' },\n  'reg.feat.juris.p': { en: 'Changes tagged by country and authority: Sweden, EU, US. Filter your feed by the jurisdictions that matter to you.', sv: 'Ändringar taggade per land och myndighet: Sverige, EU, USA. Filtrera ditt flöde på de jurisdiktioner som berör er.' },\n  'reg.feat.doctype.h': { en: 'Document type detection', sv: 'Dokumenttyp-identifiering' },\n  'reg.feat.doctype.p': { en: 'AI identifies whether the change is a regulation, guidance, consultation, decision, or standard — so you know how to prioritize.', sv: 'AI identifierar om ändringen gäller en föreskrift, vägledning, remiss, beslut eller standard — så ni vet hur den ska prioriteras.' },\n  'reg.feat.audit.h': { en: 'Compliance audit trail', sv: 'Compliance audit trail' },\n  'reg.feat.audit.p': { en: 'Every detected change timestamped and archived. Export filtered CSV for auditors — by jurisdiction, document type, or action level.', sv: 'Varje detekterad ändring tidsstämplas och arkiveras. Exportera filtrerad CSV till revisorer — per jurisdiktion, dokumenttyp eller åtgärdsnivå.' },\n  'reg.feat.pre.h': { en: '60+ agencies across 5 countries', sv: '60+ myndigheter i 5 länder' },\n  'reg.feat.pre.p': { en: 'One-click add Nordic, EU, and US agencies: Finansinspektionen, IMY, Socialstyrelsen, EBA, ESMA, EDPB, EMA, SEC, NIST, and more.', sv: 'Lägg till nordiska, EU- och amerikanska myndigheter med ett klick: Finansinspektionen, IMY, Socialstyrelsen, EBA, ESMA, EDPB, EMA, SEC, NIST med flera.' },\n  'reg.feat.sector.h': { en: 'Sector-based watchlists', sv: 'Branschbaserade bevakningslistor' },\n  'reg.feat.sector.p': { en: 'Pre-built lists for finance, health, transport, data privacy, environment, and labor. Add an entire sector in seconds.', sv: 'Färdiga listor för finans, hälsa, transport, dataskydd, miljö och arbetsmarknad. Lägg till en hel sektor på sekunder.' },\n\n  'reg.sectors.h2': { en: 'Pre-built watchlists for every sector', sv: 'Färdiga bevakningslistor för varje sektor' },\n  'reg.sectors.sub': { en: 'Add an entire regulatory sector with one click.', sv: 'Lägg till en hel regulatorisk sektor med ett klick.' },\n  'reg.sectors.finance': { en: 'Finance & Banking', sv: 'Finans & Bank' },\n  'reg.sectors.finance.p': { en: 'Finansinspektionen, Riksbanken, EBA, ESMA, EIOPA, SEC', sv: 'Finansinspektionen, Riksbanken, EBA, ESMA, EIOPA, SEC' },\n  'reg.sectors.health': { en: 'Health & Pharma', sv: 'Hälsa & Läkemedel' },\n  'reg.sectors.health.p': { en: 'Socialstyrelsen, Läkemedelsverket, EMA, Folkhälsomyndigheten', sv: 'Socialstyrelsen, Läkemedelsverket, EMA, Folkhälsomyndigheten' },\n  'reg.sectors.data': { en: 'Data & Privacy', sv: 'Data & Integritet' },\n  'reg.sectors.data.p': { en: 'IMY, EDPB, PTS, DIGG, EU AI Act', sv: 'IMY, EDPB, PTS, DIGG, EU:s AI-förordning' },\n  'reg.sectors.transport': { en: 'Transport & Infrastructure', sv: 'Transport & Infrastruktur' },\n  'reg.sectors.transport.p': { en: 'Transportstyrelsen, Trafikverket, Jordbruksverket, HaV', sv: 'Transportstyrelsen, Trafikverket, Jordbruksverket, HaV' },\n  'reg.sectors.env': { en: 'Environment & Energy', sv: 'Miljö & Energi' },\n  'reg.sectors.env.p': { en: 'Naturvårdsverket, Energimyndigheten, KemI, ECHA', sv: 'Naturvårdsverket, Energimyndigheten, KemI, ECHA' },\n  'reg.sectors.labor': { en: 'Labor & Workplace', sv: 'Arbetsmarknad & Arbetsmiljö' },\n  'reg.sectors.labor.p': { en: 'Arbetsmiljöverket, MSB, Boverket', sv: 'Arbetsmiljöverket, MSB, Boverket' },\n\n  'reg.footer.h2a': { en: 'Stop checking websites manually.', sv: 'Sluta kolla webbsidor manuellt.' },\n  'reg.footer.h2b': { en: 'Let AI watch', sv: 'Låt AI bevaka' },\n  'reg.footer.h2c': { en: 'the regulators.', sv: 'myndigheterna.' },\n  'reg.footer.sub': { en: 'Free to start. Monitor 3 agencies at no cost. Upgrade when you need more.', sv: 'Gratis att börja. Bevaka 3 myndigheter utan kostnad. Uppgradera när du behöver mer.' },\n\n  // ─── Why changebrief ───\n  'reg.why.h2': { en: 'Why compliance teams are leaving traditional law monitoring', sv: 'Varför compliance-team lämnar traditionell lagbevakning' },\n  'reg.why.web.h': { en: 'Changes appear on websites first — not in legal databases', sv: 'Ändringar syns på webbsidor först — inte i juridiska databaser' },\n  'reg.why.web.p': { en: 'Updated guidance, new forms, revised requirements — they all appear on agency websites days before formal SFS or FFFS publication. Traditional tools miss this entirely. changebrief sees it the same day.', sv: 'Uppdaterade vägledningar, nya formulär, reviderade krav — allt syns på myndigheters webbsidor dagar före formell SFS- eller FFFS-publicering. Traditionella verktyg missar detta helt. changebrief ser det samma dag.' },\n  'reg.why.ai.h': { en: 'AI classification in seconds — not jurist review in days', sv: 'AI-klassificering på sekunder — inte juristgranskning på dagar' },\n  'reg.why.ai.p': { en: 'Every change is classified automatically: does it require action, review, or is it just informational? No waiting for a human to read and summarize. Consistent quality whether you monitor 5 or 500 sources.', sv: 'Varje ändring klassificeras automatiskt: kräver den åtgärd, granskning, eller är den bara information? Ingen väntan på att en människa ska läsa och sammanfatta. Konsekvent kvalitet oavsett om ni bevakar 5 eller 500 källor.' },\n  'reg.why.open.h': { en: 'Plugs into your existing workflow — not another silo', sv: 'Kopplar in i ert befintliga arbetsflöde — inte ännu en silo' },\n  'reg.why.open.p': { en: 'Get alerts in Slack, Teams, or email. Create Jira tickets automatically. Page on-call via PagerDuty. Subscribe via RSS. Export to CSV. No login required to stay informed.', sv: 'Få notiser i Slack, Teams eller e-post. Skapa Jira-ärenden automatiskt. Larma jour via PagerDuty. Prenumerera via RSS. Exportera till CSV. Ingen inloggning krävs för att hålla sig uppdaterad.' },\n  'reg.why.api.h': { en: 'API-first — build on top, don\\'t depend on a portal', sv: 'API-first — bygg ovanpå, bli inte beroende av en portal' },\n  'reg.why.api.p': { en: 'REST API, filtered RSS feeds, webhook payloads, CSV audit exports. Connect to Zapier, Make, n8n, or build custom integrations. Your compliance data, your way.', sv: 'REST API, filtrerade RSS-flöden, webhook-payloads, CSV audit-exporter. Koppla till Zapier, Make, n8n, eller bygg egna integrationer. Er compliance-data, på ert sätt.' },\n\n  // ─── ISO section ───\n  'reg.iso.h2': { en: 'Built for ISO-certified organizations', sv: 'Byggd för ISO-certifierade organisationer' },\n  'reg.iso.sub': { en: 'Whether you maintain ISO 14001, ISO 45001, or ISO 9001 — changebrief gives you the audit trail and acknowledgment workflow your certification requires.', sv: 'Oavsett om ni arbetar med ISO 14001, ISO 45001 eller ISO 9001 — changebrief ger er den audit trail och kvittenshantering som er certifiering kräver.' },\n  'reg.iso.audit.h': { en: 'Audit-ready compliance trail', sv: 'Revisionsklar compliance trail' },\n  'reg.iso.audit.p': { en: 'Every detected change timestamped and archived. Export filtered CSV reports for auditors — by jurisdiction, document type, or action level.', sv: 'Varje detekterad ändring tidsstämplad och arkiverad. Exportera filtrerade CSV-rapporter till revisorer — per jurisdiktion, dokumenttyp eller åtgärdsnivå.' },\n  'reg.iso.kvittens.h': { en: 'Proof that every change was reviewed', sv: 'Bevis att varje ändring granskades' },\n  'reg.iso.kvittens.p': { en: 'Mark changes as reviewed with your name and notes. When the auditor asks \"who reviewed this regulatory change and when?\" — you have the answer. Exportable.', sv: 'Markera ändringar som granskade med ditt namn och anteckningar. När revisorn frågar \"vem granskade denna regeländring och när?\" — har ni svaret. Exporterbart.' },\n  'reg.iso.overview.h': { en: 'Real-time regulatory overview', sv: 'Regulatorisk översikt i realtid' },\n  'reg.iso.overview.p': { en: 'See all monitored authorities in one table: last change, action level, review status. Sortable, filterable, printable for board meetings.', sv: 'Se alla bevakade myndigheter i en tabell: senaste ändring, åtgärdsnivå, granskningsstatus. Sorterbar, filtrerbar, utskriftsvänlig för styrelsemöten.' },\n\n  // ─── Beyond legislation ───\n  'reg.beyond.h2': { en: 'What your current tool can\\'t see', sv: 'Vad ert nuvarande verktyg inte kan se' },\n  'reg.beyond.visual.h': { en: 'Visual changes on government websites', sv: 'Visuella förändringar på myndighetssidor' },\n  'reg.beyond.visual.p': { en: 'New guidance documents, updated forms, changed requirements — all caught by AI-powered visual monitoring before they become formal publications.', sv: 'Nya vägledningsdokument, uppdaterade formulär, ändrade krav — allt fångat av AI-driven visuell bevakning innan de blir formella publiceringar.' },\n  'reg.beyond.guidance.h': { en: 'Guidance and interpretive notices', sv: 'Vägledningar och tolkningsbesked' },\n  'reg.beyond.guidance.p': { en: 'Not just SFS and FFFS — we monitor the practical guidance that shapes how regulations are applied in your industry.', sv: 'Inte bara SFS och FFFS — vi bevakar den praktiska vägledning som styr hur regler tillämpas i er bransch.' },\n  'reg.beyond.intl.h': { en: 'International coverage beyond the Nordics', sv: 'Internationell täckning bortom Norden' },\n  'reg.beyond.intl.p': { en: 'Monitor EU agencies (EBA, ESMA, EDPB, EMA), US regulators (SEC, NIST), and more. One dashboard for all your jurisdictions.', sv: 'Bevaka EU-myndigheter (EBA, ESMA, EDPB, EMA), amerikanska tillsynsmyndigheter (SEC, NIST) och fler. En dashboard för alla era jurisdiktioner.' },\n\n  // ─── Numbers strip ───\n  'reg.proof.authorities': { en: '60+ authorities', sv: '60+ myndigheter' },\n  'reg.proof.sectors': { en: '8 sectors', sv: '8 sektorer' },\n  'reg.proof.countries': { en: '5 countries', sv: '5 länder' },\n  'reg.proof.integrations': { en: '9 integrations', sv: '9 integrationer' },\n\n  // ─── Compliance FAQ ───\n  // ─── How it works (compliance) ───\n  'reg.how.h2': { en: 'How it works', sv: 'Så fungerar det' },\n  'reg.how.sub': { en: 'From setup to compliance insights in under 60 seconds.', sv: 'Från setup till compliance-insikter på under 60 sekunder.' },\n  'reg.how.s1': { en: 'Step 1', sv: 'Steg 1' },\n  'reg.how.s1.h': { en: 'Pick your authorities', sv: 'Välj era myndigheter' },\n  'reg.how.s1.p': { en: 'Select jurisdiction and sector — we recommend 60+ pre-configured agencies across Sweden, Denmark, Norway, Finland, the EU, and the US.', sv: 'Välj jurisdiktion och sektor — vi rekommenderar 60+ förkonfigurerade myndigheter i Sverige, Danmark, Norge, Finland, EU och USA.' },\n  'reg.how.s2': { en: 'Step 2', sv: 'Steg 2' },\n  'reg.how.s2.h': { en: 'AI monitors 24/7', sv: 'AI bevakar dygnet runt' },\n  'reg.how.s2.p': { en: 'Every 6 hours, our AI takes screenshots, detects changes, and classifies them: action required, review recommended, or info only.', sv: 'Var 6:e timme tar vår AI screenshots, upptäcker ändringar och klassificerar dem: åtgärd krävs, granskning rekommenderas, eller bara info.' },\n  'reg.how.s3': { en: 'Step 3', sv: 'Steg 3' },\n  'reg.how.s3.h': { en: 'Review and comply', sv: 'Granska och agera' },\n  'reg.how.s3.p': { en: 'Get notified via Slack, email, or Teams. Mark changes as reviewed with your name. Export audit trails for your ISO auditor.', sv: 'Bli notifierad via Slack, e-post eller Teams. Markera ändringar som granskade med ditt namn. Exportera audit trails till er ISO-revisor.' },\n\n  'reg.faq.h2': { en: 'Questions from compliance teams', sv: 'Frågor från compliance-team' },\n  'reg.faq.q1': { en: 'How is this different from traditional law monitoring tools?', sv: 'Hur skiljer sig detta från traditionella lagbevakningsverktyg?' },\n  'reg.faq.a1': { en: 'Three key differences: (1) We monitor the actual agency websites where changes appear first — not just legal databases that update days later. (2) AI classifies every change in seconds — no waiting for a jurist to write a summary. (3) We\\'re API-first: Slack, Teams, Jira, PagerDuty, RSS, webhooks, CSV — not a closed portal you have to log into.', sv: 'Tre nyckelskillnader: (1) Vi bevakar de faktiska myndighetssidorna där ändringar syns först — inte bara juridiska databaser som uppdateras dagar senare. (2) AI klassificerar varje ändring på sekunder — ingen väntan på att en jurist ska skriva en sammanfattning. (3) Vi är API-first: Slack, Teams, Jira, PagerDuty, RSS, webhooks, CSV — inte en stängd portal man måste logga in i.' },\n  'reg.faq.q2': { en: 'Can I use changebrief for ISO 14001/45001 compliance?', sv: 'Kan jag använda changebrief för ISO 14001/45001-efterlevnad?' },\n  'reg.faq.a2': { en: 'Yes. changebrief provides timestamped audit trails, reviewer attribution (who reviewed what and when), and CSV export — all evidence your ISO auditor needs. The acknowledgment workflow tracks that every regulatory change has been reviewed by the responsible person.', sv: 'Ja. changebrief ger tidsstämplade audit trails, granskningsattribution (vem som granskade vad och när) och CSV-export — alla bevis er ISO-revisor behöver. Kvittensflödet spårar att varje regeländring har granskats av ansvarig person.' },\n  'reg.faq.q3': { en: 'Which countries and authorities do you cover?', sv: 'Vilka länder och myndigheter täcker ni?' },\n  'reg.faq.a3': { en: 'We have 60+ pre-configured authorities across Sweden, Denmark, Norway, Finland, the EU, and the US. This includes Finansinspektionen, IMY, Transportstyrelsen, EBA, ESMA, EDPB, SEC, and many more. You can also add any custom URL — if it has a webpage, we can monitor it.', sv: 'Vi har 60+ förkonfigurerade myndigheter i Sverige, Danmark, Norge, Finland, EU och USA. Det inkluderar Finansinspektionen, IMY, Transportstyrelsen, EBA, ESMA, EDPB, SEC och många fler. Du kan också lägga till valfri URL — om den har en webbsida kan vi bevaka den.' },\n  'reg.faq.q4': { en: 'How often are pages checked?', sv: 'Hur ofta kontrolleras sidorna?' },\n  'reg.faq.a4': { en: 'Every 6 hours, 24/7. When a change is detected, you\\'re notified immediately via your chosen channels (email, Slack, Teams, etc.). Weekly/daily digest summaries are also available.', sv: 'Var 6:e timme, dygnet runt. När en ändring upptäcks notifieras du direkt via dina valda kanaler (e-post, Slack, Teams etc.). Vecko-/dagliga sammanfattningar finns också tillgängliga.' },\n} as const;\n\nexport type LandingKey = keyof typeof landing;\n\nexport function lt(key: LandingKey, lang: Lang): string {\n  return landing[key]?.[lang] ?? landing[key]?.en ?? key;\n}\n","numLines":219,"startLine":1,"totalLines":219}}}
