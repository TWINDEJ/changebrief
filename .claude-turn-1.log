text-white\">{lt('price.popular', lang)}</div>\n            <div class=\"rounded-2xl theme-bg p-7 flex flex-col flex-1\">\n              <h3 class=\"text-lg font-semibold theme-text\">Pro</h3>\n              <div class=\"mt-4 flex items-baseline gap-1\"><span class=\"text-4xl font-bold theme-text\">$19</span><span class=\"theme-text-muted\">{lt('price.mo', lang)}</span></div>\n              <p class=\"mt-1 text-xs theme-text-muted\">{lt('price.or', lang)} $190{lt('price.year', lang)} ({lt('price.save', lang)})</p>\n              <p class=\"mt-4 text-sm theme-text-secondary\">{lt('price.pro.desc', lang)}</p>\n              <ul class=\"mt-8 space-y-3 text-sm theme-text-secondary flex-1\">\n                <li class=\"flex items-center gap-3\"><svg class=\"h-4 w-4 shrink-0 text-blue-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" /></svg>25 {lt('price.pages', lang)}</li>\n                <li class=\"flex items-center gap-3\"><svg class=\"h-4 w-4 shrink-0 text-blue-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" /></svg>{lang === 'sv' ? 'PDF-rapport & CSV' : 'PDF report & CSV export'}</li>\n                <li class=\"flex items-center gap-3\"><svg class=\"h-4 w-4 shrink-0 text-blue-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" /></svg>{lang === 'sv' ? 'GRC webhook' : 'GRC webhook integration'}</li>\n                <li class=\"flex items-center gap-3\"><svg class=\"h-4 w-4 shrink-0 text-blue-500\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M5 13l4 4L19 7\" /></svg>{lang === 'sv' ? 'SLA-uppföljning' : 'SLA deadline tracking'}</li>\n  