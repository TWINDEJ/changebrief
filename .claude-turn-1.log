{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AjUHKefuww5xzVmei6buU9","type":"tool_result","content":"1\t'use client';\n2\t\n3\timport { useState, useCallback, useMemo } from 'react';\n4\timport { useRouter } from 'next/navigation';\n5\timport { Toast, useToast } from './toast';\n6\timport { CopyUrl } from './copy-url';\n7\timport { LiveTime } from './live-time';\n8\timport { useLocale } from '../locale-provider';\n9\t\n10\tinterface WatchedUrl {\n11\t  id: number;\n12\t  url: string;\n13\t  name: string;\n14\t  active: number;\n15\t  threshold: number;\n16\t  selector: string | null;\n17\t  mobile: number;\n18\t  muted: number | null;\n19\t  last_checked_at: string | null;\n20\t  last_error: string | null;\n21\t  consecutive_errors: number | null;\n22\t  cookies: string | null;\n23\t  headers: string | null;\n24\t  last_summary: string | null;\n25\t  last_importance: number | null;\n26\t  last_change_at: string | null;\n27\t}\n28\t\n29\ttype SortKey = 'name' | 'changed' | 'importance';\n30\t\n31\tfunction useTimeAgo() {\n32\t  const { t } = useLocale();\n33\t  return (dateStr: string) => {\n34\t    const diff = Math.floor((Date.now() - new Date(dateStr + 'Z').getTime()) / 1000);\n35\t    if (diff < 60) return t('time.justNow');\n36\t    if (diff < 3600) return `${Math.floor(diff / 60)}${t('time.mAgo')}`;\n37\t    if (diff < 86400) return `${Math.floor(diff / 3600)}${t('time.hAgo')}`;\n38\t    return `${Math.floor(diff / 86400)}${t('time.dAgo')}`;\n39\t  };\n40\t}\n41\t\n42\texport function MonitoredGrid({ urls }: { urls: WatchedUrl[] }) {\n43\t  const { t, locale } = useLocale();\n44\t  const router = useRouter();\n45\t  const [removing, setRemoving] = useState<number | null>(null);\n46\t  const [muting, setMuting] = useState<number | null>(null);\n47\t  const [sort, setSort] = useState<SortKey>('name');\n48\t  const [expandedId, setExpandedId] = useState<number | null>(null);\n49\t  const { toast, show, clear } = useToast();\n50\t  const timeAgo = useTimeAgo();\n51\t\n52\t  const sorted = useMemo(() => {\n53\t    const items = [...urls];\n54\t    switch (sort) {\n55\t      case 'name':\n56\t        items.sort((a, b) => a.name.localeCompare(b.name));\n57\t        break;\n58\t      case 'changed':\n59\t        items.sort((a, b) => {\n60\t          const aDate = a.last_change_at || '0';\n61\t          const bDate = b.last_change_at || '0';\n62\t          return bDate.localeCompare(aDate);\n63\t        });\n64\t        break;\n65\t      case 'importance':\n66\t        items.sort((a, b) => (b.last_importance ?? 0) - (a.last_importance ?? 0));\n67\t        break;\n68\t    }\n69\t    return items;\n70\t  }, [urls, sort]);\n71\t\n72\t  const handleRemove = useCallback(\n73\t    async (id: number, name: string) => {\n74\t      setRemoving(id);\n75\t      const res = await fetch(`/api/urls?id=${id}`, { method: 'DELETE' });\n76\t      if (res.ok) {\n77\t        show(`${t('urls.removed')} \"${name}\"`, 'success');\n78\t        router.refresh();\n79\t      } else {\n80\t        show('Failed to remove URL', 'error');"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"6552c348-dfbc-4a15-a70e-bedc7bb2dd16","timestamp":"2026-04-18T21:23:32.084Z"}
