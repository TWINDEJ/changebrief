      <p className=\"mt-1 text-2xl font-bold text-slate-900\">48</p>\n154\t            </div>\n155\t          </div>\n156\t        </section>\n157\t\n158\t        {/* Activity feed */}\n159\t        <section>\n160\t          <h2 className=\"text-lg font-semibold text-slate-900/90 mb-1\">Recent changes</h2>\n161\t          <p className=\"text-sm text-slate-500 mb-4\">AI-powered summaries of regulatory changes, ranked by importance.</p>\n162\t          <div className=\"space-y-3\">\n163\t            {mockChanges\n164\t              .sort((a, b) => b.importance - a.importance)\n165\t              .map((change) => (\n166\t              <div key={change.id} className=\"rounded-xl bg-white border border-slate-200 p-4 hover:shadow-md transition-shadow\">\n167\t                <div className=\"flex items-start justify-between gap-3\">\n168\t                  <div className=\"flex-1 min-w-0\">\n169\t                    <div className=\"flex items-center gap-2 mb-1 flex-wrap\">\n170\t                      <span className={`inline-flex items-center justify-center h-6 w-6 rounded-full text-xs font-bold text-white ${\n171\t                        change.importance >= 7 ? 'bg-red-500' : change.importance >= 4 ? 'bg-amber-500' : 'bg-slate-400'\n172\t                      }`}>\n173\t                        {change.importance}\n174\t                      </span>\n175\t                      <span className=\"text-sm font-semibold text-slate-900 truncate\">{change.name}</span>\n176\t                      <ActionBadge action={change.compliance_action} />\n177\t                      {change.jurisdiction && (\n178\t                        <span className=\"text-xs text-slate-400 font-mono\">[{change.jurisdiction}]</span>\n179\t                      )}\n180\t                    </div>\n181\t                    <p className=\"text-sm text-slate-700 leading-relaxed\">{change.summary}</p>\n182\t                    <div className=\"flex items-center gap-3 mt-2 text-xs text-slate-400\">\n183\t                      <span>{timeAgo(change.checked_at)}</span>\n184\t                      <span>{change.change_percent.toFixed(1)}% pixel diff</span>\n185\t                      {change.document_type && <span className=\"capitalize\">{change.document_type}</span>}\n186\t                      {change.reviewed_at && <span className=\"text-emerald-600 font-medium\">Reviewed</span>}\n187\t                    </div>\n188\t                  </div>\n189\t                  {!change.reviewed_at && (\n190\t                    <button\n191\t                      className=\"shrink-0 rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-medium text-slate-600 hover:bg-slate-50 transition cursor-default opacity-60\"\n192\t                      title=\"Sign up to review changes\"\n193\t                    >\n194\t                      Mark reviewed\n195\t                    </button>\n196\t                  )}\n197\t                </div>\n198\t              </div>\n199\t            ))}\n200\t          </div>\n201\t        </section>\n202\t\n203\t        {/* Sources */}\n204\t        <section>\n205\t          <h2 className=\"text-lg font-semibold text-slate-900/90 mb-1\">Monitored sources</h2>\n206\t          <p className=\"text-sm text-slate-500 mb-4\">Regulatory agencies being monitored every 6 hours.</p>\n207\t          <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n208\t            {mockSources.map((source) => (\n209\t              <div key={source.url} className=\"rounded-xl bg-white border border-slate-200 px-4 py-3 flex items-center justify-between\">\n210\t                <div>\n211\t                  <p className=\"text-sm font-medium text-slate-900\">{source.name}</p>\n212\t                  <p className=\"text-xs text-slate-400\">{source.url} · {source.category}</p>\n213\t                </div>\n214\t                <div className=\"flex items-center gap-2\">\n215\t                  <span className=\"text-xs text-slate-400\">{source.lastCheck}</span>