{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018gbzYAd2FqamNyEAA3PZiU","type":"tool_result","content":"1\t'use client';\n2\t\n3\timport { useState, useMemo, useCallback } from 'react';\n4\timport { useLocale } from '../locale-provider';\n5\timport { useRouter } from 'next/navigation';\n6\timport suggestions from '@/data/suggestions.json';\n7\t\n8\tinterface Props {\n9\t  canAdd: boolean;\n10\t}\n11\t\n12\ttype Jurisdiction = 'SE' | 'DK' | 'NO' | 'FI' | 'EU' | 'US';\n13\ttype Step = 1 | 2 | 3;\n14\t\n15\tconst JURISDICTIONS: Jurisdiction[] = ['SE', 'DK', 'NO', 'FI', 'EU', 'US'];\n16\t\n17\tconst SECTORS = [\n18\t  'Finance & Banking',\n19\t  'Health & Pharma',\n20\t  'Data & Privacy',\n21\t  'Transport & Infrastructure',\n22\t  'Environment & Energy',\n23\t  'Labor & Workplace',\n24\t  'Laws & Government',\n25\t] as const;\n26\t\n27\ttype Sector = typeof SECTORS[number];\n28\t\n29\tconst sectorLabels: Record<Sector, { en: string; sv: string }> = {\n30\t  'Finance & Banking':           { en: 'Finance & Banking',           sv: 'Finans & Bank' },\n31\t  'Health & Pharma':             { en: 'Health & Pharma',             sv: 'Hälsa & Läkemedel' },\n32\t  'Data & Privacy':              { en: 'Data & Privacy',              sv: 'Data & Integritet' },\n33\t  'Transport & Infrastructure':  { en: 'Transport & Infrastructure',  sv: 'Transport & Infrastruktur' },\n34\t  'Environment & Energy':        { en: 'Environment & Energy',        sv: 'Miljö & Energi' },\n35\t  'Labor & Workplace':           { en: 'Labor & Workplace',           sv: 'Arbete & Arbetsmiljö' },\n36\t  'Laws & Government':           { en: 'Laws & Government',           sv: 'Lagar & Myndigheter' },\n37\t};\n38\t\n39\tconst i18n = {\n40\t  en: {\n41\t    step1Title: 'Select your jurisdictions',\n42\t    step1Sub: 'Which countries or regions do you need to monitor?',\n43\t    step2Title: 'Select your sector',\n44\t    step2Sub: 'What industry are you in?',\n45\t    step3Title: 'Recommended sources',\n46\t    step3Sub: 'Based on your selections, we found these regulatory sources.',\n47\t    matchCount: (n: number) => `${n} matching source${n !== 1 ? 's' : ''}`,\n48\t    addAll: 'Add all recommended',\n49\t    adding: (current: number, total: number) => `Adding ${current} of ${total}...`,\n50\t    done: 'All sources added!',\n51\t    back: 'Back',\n52\t    next: 'Next',\n53\t    skip: 'Skip',\n54\t    noMatches: 'No sources match your selection. Try adjusting your jurisdictions or sector.',\n55\t    cannotAdd: 'You have reached your URL limit. Upgrade to add more.',\n56\t  },\n57\t  sv: {\n58\t    step1Title: 'Välj dina jurisdiktioner',\n59\t    step1Sub: 'Vilka länder eller regioner behöver du bevaka?',\n60\t    step2Title: 'Välj din bransch',\n61\t    step2Sub: 'Vilken bransch verkar du inom?',\n62\t    step3Title: 'Rekommenderade källor',\n63\t    step3Sub: 'Baserat på dina val hittade vi dessa regulatoriska källor.',\n64\t    matchCount: (n: number) => `${n} matchande käll${n !== 1 ? 'or' : 'a'}`,\n65\t    addAll: 'Lägg till alla rekommenderade',\n66\t    adding: (current: number, total: number) => `Lägger till ${current} av ${total}...`,\n67\t    done: 'Alla källor tillagda!',\n68\t    back: 'Tillbaka',\n69\t    next: 'Nästa',\n70\t    skip: 'Hoppa över',\n71\t    noMatches: 'Inga källor matchar ditt urval. Försök ändra jurisdiktioner eller bransch.',\n72\t    cannotAdd: 'Du har nått din URL-gräns. Uppgradera för att lägga till fler.',\n73\t  },\n74\t};\n75\t\n76\texport default function ComplianceOnboarding({ canAdd }: Props) {\n77\t  const { locale } = useLocale();\n78\t  const router = useRouter();\n79\t  const tx = locale === 'sv' ? i18n.sv : i18n.en;\n80\t\n81\t  const [step, setStep] = useState<Step>(1);\n82\t  const [selectedJurisdictions, setSelectedJurisdictions] = useState<Set<Jurisdiction>>(new Set());\n83\t  const [selectedSector, setSelectedSector] = useState<Sector | null>(null);\n84\t  const [isAdding, setIsAdding] = useState(false);\n85\t  const [addProgress, setAddProgress] = useState({ current: 0, total: 0 });\n86\t  const [isDone, setIsDone] = useState(false);\n87\t  const [visible, setVisible] = useState(true);\n88\t\n89\t  const toggleJurisdiction = useCallback((j: Jurisdiction) => {\n90\t    setSelectedJurisdictions(prev => {\n91\t      const next = new Set(prev);\n92\t      if (next.has(j)) { next.delete(j); } else { next.add(j); }\n93\t      return next;\n94\t    });\n95\t  }, []);\n96\t\n97\t  const matched = useMemo(() => {\n98\t    if (selectedJurisdictions.size === 0 || !selectedSector) return [];\n99\t    return suggestions.filter(\n100\t      s => selectedJurisdictions.has(s.jurisdiction as Jurisdiction) && s.category === selectedSector\n101\t    );\n102\t  }, [selectedJurisdictions, selectedSector]);\n103\t\n104\t  const handleAddAll = useCallback(async () => {\n105\t    if (!canAdd) return;\n106\t    setIsAdding(true);\n107\t    const toAdd = matched;\n108\t    setAddProgress({ current: 0, total: toAdd.length });\n109\t\n110\t    for (let i = 0; i < toAdd.length; i++) {\n111\t      setAddProgress({ current: i + 1, total: toAdd.length });\n112\t      const s = toAdd[i];\n113\t      try {\n114\t        await fetch('/api/urls', {\n115\t          method: 'POST',\n116\t          headers: { 'Content-Type': 'application/json' },\n117\t          body: JSON.stringify({\n118\t            url: s.url,\n119\t            name: locale === 'sv' ? s.name_sv : s.name,\n120\t            category: s.category,\n121\t          }),\n122\t        });\n123\t      } catch {\n124\t        // Fortsätt med nästa även om en misslyckas\n125\t      }\n126\t    }\n127\t\n128\t    setIsAdding(false);\n129\t    setIsDone(true);\n130\t    router.refresh();\n131\t  }, [canAdd, matched, locale, router]);\n132\t\n133\t  const handleClose = useCallback(() => {\n134\t    setVisible(false);\n135\t  }, []);\n136\t\n137\t  if (!visible) return null;\n138\t\n139\t  return (\n140\t    <div className=\"mx-auto max-w-lg rounded-xl border border-slate-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm\">\n141\t      {/* Stegindikator */}\n142\t      <div className=\"mb-5 flex items-center justify-center gap-2\">\n143\t        {[1, 2, 3].map(s => (\n144\t          <div\n145\t            key={s}\n146\t            className={`h-2 w-8 rounded-full transition-colors ${\n147\t              s === step ? 'bg-blue-600' : s < step ? 'bg-blue-300' : 'bg-slate-200'\n148\t            }`}\n149\t          />\n150\t        ))}\n151\t      </div>\n152\t\n153\t      {/* Steg 1: Jurisdiktioner */}\n154\t      {step === 1 && (\n155\t        <div>\n156\t          <h3 className=\"text-lg font-semibold text-slate-900\">{tx.step1Title}</h3>\n157\t          <p className=\"mb-4 text-sm text-slate-500\">{tx.step1Sub}</p>\n158\t          <div className=\"flex flex-wrap gap-2\">\n159\t            {JURISDICTIONS.map(j => (\n160\t              <button\n161\t                key={j}\n162\t                type=\"button\"\n163\t                onClick={() => toggleJurisdiction(j)}\n164\t                className={`cursor-pointer rounded-full px-4 py-1.5 text-sm font-medium transition-colors ${\n165\t                  selectedJurisdictions.has(j)\n166\t                    ? 'bg-blue-100 text-blue-700 ring-1 ring-blue-300'\n167\t                    : 'bg-slate-100 text-slate-600 hover:bg-slate-200'\n168\t                }`}\n169\t              >\n170\t                {j}\n171\t              </button>\n172\t            ))}\n173\t          </div>\n174\t        </div>\n175\t      )}\n176\t\n177\t      {/* Steg 2: Bransch */}\n178\t      {step === 2 && (\n179\t        <div>\n180\t          <h3 className=\"text-lg font-semibold text-slate-900\">{tx.step2Title}</h3>\n181\t          <p className=\"mb-4 text-sm text-slate-500\">{tx.step2Sub}</p>\n182\t          <div className=\"flex flex-wrap gap-2\">\n183\t            {SECTORS.map(s => (\n184\t              <button\n185\t                key={s}\n186\t                type=\"button\"\n187\t                onClick={() => setSelectedSector(s)}\n188\t                className={`cursor-pointer rounded-full px-4 py-1.5 text-sm font-medium transition-colors ${\n189\t                  selectedSector === s\n190\t                    ? 'bg-blue-100 text-blue-700 ring-1 ring-blue-300'\n191\t                    : 'bg-slate-100 text-slate-600 hover:bg-slate-200'\n192\t                }`}\n193\t              >\n194\t                {locale === 'sv' ? sectorLabels[s].sv : sectorLabels[s].en}\n195\t              </button>\n196\t            ))}\n197\t          </div>\n198\t        </div>\n199\t      )}\n200\t\n201\t      {/* Steg 3: Resultat */}\n202\t      {step === 3 && (\n203\t        <div>\n204\t          <h3 className=\"text-lg font-semibold text-slate-900\">{tx.step3Title}</h3>\n205\t          <p className=\"mb-3 text-sm text-slate-500\">{tx.step3Sub}</p>\n206\t\n207\t          {matched.length === 0 ? (\n208\t            <p className=\"rounded-lg bg-slate-50 p-4 text-center text-sm text-slate-500\">\n209\t              {tx.noMatches}\n210\t            </p>\n211\t          ) : (\n212\t            <>\n213\t              <p className=\"mb-3 text-sm font-medium text-blue-600\">\n214\t                {tx.matchCount(matched.length)}\n215\t              </p>\n216\t              <ul className=\"mb-4 max-h-48 space-y-2 overflow-y-auto\">\n217\t                {matched.map(s => (\n218\t                  <li\n219\t                    key={s.url}\n220\t                    className=\"flex items-start gap-2 rounded-lg bg-slate-50 px-3 py-2\"\n221\t                  >\n222\t                    <span className=\"mt-0.5 inline-block rounded bg-blue-100 px-1.5 py-0.5 text-[10px] font-bold text-blue-700\">\n223\t                      {s.jurisdiction}\n224\t                    </span>\n225\t                    <div className=\"min-w-0\">\n226\t                      <p className=\"truncate text-sm font-medium text-slate-800\">\n227\t                        {locale === 'sv' ? s.name_sv : s.name}\n228\t                      </p>\n229\t                      <p className=\"truncate text-xs text-slate-500\">\n230\t                        {locale === 'sv' ? s.description_sv : s.description}\n231\t                      </p>\n232\t                    </div>\n233\t                  </li>\n234\t                ))}\n235\t              </ul>\n236\t\n237\t              {!canAdd ? (\n238\t                <p className=\"rounded-lg bg-amber-50 p-3 text-center text-sm text-amber-700\">\n239\t                  {tx.cannotAdd}\n240\t                </p>\n241\t              ) : isDone ? (\n242\t                <p className=\"rounded-lg bg-green-50 p-3 text-center text-sm font-medium text-green-700\">\n243\t                  {tx.done}\n244\t                </p>\n245\t              ) : (\n246\t                <button\n247\t                  type=\"button\"\n248\t                  onClick={handleAddAll}\n249\t                  disabled={isAdding}\n250\t                  className=\"w-full cursor-pointer rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-blue-700 disabled:opacity-60\"\n251\t                >\n252\t                  {isAdding ? tx.adding(addProgress.current, addProgress.total) : tx.addAll}\n253\t                </button>\n254\t              )}\n255\t            </>\n256\t          )}\n257\t        </div>\n258\t      )}\n259\t\n260\t      {/* Navigering */}\n261\t      <div className=\"mt-5 flex items-center justify-between\">\n262\t        <button\n263\t          type=\"button\"\n264\t          onClick={handleClose}\n265\t          className=\"cursor-pointer text-sm text-slate-400 hover:text-slate-600 transition-colors\"\n266\t        >\n267\t          {tx.skip}\n268\t        </button>\n269\t        <div className=\"flex gap-2\">\n270\t          {step > 1 && (\n271\t            <button\n272\t              type=\"button\"\n273\t              onClick={() => setStep((step - 1) as Step)}\n274\t              className=\"cursor-pointer rounded-lg border border-slate-200 px-4 py-1.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition-colors\"\n275\t            >\n276\t              {tx.back}\n277\t            </button>\n278\t          )}\n279\t          {step < 3 && (\n280\t            <button\n281\t              type=\"button\"\n282\t              onClick={() => setStep((step + 1) as Step)}\n283\t              disabled={step === 1 && selectedJurisdictions.size === 0}\n284\t              className=\"cursor-pointer rounded-lg bg-blue-600 px-4 py-1.5 text-sm font-medium text-white hover:bg-blue-700 disabled:opacity-40 transition-colors\"\n285\t            >\n286\t              {tx.next}\n287\t            </button>\n288\t          )}\n289\t        </div>\n290\t      </div>\n291\t    </div>\n292\t  );\n293\t}\n294\t"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"d3632001-9055-473d-8af2-210c50069982","timestamp":"2026-04-18T21:23:20.685Z"}
