{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E3Qd7PwjAwNk1Zpah8Ehf8","type":"tool_result","content":"1\timport * as fs from 'fs';\n2\timport * as path from 'path';\n3\t\n4\texport interface WatchTarget {\n5\t  url: string;\n6\t  name: string;\n7\t  active: boolean;\n8\t  threshold: number;       // procent pixel-diff som triggar AI-analys\n9\t  minImportance: number;   // minsta importance-score för att skicka notis\n10\t  selector?: string;       // CSS-selektor — screenshota bara detta element\n11\t  mobile?: boolean;        // ta screenshot i mobil-viewport (375×812)\n12\t  headers?: Record<string, string>;  // extra HTTP-headers (t.ex. Authorization)\n13\t  cookies?: Array<{name: string; value: string; domain: string}>;\n14\t  waitForSelector?: string; // vänta på att detta element finns innan screenshot\n15\t  notifySlack: boolean;\n16\t  notifyEmail?: string;    // email-adress att notifiera\n17\t}\n18\t\n19\tconst CONFIG_FILE = path.join('data', 'urls.json');\n20\t\n21\tfunction defaultTarget(url: string, name: string): WatchTarget {\n22\t  return {\n23\t    url,\n24\t    name,\n25\t    active: true,\n26\t    threshold: 0.3,\n27\t    minImportance: 5,\n28\t    notifySlack: true,\n29\t  };\n30\t}\n31\t\n32\texport function loadTargets(): WatchTarget[] {\n33\t  if (!fs.existsSync(CONFIG_FILE)) return [];\n34\t  const raw = fs.readFileSync(CONFIG_FILE, 'utf-8');\n35\t  const items = JSON.parse(raw);\n36\t\n37\t  // Stöd gammalt format (bara url + name) och nytt format\n38\t  return items.map((item: Partial<WatchTarget> & { url: string; name: string }) => ({\n39\t    ...defaultTarget(item.url, item.name),\n40\t    ...item,\n41\t  }));\n42\t}\n43\t\n44\texport function saveTargets(targets: WatchTarget[]): void {\n45\t  fs.mkdirSync(path.dirname(CONFIG_FILE), { recursive: true });\n46\t  fs.writeFileSync(CONFIG_FILE, JSON.stringify(targets, null, 2));\n47\t}\n48\t\n49\texport function addTarget(url: string, name: string, options?: Partial<WatchTarget>): WatchTarget {\n50\t  const targets = loadTargets();\n51\t  const existing = targets.find(t => t.url === url);\n52\t  if (existing) {\n53\t    throw new Error(`URL redan bevakad: ${url} (${existing.name})`);\n54\t  }\n55\t  // Filtrera bort undefined-värden så de inte skriver över defaults\n56\t  const cleanOptions = Object.fromEntries(\n57\t    Object.entries(options ?? {}).filter(([, v]) => v !== undefined)\n58\t  );\n59\t  const target = { ...defaultTarget(url, name), ...cleanOptions } as WatchTarget;\n60\t  targets.push(target);\n61\t  saveTargets(targets);\n62\t  return target;\n63\t}\n64\t\n65\texport function removeTarget(url: string): boolean {\n66\t  const targets = loadTargets();\n67\t  const index = targets.findIndex(t => t.url === url);\n68\t  if (index === -1) return false;\n69\t  targets.splice(index, 1);\n70\t  saveTargets(targets);\n71\t  return true;\n72\t}\n73\t\n74\texport function listTargets(): void {\n75\t  const targets = loadTargets();\n76\t  if (targets.length === 0) {\n77\t    console.log('Inga bevakade URLs. Lägg till med: npm run cli -- add <url> <namn>');\n78\t    return;\n79\t  }\n80\t  console.log(`\\n${targets.length} bevakade sidor:\\n`);\n81\t  for (const t of targets) {\n82\t    const status = t.active ? '●' : '○';\n83\t    const extras = [\n84\t      t.selector ? `selector: ${t.selector}` : null,\n85\t      t.mobile ? 'mobil' : null,\n86\t      `tröskel: ${t.threshold}%`,\n87\t    ].filter(Boolean).join(', ');\n88\t    console.log(`  ${status} ${t.name}`);\n89\t    console.log(`    ${t.url}`);\n90\t    console.log(`    ${extras}`);\n91\t  }\n92\t}\n93\t"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"11592008-0cb0-471f-895d-ffbce8609914","timestamp":"2026-04-18T21:23:13.938Z"}
