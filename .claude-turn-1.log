{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VeqPVXnku2YBEjZ5Hp9tyW","type":"tool_result","content":"1\timport Link from 'next/link';\n2\t\n3\t// Hardcoded mock data — no DB or auth needed\n4\tconst mockChanges = [\n5\t  {\n6\t    id: 1, url: 'https://www.fi.se/sv/vara-register/foretagsregistret/', name: 'Finansinspektionen — Regulations',\n7\t    summary: 'New capital adequacy requirements published for credit institutions. Effective date: 2026-06-01.',\n8\t    importance: 9, compliance_action: 'action_required', jurisdiction: 'SE', document_type: 'regulation',\n9\t    checked_at: new Date(Date.now() - 2 * 3600_000).toISOString(), reviewed_at: null, change_percent: 4.2,\n10\t  },\n11\t  {\n12\t    id: 2, url: 'https://www.transportstyrelsen.se/sv/vagtrafik/Fordon/', name: 'Transportstyrelsen — Vehicle Standards',\n13\t    summary: 'Updated guidance on electric vehicle type approval testing procedures.',\n14\t    importance: 6, compliance_action: 'review_recommended', jurisdiction: 'SE', document_type: 'guidance',\n15\t    checked_at: new Date(Date.now() - 8 * 3600_000).toISOString(), reviewed_at: null, change_percent: 2.1,\n16\t  },\n17\t  {\n18\t    id: 3, url: 'https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32024R1234', name: 'EU DORA — Digital Operational Resilience',\n19\t    summary: 'Minor formatting update to article numbering in annex III. No substantive changes.',\n20\t    importance: 2, compliance_action: 'info_only', jurisdiction: 'EU', document_type: 'regulation',\n21\t    checked_at: new Date(Date.now() - 24 * 3600_000).toISOString(), reviewed_at: new Date(Date.now() - 20 * 3600_000).toISOString(), change_percent: 0.8,\n22\t  },\n23\t  {\n24\t    id: 4, url: 'https://www.datainspektionen.se/', name: 'IMY — Data Privacy Authority',\n25\t    summary: 'Published new consultation on cross-border data transfer assessment requirements under GDPR.',\n26\t    importance: 7, compliance_action: 'action_required', jurisdiction: 'SE', document_type: 'consultation',\n27\t    checked_at: new Date(Date.now() - 4 * 3600_000).toISOString(), reviewed_at: null, change_percent: 5.7,\n28\t  },\n29\t  {\n30\t    id: 5, url: 'https://www.riksbanken.se/sv/penningpolitik/', name: 'Riksbanken — Monetary Policy',\n31\t    summary: 'Policy rate decision announcement page updated with new rate: 3.25% (unchanged).',\n32\t    importance: 5, compliance_action: 'review_recommended', jurisdiction: 'SE', document_type: 'decision',\n33\t    checked_at: new Date(Date.now() - 12 * 3600_000).toISOString(), reviewed_at: null, change_percent: 1.9,\n34\t  },\n35\t  {\n36\t    id: 6, url: 'https://www.fsa.dk/', name: 'Danish FSA — Financial Supervision',\n37\t    summary: 'New anti-money laundering reporting guidelines for financial institutions published.',\n38\t    importance: 8, compliance_action: 'action_required', jurisdiction: 'DK', document_type: 'guidance',\n39\t    checked_at: new Date(Date.now() - 6 * 3600_000).toISOString(), reviewed_at: null, change_percent: 3.4,\n40\t  },\n41\t];\n42\t\n43\tconst mockSources = [\n44\t  { name: 'Finansinspektionen', url: 'fi.se', category: 'Finance & Banking', status: 'active', lastCheck: '2h ago' },\n45\t  { name: 'Transportstyrelsen', url: 'transportstyrelsen.se', category: 'Transport & Infrastructure', status: 'active', lastCheck: '2h ago' },\n46\t  { name: 'EU DORA', url: 'eur-lex.europa.eu', category: 'Finance & Banking', status: 'active', lastCheck: '2h ago' },\n47\t  { name: 'IMY', url: 'datainspektionen.se', category: 'Data & Privacy', status: 'active', lastCheck: '2h ago' },\n48\t  { name: 'Riksbanken', url: 'riksbanken.se', category: 'Finance & Banking', status: 'active', lastCheck: '2h ago' },\n49\t  { name: 'Danish FSA', url: 'fsa.dk', category: 'Finance & Banking', status: 'active', lastCheck: '2h ago' },\n50\t  { name: 'Norwegian FSA', url: 'finanstilsynet.no', category: 'Finance & Banking', status: 'active', lastCheck: '6h ago' },\n51\t  { name: 'EBA', url: 'eba.europa.eu', category: 'Finance & Banking', status: 'active', lastCheck: '6h ago' },\n52\t];\n53\t\n54\tfunction timeAgo(dateStr: string): string {\n55\t  const diff = Math.floor((Date.now() - new Date(dateStr).getTime()) / 1000);\n56\t  if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;\n57\t  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;\n58\t  return `${Math.floor(diff / 86400)}d ago`;\n59\t}\n60\t\n61\tfunction ActionBadge({ action }: { action: string }) {\n62\t  const styles: Record<string, string> = {\n63\t    action_required: 'bg-red-50 text-red-700 border-red-200',\n64\t    review_recommended: 'bg-amber-50 text-amber-700 border-amber-200',\n65\t    info_only: 'bg-slate-50 text-slate-500 border-slate-200',\n66\t  };\n67\t  const labels: Record<string, string> = {\n68\t    action_required: 'Action required',\n69\t    review_recommended: 'Review',\n70\t    info_only: 'Info',\n71\t  };\n72\t  return (\n73\t    <span className={`inline-flex items-center rounded-full border px-2 py-0.5 text-xs font-medium ${styles[action] || ''}`}>\n74\t      {labels[action] || action}\n75\t    </span>\n76\t  );\n77\t}\n78\t\n79\texport default function DemoPage() {\n80\t  const actionRequired = mockChanges.filter(c => c.compliance_action === 'action_required' && !c.reviewed_at).length;\n81\t  const reviewRecommended = mockChanges.filter(c => c.compliance_action === 'review_recommended' && !c.reviewed_at).length;\n82\t  const reviewed = mockChanges.filter(c => c.reviewed_at).length;\n83\t\n84\t  return (\n85\t    <div className=\"min-h-screen bg-slate-50\">\n86\t      {/* Demo banner */}\n87\t      <div className=\"bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-center py-2.5 px-4 text-sm font-medium\">\n88\t        This is an interactive demo with sample data.{' '}\n89\t        <Link href=\"/login\" className=\"underline font-semibold hover:text-blue-100\">\n90\t          Sign up free\n91\t        </Link>{' '}\n92\t        to monitor your own regulatory sources.\n93\t      </div>\n94\t\n95\t      {/* Header */}\n96\t      <header className=\"border-b border-slate-200 bg-white/80 backdrop-blur-xl sticky top-0 z-30\">\n97\t        <div className=\"mx-auto flex max-w-5xl items-center justify-between px-4 sm:px-6 py-3\">\n98\t          <div className=\"flex items-center gap-2.5\">\n99\t            <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600\">\n100\t              <svg className=\"h-4 w-4 text-white\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\">\n101\t                <circle cx=\"12\" cy=\"12\" r=\"3\" />\n102\t                <path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\" />\n103\t              </svg>\n104\t            </div>\n105\t            <h1 className=\"text-lg font-bold tracking-tight\">\n106\t              change<span className=\"text-blue-600\">brief</span>\n107\t            </h1>\n108\t            <span className=\"rounded-full bg-amber-50 border border-amber-200 px-2.5 py-0.5 text-xs font-medium text-amber-700 ml-2\">\n109\t              Demo\n110\t            </span>\n111\t          </div>\n112\t          <Link\n113\t            href=\"/login\"\n114\t            className=\"rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 px-4 py-1.5 text-sm font-medium text-white hover:from-blue-400 hover:to-indigo-400 transition-all\"\n115\t          >\n116\t            Get started free\n117\t          </Link>\n118\t        </div>\n119\t      </header>\n120\t\n121\t      <main className=\"mx-auto max-w-5xl px-4 sm:px-6 py-6 sm:py-8 space-y-6\">\n122\t        {/* Stats */}\n123\t        <section className=\"space-y-3\">\n124\t          <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n125\t            <div className=\"rounded-xl bg-red-50 border border-red-100 px-4 py-3\">\n126\t              <p className=\"text-xs text-red-600/70 font-medium\">Action required</p>\n127\t      