{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014JDYxwRbHfTvNcPUaFUPmP","type":"tool_result","content":"1\t---\n2\timport Base from '../layouts/Base.astro';\n3\timport Header from './Header.astro';\n4\timport { lt, type Lang } from '../i18n';\n5\t\n6\tinterface Props { lang: Lang }\n7\tconst { lang } = Astro.props;\n8\t\n9\tconst title = lang === 'sv'\n10\t  ? 'changebrief — Regulatorisk omvärldsbevakning med AI'\n11\t  : 'changebrief — AI-powered regulatory monitoring';\n12\tconst description = lt('reg.sub', lang);\n13\t\n14\tconst canonical = lang === 'sv'\n15\t  ? 'https://changebrief.io/sv/compliance'\n16\t  : 'https://changebrief.io/compliance';\n17\t\n18\tconst hreflang = [\n19\t  { lang: 'en', href: 'https://changebrief.io/compliance' },\n20\t  { lang: 'sv', href: 'https://changebrief.io/sv/compliance' },\n21\t  { lang: 'x-default', href: 'https://changebrief.io/compliance' },\n22\t];\n23\t\n24\tconst faqData = {\n25\t  '@context': 'https://schema.org',\n26\t  '@type': 'FAQPage',\n27\t  mainEntity: [1,2,3,4].map(n => ({\n28\t    '@type': 'Question',\n29\t    name: lt(`reg.faq.q${n}` as any, lang),\n30\t    acceptedAnswer: {\n31\t      '@type': 'Answer',\n32\t      text: lt(`reg.faq.a${n}` as any, lang),\n33\t    },\n34\t  })),\n35\t};\n36\t\n37\tconst structuredData = [{\n38\t  '@context': 'https://schema.org',\n39\t  '@type': 'SoftwareApplication',\n40\t  name: 'changebrief',\n41\t  applicationCategory: 'BusinessApplication',\n42\t  operatingSystem: 'Web',\n43\t  description: lang === 'sv'\n44\t    ? 'AI-driven regulatorisk omvärldsbevakning. Bevaka myndigheter och tillsynsorgan automatiskt.'\n45\t    : 'AI-powered regulatory monitoring. Track government agencies and regulators automatically.',\n46\t  url: 'https://changebrief.io/compliance',\n47\t  offers: [\n48\t    {\n49\t      '@type': 'Offer',\n50\t      name: 'Free',\n51\t      price: '0',\n52\t      priceCurrency: 'USD',\n53\t      description: '3 pages, 100 checks/month',\n54\t    },\n55\t    {\n56\t      '@type': 'Offer',\n57\t      name: 'Pro',\n58\t      price: '29',\n59\t      priceCurrency: 'USD',\n60\t      description: '25 pages, 2000 checks/month, daily digest, CSV export',\n61\t    },\n62\t  ],\n63\t  featureList: [\n64\t    'AI compliance classification',\n65\t    'Jurisdiction tagging (SE, EU, US)',\n66\t    'Document type identification',\n67\t    'Action-level badges',\n68\t    'RSS feeds per sector',\n69\t    'Audit trail CSV export',\n70\t    'Weekly/daily compliance digest',\n71\t  ],\n72\t}, faqData];\n73\t---\n74\t\n75\t<Base title={title} description={description} lang={lang} canonical={canonical} hreflang={hreflang} structuredData={structuredData}>\n76\t  <Header lang={lang} />\n77\t  <main>\n78\t    <!-- Hero -->\n79\t    <section class=\"relative overflow-hidden pt-36 pb-24 lg:pt-44 lg:pb-36\" style=\"background: linear-gradient(to bottom, var(--hero-compliance-from), var(--hero-compliance-to))\">\n80\t      <div class=\"relative mx-auto max-w-6xl px-6 text-center\">\n81\t        <div class=\"mb-8 inline-flex animate-fade-in-up items-center gap-2.5 rounded-full bg-red-50 border border-red-100 px-4 py-2 text-sm text-red-700\">\n82\t          <span class=\"relative flex h-2 w-2\"><span class=\"absolute inline-flex h-full w-full animate-ping rounded-full bg-red-500 opacity-60\"></span><span class=\"relative inline-flex h-2 w-2 rounded-full bg-red-500\"></span></span>\n83\t          {lt('reg.badge', lang)}\n84\t        </div>\n85\t        <h1 class=\"mx-auto max-w-4xl animate-fade-in-up delay-100 text-5xl font-extrabold leading-[1.1] tracking-tight theme-text sm:text-6xl lg:text-7xl\">\n86\t          {lt('reg.h1a', lang)}\n87\t          <span class=\"block bg-gradient-to-r from-red-600 via-amber-500 to-orange-500 bg-clip-text text-transparent\">{lt('reg.h1b', lang)}</span>\n88\t        </h1>\n89\t        <p class=\"mx-auto mt-6 max-w-2xl animate-fade-in-up delay-200 text-lg leading-relaxed theme-text-secondary lg:text-xl\">\n90\t          <span class=\"theme-text font-semibold\">change</span><span class=\"text-blue-600 font-semibold\">brief</span> {lang === 'sv' ? 'bevakar myndigheter och tillsynsorgan med AI — och berättar exakt vad som ändrades, om det kräver åtgärd och vilken jurisdiktion som berörs.' : 'monitors government agencies and regulators with AI — and tells you exactly what changed, whether it requires action, and which jurisdiction it affects.'}\n91\t        </p>\n92\t        <div class=\"mt-10 flex animate-fade-in-up delay-300 flex-col items-center justify-center gap-4 sm:flex-row\">\n93\t          <a href=\"https://app.changebrief.io?ref=compliance\" class=\"btn-glow group inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-red-600 to-amber-600 px-8 py-3.5 text-base font-semibold text-white transition-all duration-300\">\n94\t            {lt('reg.cta1', lang)}\n95\t            <svg class=\"h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\" /></svg>\n96\t          </a>\n97\t          <a href=\"#how-it-works\" class=\"group inline-flex items-center gap-2 rounded-full border theme-border theme-bg px-8 py-3.5 text-base font-semibold theme-text-secondary transition-all duration-200 hover:border-[var(--border-primary)] hover:text-[var(--text-primary)] hover:shadow-sm\">\n98\t            {lt('reg.cta2', lang)}\n99\t            <svg class=\"h-4 w-4 transition-transform duration-200 group-hover:translate-y-0.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" /></svg>\n100\t          </a>"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"46b2af53-4618-4e7d-980b-963c98f2e4ba","timestamp":"2026-04-18T21:23:44.288Z"}
