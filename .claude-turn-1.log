{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GVvdv4noMMVwocbwXTpzic","type":"tool_result","content":"1\t/**\n2\t * Centralt DB-schema för changebrief.\n3\t * Används av både engine (check-all.ts) och app (db.ts).\n4\t * All schema-logik ska ligga HÄR — inte dupliceras.\n5\t */\n6\t\n7\timport type { Client } from '@libsql/client';\n8\t\n9\tconst BASE_TABLES = `\n10\t  CREATE TABLE IF NOT EXISTS users (\n11\t    id TEXT PRIMARY KEY,\n12\t    email TEXT UNIQUE NOT NULL,\n13\t    name TEXT,\n14\t    image TEXT,\n15\t    plan TEXT DEFAULT 'free',\n16\t    polar_customer_id TEXT,\n17\t    notify_email INTEGER DEFAULT 1,\n18\t    slack_webhook_url TEXT,\n19\t    created_at TEXT DEFAULT (datetime('now'))\n20\t  );\n21\t\n22\t  CREATE TABLE IF NOT EXISTS watched_urls (\n23\t    id INTEGER PRIMARY KEY AUTOINCREMENT,\n24\t    user_id TEXT NOT NULL REFERENCES users(id),\n25\t    url TEXT NOT NULL,\n26\t    name TEXT NOT NULL,\n27\t    active INTEGER DEFAULT 1,\n28\t    threshold REAL DEFAULT 0.3,\n29\t    selector TEXT,\n30\t    mobile INTEGER DEFAULT 0,\n31\t    min_importance INTEGER DEFAULT 5,\n32\t    created_at TEXT DEFAULT (datetime('now')),\n33\t    UNIQUE(user_id, url)\n34\t  );\n35\t\n36\t  CREATE TABLE IF NOT EXISTS change_history (\n37\t    id INTEGER PRIMARY KEY AUTOINCREMENT,\n38\t    user_id TEXT NOT NULL REFERENCES users(id),\n39\t    url TEXT NOT NULL,\n40\t    name TEXT NOT NULL,\n41\t    change_percent REAL NOT NULL,\n42\t    summary TEXT,\n43\t    importance INTEGER,\n44\t    changed_elements TEXT,\n45\t    has_significant_change INTEGER DEFAULT 0,\n46\t    before_screenshot TEXT,\n47\t    after_screenshot TEXT,\n48\t    checked_at TEXT DEFAULT (datetime('now'))\n49\t  );\n50\t\n51\t  CREATE TABLE IF NOT EXISTS api_keys (\n52\t    id TEXT PRIMARY KEY,\n53\t    user_id TEXT NOT NULL REFERENCES users(id),\n54\t    name TEXT NOT NULL,\n55\t    key_hash TEXT NOT NULL UNIQUE,\n56\t    key_prefix TEXT NOT NULL,\n57\t    created_at TEXT DEFAULT (datetime('now')),\n58\t    last_used_at TEXT,\n59\t    revoked_at TEXT\n60\t  );\n61\t`;\n62\t\n63\t// Varje migration läggs till HÄR. Ordningen spelar roll.\n64\t// ALTER TABLE ... ADD COLUMN misslyckas tyst om kolumnen redan finns.\n65\tconst MIGRATIONS = [\n66\t  'ALTER TABLE users ADD COLUMN notify_email INTEGER DEFAULT 1',\n67\t  'ALTER TABLE users ADD COLUMN slack_webhook_url TEXT',\n68\t  'ALTER TABLE watched_urls ADD COLUMN last_checked_at TEXT',\n69\t  'ALTER TABLE watched_urls ADD COLUMN last_error TEXT',\n70\t  'ALTER TABLE watched_urls ADD COLUMN consecutive_errors INTEGER DEFAULT 0',\n71\t  'ALTER TABLE watched_urls ADD COLUMN cookies TEXT',\n72\t  'ALTER TABLE watched_urls ADD COLUMN headers TEXT',\n73\t  'ALTER TABLE users ADD COLUMN weekly_digest INTEGER DEFAULT 1',\n74\t  'ALTER TABLE watched_urls ADD COLUMN muted INTEGER DEFAULT 0',\n75\t  'ALTER TABLE users ADD COLUMN checks_this_month INTEGER DEFAULT 0',\n76\t  'ALTER TABLE users ADD COLUMN checks_month TEXT',\n77\t  \"ALTER TABLE users ADD COLUMN digest_frequency TEXT DEFAULT 'weekly'\",\n78\t  'ALTER TABLE watched_urls ADD COLUMN webhook_url TEXT',\n79\t  'ALTER TABLE watched_urls ADD COLUMN category TEXT',\n80\t  'ALTER TABLE change_history ADD COLUMN jurisdiction TEXT',\n81\t  'ALTER TABLE change_history ADD COLUMN document_type TEXT',\n82\t  'ALTER TABLE change_history ADD COLUMN compliance_action TEXT',\n83\t  'ALTER TABLE change_history ADD COLUMN reviewed_at TEXT',\n84\t  'ALTER TABLE change_history ADD COLUMN reviewed_by TEXT',\n85\t  'ALTER TABLE change_history ADD COLUMN review_note TEXT',\n86\t  'ALTER TABLE users ADD COLUMN notify_action_required INTEGER DEFAULT 1',\n87\t  'ALTER TABLE users ADD COLUMN notify_review_recommended INTEGER DEFAULT 1',\n88\t  'ALTER TABLE users ADD COLUMN notify_info_only INTEGER DEFAULT 0',\n89\t  'ALTER TABLE users ADD COLUMN webhook_url TEXT',\n90\t  'ALTER TABLE users ADD COLUMN sla_action_hours INTEGER DEFAULT 48',\n91\t  'ALTER TABLE users ADD COLUMN sla_review_hours INTEGER DEFAULT 168',\n92\t  'ALTER TABLE change_history ADD COLUMN assigned_to TEXT',\n93\t  'ALTER TABLE change_history ADD COLUMN assigned_at TEXT',\n94\t  \"ALTER TABLE users ADD COLUMN locale TEXT DEFAULT 'en'\",\n95\t  'ALTER TABLE users ADD COLUMN teams_webhook_url TEXT',\n96\t  'ALTER TABLE users ADD COLUMN discord_webhook_url TEXT',\n97\t  'ALTER TABLE users ADD COLUMN pagerduty_routing_key TEXT',\n98\t];\n99\t\n100\texport async function initSchema(db: Client) {\n101\t  await db.executeMultiple(BASE_TABLES);\n102\t\n103\t  for (const migration of MIGRATIONS) {\n104\t    try {\n105\t      await db.execute(migration);\n106\t    } catch {\n107\t      // Kolumn finns redan — ignorera\n108\t    }\n109\t  }\n110\t}\n111\t"}]},"parent_tool_use_id":"toolu_015rL6bgmjKS8EbaZQjd6pyg","session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"3e603fff-6780-4022-975d-87a12091075c","timestamp":"2026-04-18T21:23:28.972Z"}
