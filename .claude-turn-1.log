{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VnNqX4GQz8UjZnWCiFa2GE","type":"tool_result","content":"1\timport { auth } from '@/lib/auth';\n2\timport { cookies } from 'next/headers';\n3\timport { redirect } from 'next/navigation';\n4\timport { getUserByEmail, getWatchedUrls, getChangeHistory, getComplianceHistory, getComplianceTrend, getComplianceOverview, getUrlLimit, getDashboardStats, getComplianceActionSummary } from '@/lib/db';\n5\timport { t, type Locale } from '@/lib/i18n';\n6\timport { Onboarding } from './onboarding';\n7\timport { AddUrlForm } from './add-url-form';\n8\timport { MonitoredGrid } from './monitored-grid';\n9\timport { ActivityFeed } from './activity-feed';\n10\timport { PopularWatchlists } from './popular-watchlists';\n11\timport { ComplianceFeed } from './compliance-feed';\n12\timport { ComplianceTrend } from './compliance-trend';\n13\timport { ComplianceOverview } from './compliance-overview';\n14\timport { ComplianceTabs } from './compliance-tabs';\n15\timport { SettingsForm } from './settings-form';\n16\timport { SignOutButton } from './sign-out-button';\n17\timport { CheckoutToast } from './checkout-toast';\n18\timport { SectionErrorBoundary } from './error-boundary';\n19\timport { KeyboardShortcutsHelp } from './keyboard-shortcuts';\n20\timport { LanguageSwitcher } from '../locale-provider';\n21\timport { ThemeToggle } from './theme-toggle';\n22\timport { AnimatedNumber } from './animated-number';\n23\timport { DashboardShell } from './dashboard-shell';\n24\timport { FaviconBadge } from './favicon-badge';\n25\timport { ShortcutHint } from './shortcut-hint';\n26\timport ComplianceOnboarding from './compliance-onboarding';\n27\t\n28\tfunction formatLastCheck(dateStr: string | null, locale: Locale): string {\n29\t  if (!dateStr) return t('stats.never', locale);\n30\t  const diff = Math.floor((Date.now() - new Date(dateStr + 'Z').getTime()) / 1000);\n31\t  if (diff < 60) return locale === 'sv' ? 'nyss' : 'just now';\n32\t  if (diff < 3600) return `${Math.floor(diff / 60)}${locale === 'sv' ? ' min sedan' : 'm ago'}`;\n33\t  if (diff < 86400) return `${Math.floor(diff / 3600)}${locale === 'sv' ? 'h sedan' : 'h ago'}`;\n34\t  return `${Math.floor(diff / 86400)}${locale === 'sv' ? 'd sedan' : 'd ago'}`;\n35\t}\n36\t\n37\texport default async function DashboardPage({\n38\t  searchParams,\n39\t}: {\n40\t  searchParams: Promise<{ [key: string]: string | string[] | undefined }>;\n41\t}) {\n42\t  const params = await searchParams;\n43\t  const session = await auth();\n44\t  if (!session?.user?.email) {\n45\t    const ref = typeof params.ref === 'string' ? params.ref : '';\n46\t    redirect(ref ? `/login?ref=${ref}` : '/login');\n47\t  }\n48\t\n49\t  const user = await getUserByEmail(session.user.email);\n50\t  if (!user) redirect('/login');\n51\t\n52\t  const cookieStore = await cookies();\n53\t  const locale = (cookieStore.get('locale')?.value as Locale) || 'en';\n54\t\n55\t  const checkoutSuccess = params.checkout === 'success';\n56\t  const isComplianceRef = params.ref === 'compliance';\n57\t\n58\t  const [urls, history, complianceHistory, trendData, complianceOverview, stats, complianceSummary] = await Promise.all([\n59\t    getWatchedUrls(user.id as string) as Promise<any[]>,\n60\t    getChangeHistory(user.id as string, 50) as Promise<any[]>,\n61\t    getComplianceHistory(user.id as string) as Promise<any[]>,\n62\t    getComplianceTrend(user.id as string) as Promise<any[]>,\n63\t    getComplianceOverview(user.id as string) as Promise<any[]>,\n64\t    getDashboardStats(user.id as string),\n65\t    getComplianceActionSummary(user.id as string),\n66\t  ]);\n67\t  const urlLimit = getUrlLimit(user.plan as string);\n68\t  const planLabel = t(`header.plan.${user.plan as 'free' | 'pro' | 'team'}` as any, locale);\n69\t  const isNewUser = urls.length === 0 && history.length === 0;\n70\t\n71\t  return (\n72\t    <div className=\"min-h-screen\" style={{ background: 'var(--app-bg)', color: 'var(--app-text)' }}>\n73\t\n74\t      {/* Checkout success toast */}\n75\t      <CheckoutToast show={checkoutSuccess} />\n76\t      <FaviconBadge count={complianceSummary.actionRequired + complianceSummary.reviewRecommended} />\n77\t\n78\t      <DashboardShell header={\n79\t        <div className=\"mx-auto flex max-w-5xl items-center justify-between\">\n80\t          <div className=\"flex items-center gap-2.5\">\n81\t            <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600\">\n82\t              <svg className=\"h-4 w-4 text-white\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\">\n83\t                <circle cx=\"12\" cy=\"12\" r=\"3\" />\n84\t                <path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\" />\n85\t              </svg>\n86\t            </div>\n87\t            <h1 className=\"text-lg font-bold tracking-tight hidden sm:block\">\n88\t              change<span className=\"text-blue-600\">brief</span>\n89\t            </h1>\n90\t          </div>\n91\t          <div className=\"flex items-center gap-2 sm:gap-3\">\n92\t            <ThemeToggle />\n93\t            <LanguageSwitcher />\n94\t            <span className=\"rounded-full bg-blue-50 border border-blue-100 px-2.5 sm:px-3 py-1 text-xs font-medium text-blue-700\">\n95\t              {planLabel}\n96\t            </span>\n97\t            {user.plan !== 'team' && (\n98\t              <a\n99\t                href={user.plan === 'pro'\n100\t                  ? 'https://buy.polar.sh/polar_cl_HmjMU2dLQz7qe5fAcTjK2SsssRYDPboqXQJXd4QgARz'\n101\t                  : 'https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF'}\n102\t                target=\"_blank\"\n103\t                rel=\"noopener noreferrer\"\n104\t                className=\"rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 px-2.5 sm:px-3 py-1 text-xs font-medium text-white hover:from-blue-400 hover:to-indigo-400 transition-all\"\n105\t              >\n106\t                {t('header.upgrade', locale)}\n107\t              </a>\n108\t            )}\n109\t            <a\n110\t              href={`mailto:kristian@changebrief.io?subject=${encodeURIComponent(locale === 'sv' ? 'Feedback på changebrief' : 'Feedback on changebrief')}&body=${encodeURIComponent(locale === 'sv'\n111\t                ? '1. Vilka sidor/myndigheter bevakar du?\\n\\n2. Fick du någon ändring klassificerad? Stämde den?\\n\\n3. Vad saknar du?\\n\\n4. Skulle du betala för detta? Hur mycket?\\n\\n5. Vem mer borde testa detta?\\n'\n112\t                : '1. Which pages/agencies are you monitoring?\\n\\n2. Did you get any change classified? Was it accurate?\\n\\n3. What is missing?\\n\\n4. Would you pay for this? How much?\\n\\n5. Who else should try this?\\n')}`}\n113\t              className=\"group flex items-center gap-1.5 rounded-full bg-amber-50 border border-amber-200 px-3 py-1 text-xs font-medium text-amber-700 hover:bg-amber-100 hover:text-amber-800 transition-all animate-pulse hover:animate-none\"\n114\t            >\n115\t              <svg className=\"h-3.5 w-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\" /></svg>\n116\t              {locale === 'sv' ? 'Ge feedback' : 'Give feedback'}\n117\t            </a>\n118\t            <span className=\"text-sm text-slate-400 hidden md:inline\">{session.user.email}</span>\n119\t            <SignOutButton />\n120\t          </div>\n121\t        </div>\n122\t      }>\n123\t\n124\t      <main className=\"relative mx-auto max-w-5xl px-4 sm:px-6 py-6 sm:py-8 space-y-6 sm:space-y-8\">\n125\t        {/* 1. Onboarding for new users */}\n126\t        {isNewUser && isComplianceRef ? (\n127\t          <section>\n128\t            <ComplianceOnboarding canAdd={urls.length < urlLimit} />\n129\t          </section>\n130\t        ) : isNewUser ? (\n131\t          <section>\n132\t            <Onboarding />\n133\t          </section>\n134\t        ) : null}\n135\t\n136\t        {/* 2. Stats bar — compliance summary or generic */}\n137\t        {urls.length > 0 && (\n138\t          <section className=\"space-y-3\">\n139\t            {/* Compliance action summary (shown when compliance data exists) */}\n140\t            {complianceHistory.length > 0 && (complianceSummary.actionRequired > 0 || complianceSummary.reviewRecommended > 0 || complianceSummary.reviewedThisWeek > 0) && (\n141\t              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3 stagger-children\">\n142\t                <div className=\"rounded-xl bg-red-50 border border-red-100 px-4 py-3\">\n143\t                  <p className=\"text-xs text-red-600/70 font-medium\">{locale === 'sv' ? 'Åtgärd krävs' : 'Action required'}</p>\n144\t                  <p className=\"mt-1 text-2xl font-bold text-red-700\"><AnimatedNumber value={complianceSummary.actionRequired} /></p>\n145\t                </div>\n146\t                <div className=\"rounded-xl bg-amber-50 border border-amber-100 px-4 py-3\">\n147\t                  <p className=\"text-xs text-amber-600/70 font-medium\">{locale === 'sv' ? 'Granska' : 'Review'}</p>\n148\t                  <p className=\"mt-1 text-2xl font-bold text-amber-700\"><AnimatedNumber value={complianceSummary.reviewRecommended} /></p>\n149\t                </div>\n150\t                <div className=\"rounded-xl bg-emerald-50 border border-emerald-100 px-4 py-3\">\n151\t                  <p className=\"text-xs text-emerald-600/70 font-medium\">{locale === 'sv' ? 'Granskade (7d)' : 'Reviewed (7d)'}</p>\n152\t                  <p className=\"mt-1 text-2xl font-bold text-emerald-700\"><AnimatedNumber value={complianceSummary.reviewedThisWeek} /></p>\n153\t                </div>\n154\t                <div className=\"rounded-xl glass-card px-4 py-3\">\n155\t                  <p className=\"text-xs text-slate-500 font-medium\">{t('stats.lastcheck', locale)}</p>\n156\t                  <p className=\"mt-1 text-lg font-semibold text-slate-900\">{formatLastCheck(stats.lastCheck, locale)}</p>\n157\t                </div>\n158\t              </div>\n159\t            )}\n160\t            {/* Generic stats */}\n161\t            <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3 stagger-children\">\n162\t              <div className=\"rounded-xl glass-card px-4 py-3 animate-fade-in\">\n163\t                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.pages', locale)}</p>\n164\t                <p className=\"mt-1 text-2xl font-bold text-slate-900\"><AnimatedNumber value={urls.length} /><span className=\"text-sm font-normal text-slate-500\">/{urlLimit}</span></p>\n165\t              </div>\n166\t              <div className=\"rounded-xl glass-card px-4 py-3\">\n167\t                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.changes', locale)}</p>\n168\t                <p className=\"mt-1 text-2xl font-bold text-slate-900\">\n169\t                  {stats.significantChanges7d > 0 ? (\n170\t                    <span className=\"text-orange-600\">{stats.significantChanges7d}</span>\n171\t                  ) : (\n172\t                    <span className=\"text-emerald-600\">0</span>\n173\t                  )}\n174\t                </p>\n175\t              </div>\n176\t              <div className=\"rounded-xl glass-card px-4 py-3\">\n177\t                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.checks', locale)}</p>\n178\t                <p className=\"mt-1 text-2xl font-bold text-slate-900\"><AnimatedNumber value={stats.totalChecks7d} /></p>\n179\t              </div>\n180\t              {!(complianceHistory.length > 0 && (complianceSummary.actionRequired > 0 || complianceSummary.reviewRecommended > 0 || complianceSummary.reviewedThisWeek > 0)) && (\n181\t                <div className=\"rounded-xl glass-card px-4 py-3\">\n182\t                  <p className=\"text-xs text-slate-500 font-medium\">{t('stats.lastcheck', locale)}</p>\n183\t                  <p className=\"mt-1 text-lg font-semibold text-slate-900\">{formatLastCheck(stats.lastCheck, locale)}</p>\n184\t                </div>\n185\t              )}\n186\t            </div>\n187\t          </section>\n188\t        )}\n189\t\n190\t        {/* 2b. Pending first check indicator */}\n191\t        {urls.length > 0 && urls.some((u: any) => !u.last_checked_at) && (\n192\t          <section className=\"rounded-xl bg-blue-50 border border-blue-100 px-5 py-4\">\n193\t            <div className=\"flex items-start gap-3\">\n194\t              <div className=\"mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-100\">\n195\t                <svg className=\"h-4 w-4 text-blue-600 animate-spin\" fill=\"none\" viewBox=\"0 0 24 24\">\n196\t                  <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\" />\n197\t                  <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\" />\n198\t                </svg>\n199\t              </div>\n200\t              <div>\n201\t                <p className=\"text-sm font-medium text-blue-900\">\n202\t                  {locale === 'sv' ? 'Väntar på första kontrollen' : 'Waiting for first check'}\n203\t                </p>\n204\t                <p className=\"text-xs text-blue-700/70 mt-0.5\">\n205\t                  {locale === 'sv'\n206\t                    ? `${urls.filter((u: any) => !u.last_checked_at).length} ${urls.filter((u: any) => !u.last_checked_at).length === 1 ? 'sida' : 'sidor'} kontrolleras inom 6 timmar. Du får ett mejl när resultaten är klara.`\n207\t                    : `${urls.filter((u: any) => !u.last_checked_at).length} ${urls.filter((u: any) => !u.last_checked_at).length === 1 ? 'page' : 'pages'} will be checked within 6 hours. We'll email you when results are ready.`}\n208\t                </p>\n209\t              </div>\n210\t            </div>\n211\t          </section>\n212\t        )}\n213\t\n214\t        {/* 3. Activity Feed + Settings gear */}\n215\t        {urls.length > 0 && (\n216\t          <section>\n217\t            <div className=\"flex items-center justify-between mb-1\">\n218\t              <h2 className=\"text-lg font-semibold text-slate-900/90\">{t('feed.title', locale)}</h2>\n219\t              <details className=\"relative group\">\n220\t                <summary className=\"cursor-pointer list-none [&::-webkit-details-marker]:hidden p-1.5 rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-all duration-200\">\n221\t                  <svg className=\"h-5 w-5 transition-transform duration-300 group-open:rotate-90\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n222\t                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\" />\n223\t                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n224\t                  </svg>\n225\t                </summary>\n226\t                <div className=\"absolute right-0 top-10 z-20 w-80 rounded-2xl p-4 sm:p-5 shadow-xl animate-fade-in\" style={{ background: 'var(--app-bg-card)', borderColor: 'var(--app-border)', border: '1px solid var(--app-border)' }}>\n227\t                  <SettingsForm\n228\t                    initialNotifyEmail={user.notify_email !== 0}\n229\t                    initialSlackWebhookUrl={(user.slack_webhook_url as string) || ''}\n230\t                    initialDigestFrequency={(user.digest_frequency as string) || 'weekly'}\n231\t                    initialNotifyActionRequired={(user as any).notify_action_required !== 0}\n232\t                    initialNotifyReviewRecommended={(user as any).notify_review_recommended !== 0}\n233\t                    initialNotifyInfoOnly={(user as any).notify_info_only === 1}\n234\t                    initialWebhookUrl={(user as any).webhook_url || ''}\n235\t                    initialSlaActionHours={(user as any).sla_action_hours ?? 48}\n236\t                    initialSlaReviewHours={(user as any).sla_review_hours ?? 168}\n237\t                    initialTeamsWebhookUrl={(user as any).teams_webhook_url || ''}\n238\t                    initialDiscordWebhookUrl={(user as any).discord_webhook_url || ''}\n239\t                    initialPagerdutyRoutingKey={(user as any).pagerduty_routing_key || ''}\n240\t                    plan={user.plan as string}\n241\t                  />\n242\t                </div>\n243\t              </details>\n244\t            </div>\n245\t            <p className=\"text-sm text-slate-500 mb-4\">{t('feed.desc', locale)}</p>\n246\t            <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda aktivitetsflödet' : 'Could not load activity feed'}>\n247\t              <ActivityFeed history={history} plan={user.plan as string} />\n248\t            </SectionErrorBoundary>\n249\t          </section>\n250\t        )}\n251\t\n252\t        {/* 3b. Compliance section (tabbed: Feed + Overview) */}\n253\t        {(complianceHistory.length > 0 || complianceOverview.length > 0) && (\n254\t          <section>\n255\t            <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda compliance' : 'Could not load compliance'}>\n256\t              <ComplianceTabs\n257\t                feedContent={<ComplianceFeed history={complianceHistory} plan={user.plan as string} slaActionHours={(user as any).sla_action_hours ?? 48} slaReviewHours={(user as any).sla_review_hours ?? 168} />}\n258\t                overviewContent={<ComplianceOverview data={complianceOverview} />}\n259\t                trendContent={trendData.length > 0 ? <ComplianceTrend data={trendData} /> : null}\n260\t                plan={user.plan as string}\n261\t              />\n262\t            </SectionErrorBoundary>\n263\t          </section>\n264\t        )}\n265\t\n266\t        {/* 4. Monitored Pages section */}\n267\t        <section>\n268\t          <div className=\"flex items-center justify-between mb-3\">\n269\t            <div>\n270\t              <h2 className=\"text-lg font-semibold text-slate-900/90\">{t('monitor.title', locale)}</h2>\n271\t              {!isNewUser && (\n272\t                <span className=\"text-sm text-slate-600\">{urls.length} / {urlLimit} {t('dashboard.monitored.count', locale)}</span>\n273\t              )}\n274\t            </div>\n275\t          </div>\n276\t\n277\t          {/* Inline Add URL form */}\n278\t          <div className=\"rounded-xl glass-card p-4 mb-4\">\n279\t            <AddUrlForm canAdd={urls.length < urlLimit} plan={user.plan as string} />\n280\t          </div>\n281\t\n282\t          {/* URL grid */}\n283\t          <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda bevakade sidor' : 'Could not load monitored pages'}>\n284\t            <MonitoredGrid urls={urls} />\n285\t          </SectionErrorBoundary>\n286\t        </section>\n287\t\n288\t        {/* 5. Discover section */}\n289\t        <section>\n290\t          <h2 className=\"text-lg font-semibold text-slate-900/90 mb-1\">{t('discover.title', locale)}</h2>\n291\t          <p className=\"text-sm text-slate-500 mb-4\">{t('discover.desc', locale)}</p>\n292\t          <PopularWatchlists\n293\t            existingUrls={urls.map((u: any) => u.url)}\n294\t            canAdd={urls.length < urlLimit}\n295\t          />\n296\t        </section>\n297\t\n298\t        {/* Settings moved to gear icon in Activity header */}\n299\t      </main>\n300\t\n301\t      <KeyboardShortcutsHelp />\n302\t      <ShortcutHint />\n303\t      </DashboardShell>\n304\t    </div>\n305\t  );\n306\t}\n307\t"}]},"parent_tool_use_id":null,"session_id":"280bf1c5-ae85-4b13-bbe8-9cde344420de","uuid":"f5c81007-9ba7-48c8-b3fd-85a447e0d95a","timestamp":"2026-04-18T21:25:10.683Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wigclaw/overnight-work/changebrief-night-improve/app/src/app/dashboard/page.tsx","content":"import { auth } from '@/lib/auth';\nimport { cookies } from 'next/headers';\nimport { redirect } from 'next/navigation';\nimport { getUserByEmail, getWatchedUrls, getChangeHistory, getComplianceHistory, getComplianceTrend, getComplianceOverview, getUrlLimit, getDashboardStats, getComplianceActionSummary } from '@/lib/db';\nimport { t, type Locale } from '@/lib/i18n';\nimport { Onboarding } from './onboarding';\nimport { AddUrlForm } from './add-url-form';\nimport { MonitoredGrid } from './monitored-grid';\nimport { ActivityFeed } from './activity-feed';\nimport { PopularWatchlists } from './popular-watchlists';\nimport { ComplianceFeed } from './compliance-feed';\nimport { ComplianceTrend } from './compliance-trend';\nimport { ComplianceOverview } from './compliance-overview';\nimport { ComplianceTabs } from './compliance-tabs';\nimport { SettingsForm } from './settings-form';\nimport { SignOutButton } from './sign-out-button';\nimport { CheckoutToast } from './checkout-toast';\nimport { SectionErrorBoundary } from './error-boundary';\nimport { KeyboardShortcutsHelp } from './keyboard-shortcuts';\nimport { LanguageSwitcher } from '../locale-provider';\nimport { ThemeToggle } from './theme-toggle';\nimport { AnimatedNumber } from './animated-number';\nimport { DashboardShell } from './dashboard-shell';\nimport { FaviconBadge } from './favicon-badge';\nimport { ShortcutHint } from './shortcut-hint';\nimport ComplianceOnboarding from './compliance-onboarding';\n\nfunction formatLastCheck(dateStr: string | null, locale: Locale): string {\n  if (!dateStr) return t('stats.never', locale);\n  const diff = Math.floor((Date.now() - new Date(dateStr + 'Z').getTime()) / 1000);\n  if (diff < 60) return locale === 'sv' ? 'nyss' : 'just now';\n  if (diff < 3600) return `${Math.floor(diff / 60)}${locale === 'sv' ? ' min sedan' : 'm ago'}`;\n  if (diff < 86400) return `${Math.floor(diff / 3600)}${locale === 'sv' ? 'h sedan' : 'h ago'}`;\n  return `${Math.floor(diff / 86400)}${locale === 'sv' ? 'd sedan' : 'd ago'}`;\n}\n\nexport default async function DashboardPage({\n  searchParams,\n}: {\n  searchParams: Promise<{ [key: string]: string | string[] | undefined }>;\n}) {\n  const params = await searchParams;\n  const session = await auth();\n  if (!session?.user?.email) {\n    const ref = typeof params.ref === 'string' ? params.ref : '';\n    redirect(ref ? `/login?ref=${ref}` : '/login');\n  }\n\n  const user = await getUserByEmail(session.user.email);\n  if (!user) redirect('/login');\n\n  const cookieStore = await cookies();\n  const locale = (cookieStore.get('locale')?.value as Locale) || 'en';\n\n  const checkoutSuccess = params.checkout === 'success';\n  const isComplianceRef = params.ref === 'compliance';\n\n  const [urls, history, complianceHistory, trendData, complianceOverview, stats, complianceSummary] = await Promise.all([\n    getWatchedUrls(user.id as string) as Promise<any[]>,\n    getChangeHistory(user.id as string, 50) as Promise<any[]>,\n    getComplianceHistory(user.id as string) as Promise<any[]>,\n    getComplianceTrend(user.id as string) as Promise<any[]>,\n    getComplianceOverview(user.id as string) as Promise<any[]>,\n    getDashboardStats(user.id as string),\n    getComplianceActionSummary(user.id as string),\n  ]);\n  const urlLimit = getUrlLimit(user.plan as string);\n  const planLabel = t(`header.plan.${user.plan as 'free' | 'pro' | 'team'}` as any, locale);\n  const isNewUser = urls.length === 0 && history.length === 0;\n\n  return (\n    <div className=\"min-h-screen\" style={{ background: 'var(--app-bg)', color: 'var(--app-text)' }}>\n\n      {/* Checkout success toast */}\n      <CheckoutToast show={checkoutSuccess} />\n      <FaviconBadge count={complianceSummary.actionRequired + complianceSummary.reviewRecommended} />\n\n      <DashboardShell header={\n        <div className=\"mx-auto flex max-w-5xl items-center justify-between\">\n          <div className=\"flex items-center gap-2.5\">\n            <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600\">\n              <svg className=\"h-4 w-4 text-white\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"2.5\">\n                <circle cx=\"12\" cy=\"12\" r=\"3\" />\n                <path d=\"M2 12s4-7 10-7 10 7 10 7-4 7-10 7-10-7-10-7z\" />\n              </svg>\n            </div>\n            <h1 className=\"text-lg font-bold tracking-tight hidden sm:block\">\n              change<span className=\"text-blue-600\">brief</span>\n            </h1>\n          </div>\n          <div className=\"flex items-center gap-2 sm:gap-3\">\n            <ThemeToggle />\n            <LanguageSwitcher />\n            <span className=\"rounded-full bg-blue-50 border border-blue-100 px-2.5 sm:px-3 py-1 text-xs font-medium text-blue-700\">\n              {planLabel}\n            </span>\n            {user.plan !== 'team' && (\n              <a\n                href={user.plan === 'pro'\n                  ? 'https://buy.polar.sh/polar_cl_HmjMU2dLQz7qe5fAcTjK2SsssRYDPboqXQJXd4QgARz'\n                  : 'https://buy.polar.sh/polar_cl_JDnQNmWBFMsJp56ntC0GPsweHhIizDVhwWGIk4CAFVF'}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 px-2.5 sm:px-3 py-1 text-xs font-medium text-white hover:from-blue-400 hover:to-indigo-400 transition-all\"\n              >\n                {t('header.upgrade', locale)}\n              </a>\n            )}\n            <a\n              href={`mailto:kristian@changebrief.io?subject=${encodeURIComponent(locale === 'sv' ? 'Feedback på changebrief' : 'Feedback on changebrief')}&body=${encodeURIComponent(locale === 'sv'\n                ? '1. Vilka sidor/myndigheter bevakar du?\\n\\n2. Fick du någon ändring klassificerad? Stämde den?\\n\\n3. Vad saknar du?\\n\\n4. Skulle du betala för detta? Hur mycket?\\n\\n5. Vem mer borde testa detta?\\n'\n                : '1. Which pages/agencies are you monitoring?\\n\\n2. Did you get any change classified? Was it accurate?\\n\\n3. What is missing?\\n\\n4. Would you pay for this? How much?\\n\\n5. Who else should try this?\\n')}`}\n              className=\"group flex items-center gap-1.5 rounded-full bg-amber-50 border border-amber-200 px-3 py-1 text-xs font-medium text-amber-700 hover:bg-amber-100 hover:text-amber-800 transition-all animate-pulse hover:animate-none\"\n            >\n              <svg className=\"h-3.5 w-3.5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={2} d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\" /></svg>\n              {locale === 'sv' ? 'Ge feedback' : 'Give feedback'}\n            </a>\n            <span className=\"text-sm text-slate-400 hidden md:inline\">{session.user.email}</span>\n            <SignOutButton />\n          </div>\n        </div>\n      }>\n\n      <main className=\"relative mx-auto max-w-5xl px-4 sm:px-6 py-6 sm:py-8 space-y-6 sm:space-y-8\">\n        {/* 1. Onboarding for new users */}\n        {isNewUser && isComplianceRef ? (\n          <section>\n            <ComplianceOnboarding canAdd={urls.length < urlLimit} />\n          </section>\n        ) : isNewUser ? (\n          <section>\n            <Onboarding />\n          </section>\n        ) : null}\n\n        {/* 2. Stats bar — compliance summary or generic */}\n        {urls.length > 0 && (\n          <section className=\"space-y-3\">\n            {/* Compliance action summary (shown when compliance data exists) */}\n            {complianceHistory.length > 0 && (complianceSummary.actionRequired > 0 || complianceSummary.reviewRecommended > 0 || complianceSummary.reviewedThisWeek > 0) && (\n              <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3 stagger-children\">\n                <div className=\"rounded-xl bg-red-50 border border-red-100 px-4 py-3\">\n                  <p className=\"text-xs text-red-600/70 font-medium\">{locale === 'sv' ? 'Åtgärd krävs' : 'Action required'}</p>\n                  <p className=\"mt-1 text-2xl font-bold text-red-700\"><AnimatedNumber value={complianceSummary.actionRequired} /></p>\n                </div>\n                <div className=\"rounded-xl bg-amber-50 border border-amber-100 px-4 py-3\">\n                  <p className=\"text-xs text-amber-600/70 font-medium\">{locale === 'sv' ? 'Granska' : 'Review'}</p>\n                  <p className=\"mt-1 text-2xl font-bold text-amber-700\"><AnimatedNumber value={complianceSummary.reviewRecommended} /></p>\n                </div>\n                <div className=\"rounded-xl bg-emerald-50 border border-emerald-100 px-4 py-3\">\n                  <p className=\"text-xs text-emerald-600/70 font-medium\">{locale === 'sv' ? 'Granskade (7d)' : 'Reviewed (7d)'}</p>\n                  <p className=\"mt-1 text-2xl font-bold text-emerald-700\"><AnimatedNumber value={complianceSummary.reviewedThisWeek} /></p>\n                </div>\n                <div className=\"rounded-xl glass-card px-4 py-3\">\n                  <p className=\"text-xs text-slate-500 font-medium\">{t('stats.lastcheck', locale)}</p>\n                  <p className=\"mt-1 text-lg font-semibold text-slate-900\">{formatLastCheck(stats.lastCheck, locale)}</p>\n                </div>\n              </div>\n            )}\n            {/* Generic stats */}\n            <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3 stagger-children\">\n              <div className=\"rounded-xl glass-card px-4 py-3 animate-fade-in\">\n                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.pages', locale)}</p>\n                <p className=\"mt-1 text-2xl font-bold text-slate-900\"><AnimatedNumber value={urls.length} /><span className=\"text-sm font-normal text-slate-500\">/{urlLimit}</span></p>\n              </div>\n              <div className=\"rounded-xl glass-card px-4 py-3\">\n                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.changes', locale)}</p>\n                <p className=\"mt-1 text-2xl font-bold text-slate-900\">\n                  {stats.significantChanges7d > 0 ? (\n                    <span className=\"text-orange-600\">{stats.significantChanges7d}</span>\n                  ) : (\n                    <span className=\"text-emerald-600\">0</span>\n                  )}\n                </p>\n              </div>\n              <div className=\"rounded-xl glass-card px-4 py-3\">\n                <p className=\"text-xs text-slate-500 font-medium\">{t('stats.checks', locale)}</p>\n                <p className=\"mt-1 text-2xl font-bold text-slate-900\"><AnimatedNumber value={stats.totalChecks7d} /></p>\n              </div>\n              {!(complianceHistory.length > 0 && (complianceSummary.actionRequired > 0 || complianceSummary.reviewRecommended > 0 || complianceSummary.reviewedThisWeek > 0)) && (\n                <div className=\"rounded-xl glass-card px-4 py-3\">\n                  <p className=\"text-xs text-slate-500 font-medium\">{t('stats.lastcheck', locale)}</p>\n                  <p className=\"mt-1 text-lg font-semibold text-slate-900\">{formatLastCheck(stats.lastCheck, locale)}</p>\n                </div>\n              )}\n            </div>\n          </section>\n        )}\n\n        {/* 2b. Pending first check indicator */}\n        {urls.length > 0 && urls.some((u: any) => !u.last_checked_at) && (\n          <section className=\"rounded-xl bg-blue-50 border border-blue-100 px-5 py-4\">\n            <div className=\"flex items-start gap-3\">\n              <div className=\"mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-100\">\n                <svg className=\"h-4 w-4 text-blue-600 animate-spin\" fill=\"none\" viewBox=\"0 0 24 24\">\n                  <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\" />\n                  <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\" />\n                </svg>\n              </div>\n              <div>\n                <p className=\"text-sm font-medium text-blue-900\">\n                  {locale === 'sv' ? 'Väntar på första kontrollen' : 'Waiting for first check'}\n                </p>\n                <p className=\"text-xs text-blue-700/70 mt-0.5\">\n                  {locale === 'sv'\n                    ? `${urls.filter((u: any) => !u.last_checked_at).length} ${urls.filter((u: any) => !u.last_checked_at).length === 1 ? 'sida' : 'sidor'} kontrolleras inom 6 timmar. Du får ett mejl när resultaten är klara.`\n                    : `${urls.filter((u: any) => !u.last_checked_at).length} ${urls.filter((u: any) => !u.last_checked_at).length === 1 ? 'page' : 'pages'} will be checked within 6 hours. We'll email you when results are ready.`}\n                </p>\n              </div>\n            </div>\n          </section>\n        )}\n\n        {/* 3. Activity Feed + Settings gear */}\n        {urls.length > 0 && (\n          <section>\n            <div className=\"flex items-center justify-between mb-1\">\n              <h2 className=\"text-lg font-semibold text-slate-900/90\">{t('feed.title', locale)}</h2>\n              <details className=\"relative group\">\n                <summary className=\"cursor-pointer list-none [&::-webkit-details-marker]:hidden p-1.5 rounded-lg text-slate-400 hover:text-slate-700 hover:bg-slate-100 transition-all duration-200\">\n                  <svg className=\"h-5 w-5 transition-transform duration-300 group-open:rotate-90\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z\" />\n                    <path strokeLinecap=\"round\" strokeLinejoin=\"round\" strokeWidth={1.5} d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n                  </svg>\n                </summary>\n                <div className=\"absolute right-0 top-10 z-20 w-80 rounded-2xl p-4 sm:p-5 shadow-xl animate-fade-in\" style={{ background: 'var(--app-bg-card)', borderColor: 'var(--app-border)', border: '1px solid var(--app-border)' }}>\n                  <SettingsForm\n                    initialNotifyEmail={user.notify_email !== 0}\n                    initialSlackWebhookUrl={(user.slack_webhook_url as string) || ''}\n                    initialDigestFrequency={(user.digest_frequency as string) || 'weekly'}\n                    initialNotifyActionRequired={(user as any).notify_action_required !== 0}\n                    initialNotifyReviewRecommended={(user as any).notify_review_recommended !== 0}\n                    initialNotifyInfoOnly={(user as any).notify_info_only === 1}\n                    initialWebhookUrl={(user as any).webhook_url || ''}\n                    initialSlaActionHours={(user as any).sla_action_hours ?? 48}\n                    initialSlaReviewHours={(user as any).sla_review_hours ?? 168}\n                    initialTeamsWebhookUrl={(user as any).teams_webhook_url || ''}\n                    initialDiscordWebhookUrl={(user as any).discord_webhook_url || ''}\n                    initialPagerdutyRoutingKey={(user as any).pagerduty_routing_key || ''}\n                    plan={user.plan as string}\n                  />\n                </div>\n              </details>\n            </div>\n            <p className=\"text-sm text-slate-500 mb-4\">{t('feed.desc', locale)}</p>\n            <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda aktivitetsflödet' : 'Could not load activity feed'}>\n              <ActivityFeed history={history} plan={user.plan as string} />\n            </SectionErrorBoundary>\n          </section>\n        )}\n\n        {/* 3b. Compliance section (tabbed: Feed + Overview) */}\n        {(complianceHistory.length > 0 || complianceOverview.length > 0) && (\n          <section>\n            <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda compliance' : 'Could not load compliance'}>\n              <ComplianceTabs\n                feedContent={<ComplianceFeed history={complianceHistory} plan={user.plan as string} slaActionHours={(user as any).sla_action_hours ?? 48} slaReviewHours={(user as any).sla_review_hours ?? 168} />}\n                overviewContent={<ComplianceOverview data={complianceOverview} />}\n                trendContent={trendData.length > 0 ? <ComplianceTrend data={trendData} /> : null}\n                plan={user.plan as string}\n              />\n            </SectionErrorBoundary>\n          </section>\n        )}\n\n        {/* 4. Monitored Pages section */}\n        <section>\n          <div className=\"flex items-center justify-between mb-3\">\n            <div>\n              <h2 className=\"text-lg font-semibold text-slate-900/90\">{t('monitor.title', locale)}</h2>\n              {!isNewUser && (\n                <span className=\"text-sm text-slate-600\">{urls.length} / {urlLimit} {t('dashboard.monitored.count', locale)}</span>\n              )}\n            </div>\n          </div>\n\n          {/* Inline Add URL form */}\n          <div className=\"rounded-xl glass-card p-4 mb-4\">\n            <AddUrlForm canAdd={urls.length < urlLimit} plan={user.plan as string} />\n          </div>\n\n          {/* URL grid */}\n          <SectionErrorBoundary fallbackTitle={locale === 'sv' ? 'Kunde inte ladda bevakade sidor' : 'Could not load monitored pages'}>\n            <MonitoredGrid urls={urls} />\n          </SectionErrorBoundary>\n        </section>\n\n        {/* 5. Discover section */}\n        <section>\n          <h2 className=\"text-lg font-semibold text-slate-900/90 mb-1\">{t('discover.title', locale)}</h2>\n          <p className=\"text-sm text-slate-500 mb-4\">{t('discover.desc', locale)}</p>\n          <PopularWatchlists\n            existingUrls={urls.map((u: any) => u.url)}\n            canAdd={urls.length < urlLimit}\n          />\n        </section>\n\n        {/* Settings moved to gear icon in Activity header */}\n      </main>\n\n      <KeyboardShortcutsHelp />\n      <ShortcutHint />\n      </DashboardShell>\n    </div>\n  );\n}\n","numLines":307,"startLine":1,"totalLines":307}}}
